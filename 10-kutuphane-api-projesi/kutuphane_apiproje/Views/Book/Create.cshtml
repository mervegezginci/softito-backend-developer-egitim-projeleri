@model kutuphane_apiproje.Models.Book

@{
    ViewData["Title"] = "Yeni Kitap";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="form-container">

    <div class="book-form-card">

        <div class="page-header">
            <span>Kütüphane Yönetimi</span>
            <h2>Yeni Kitap Ekle</h2>
        </div>

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label>Kitap Adı</label>
                <input asp-for="Title" class="form-control">
            </div>

            <div class="form-group">
                <label>Açıklama</label>
                <textarea asp-for="Description" class="form-control area"></textarea>
            </div>

            <div class="form-group">
                <label>Resim Url</label>
                <input asp-for="ImageUrl" class="form-control">
            </div>

            <div class="row">

                <div class="col-md-6">
                    <label>Sayfa Sayısı</label>
                    <input asp-for="PageCount" class="form-control">
                </div>

                <div class="col-md-6">
                    <label>Basım Yılı</label>
                    <input asp-for="PublishYear" class="form-control">
                </div>

            </div>

            <div class="row mt-4">

                <div class="col-md-6">

                    <label>Yazar</label>

                    <select asp-for="AuthorId"
                            asp-items="ViewBag.Authors"
                            class="form-control">
                    </select>

                </div>

                <div class="col-md-6">

                    <label>Kategori</label>

                    <select asp-for="CategoryId"
                            asp-items="ViewBag.Categories"
                            class="form-control">
                    </select>

                </div>

            </div>

            <div class="mt-4">

                <div class="form-check">

                    <input asp-for="IsAvailable"
                           class="form-check-input">

                    <label class="form-check-label">
                        Ödünç Verilebilir
                    </label>

                </div>

            </div>

            <button class="save-btn">
                Kaydet
            </button>

            <a asp-action="Index" class="back-btn">
                Geri Dön
            </a>
        </form>

    </div>

</div>
