@model kutuphane_apiproje.Models.Book

@{
    ViewData["Title"] = "Düzenle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="form-container">

    <div class="book-form-card">

        <div class="page-header">
            <span>Kütüphane Yönetimi</span>
            <h2>Kitap Düzenle</h2>
        </div>

        <form asp-action="Edit">

            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label>Kitap Adı</label>
                <input asp-for="Title" class="form-control">
            </div>

            <div class="form-group">
                <label>Açıklama</label>
                <textarea asp-for="Description" class="form-control area"></textarea>
            </div>

            <div class="form-group">
                <label>Resim Url</label>
                <input asp-for="ImageUrl" class="form-control">
            </div>

            <div class="row">

                <div class="col-md-6">

                    <label>Sayfa Sayısı</label>

                    <input asp-for="PageCount"
                           class="form-control">

                </div>

                <div class="col-md-6">

                    <label>Basım Yılı</label>

                    <input asp-for="PublishYear"
                           class="form-control">

                </div>

            </div>

            <div class="row mt-4">

                <div class="col-md-6">

                    <label>Yazar</label>

                    <select asp-for="AuthorId"
                            asp-items="ViewBag.Authors"
                            class="form-control">
                    </select>

                </div>

                <div class="col-md-6">

                    <label>Kategori</label>

                    <select asp-for="CategoryId"
                            asp-items="ViewBag.Categories"
                            class="form-control">
                    </select>

                </div>

            </div>

            <button class="save-btn mt-4">
                Güncelle
            </button>


            <a asp-action="Index" class="back-btn">
                Geri Dön
            </a>
        </form>

    </div>

</div>

