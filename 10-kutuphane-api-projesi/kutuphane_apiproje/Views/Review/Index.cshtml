@model IEnumerable<kutuphane_apiproje.Models.Review>

@{
    ViewData["Title"] = "Yorumlar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="review-page">

    <div class="page-title-area">
        <div>
            <span>Yönetim Paneli</span>
            <h2>Yorumlar</h2>
        </div>
        <a asp-action="Create" class="add-btn">+ Yeni Yorum</a>
    </div>

    <!-- Arama Kutusu -->
    <form method="get" style="margin-bottom: 20px; max-width: 400px;">
        <div style="display:flex; gap:8px;">
            <input type="text" name="search" class="form-control" placeholder="Yorum veya kitap adı ara..."
                   value="@ViewBag.Search" id="txtSearch" style="border-radius:8px;" />
            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <a href="/Review/Index" class="btn btn-outline-secondary" style="border-radius:8px;">✕</a>
            }
        </div>
    </form>

    <div class="review-table-card">

        <table class="review-table">

            <thead>
                <tr>
                    <th>Puan</th>
                    <th>Yorum</th>
                    <th>Tarih</th>
                    <th>Kitap</th>
                    <th>Kullanıcı</th>
                    <th>İşlemler</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>
                            <span class="rating">
                                ★ @item.Rating
                            </span>
                        </td>

                        <td>@item.Comment</td>

                        <td>@item.CreatedDate.ToString("dd.MM.yyyy")</td>

                        <td>@item.Book?.Title</td>

                        <td>@item.User?.UserName</td>

                        <td>

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="edit-btn">
                                Düzenle
                            </a>

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="detail-btn">
                                Detay
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="delete-btn">
                                Sil
                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>