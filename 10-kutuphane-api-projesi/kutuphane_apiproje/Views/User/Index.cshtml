@model List<(kutuphane_apiproje.Models.ApplicationUser User, IList<string> Roles)>

@{
    ViewData["Title"] = "Kullanıcılar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <p class="text-muted small mb-1 text-uppercase fw-semibold" style="letter-spacing: 2px;">Yönetim Paneli</p>
        <h4 class="fw-bold mb-0">Kullanıcı Yönetimi</h4>
    </div>
    <span class="badge bg-primary px-3 py-2 fs-6">@Model.Count kullanıcı</span>
</div>

<!-- Arama -->
<form method="get" class="mb-4" style="max-width: 420px;">
    <div class="input-group">
        <span class="input-group-text bg-white"><i class="fas fa-search text-muted"></i></span>
        <input type="text" name="search" class="form-control" placeholder="İsim veya email ile ara..."
               value="@ViewBag.Search" id="txtSearch" />
        @if (!string.IsNullOrEmpty(ViewBag.Search as string))
        {
            <a href="/User/Index" class="btn btn-outline-secondary">
                <i class="fas fa-times"></i>
            </a>
        }
    </div>
</form>

<div class="card border-0 shadow-sm" style="border-radius: 14px; overflow: hidden;">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Kullanıcı Adı</th>
                    <th>Email</th>
                    <th>Rol</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <i class="fas fa-users fs-2 d-block mb-2"></i>
                            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
                            {
                                <span>«<strong>@ViewBag.Search</strong>» için sonuç bulunamadı.</span>
                            }
                            else
                            {
                                <span>Henüz kayıtlı kullanıcı bulunmuyor.</span>
                            }
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var (user, roles) in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-bold"
                                         style="width: 38px; height: 38px; font-size: 0.9rem; flex-shrink: 0;">
                                        @(string.IsNullOrEmpty(user.Name) ? "?" : user.Name[0].ToString().ToUpper())
                                    </div>
                                    <span class="fw-semibold">@user.Name</span>
                                </div>
                            </td>
                            <td class="text-muted">@user.Email</td>
                            <td>
                                @if (roles.Contains("Admin"))
                                {
                                    <span class="badge bg-danger">Admin</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Kullanıcı</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (roles.Contains("Admin"))
                                {
                                    <form asp-action="RemoveAdmin" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('Bu kullanıcının Admin rolünü kaldırmak istiyor musunuz?')">
                                            <i class="fas fa-user-minus me-1"></i> Admin Kaldır
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="MakeAdmin" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-user-shield me-1"></i> Admin Yap
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    // Arama kutusuna yazıldıkça formu otomatik gönder
    let searchTimeout;
    document.getElementById('txtSearch').addEventListener('input', function () {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(function () {
            document.querySelector('form').submit();
        }, 400);
    });
</script>