@using kutuphane_apiproje.ViewModels
@model LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="account-container">
    <div class="account-box">

        <h2>Hoşgeldiniz</h2>

        <form asp-action="Login" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-4">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="Email giriniz" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Şifre</label>
                <input asp-for="Password" class="form-control" placeholder="Enter your password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4">

                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label">
                        Beni Hatırla
                    </label>
                </div>

                <a asp-controller="Account"
                   asp-action="VerifyEmail"
                   class="forgot-link">
                    Şifremi Unuttum?
                </a>

            </div>

            <button type="submit" class="login-btn">
                Giriş Yap
            </button>

            <div class="text-center mt-4">
                <p>
                    Hesabınız yok mu?
                    <a asp-controller="Account"
                       asp-action="Register">
                        Hesap Oluşturun
                    </a>
                </p>

                <a asp-controller="Home"
                   asp-action="Index"
                   class="back-link">
                    ← Ana Sayfaya Geri Dön
                </a>
            </div>

        </form>

    </div>
</div>

<style>

    body {
        background: #f5f3ef;
        font-family: 'Inter', sans-serif;
    }

    .account-container {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 30px;
    }

    .account-box {
        width: 460px;
        background: white;
        padding: 50px;
        border: 1px solid #e7dfd8;
        box-shadow: 0 10px 30px rgba(0,0,0,.05);
    }

        .account-box h2 {
            font-family: Georgia, serif;
            font-size: 50px;
            font-weight: 400;
            text-align: center;
            color: #1f1f1f;
            margin-bottom: 40px;
        }

    .form-label {
        color: #666;
        margin-bottom: 10px;
    }

    .form-control {
        height: 55px;
        border-radius: 0;
        border: 1px solid #ddd;
        background: #faf9f7;
        padding: 15px;
        transition: .3s;
    }

        .form-control:focus {
            border-color: #c5a992;
            box-shadow: none;
            background: white;
        }

    .form-check-label {
        color: #666;
    }

    .forgot-link {
        color: #c5a992;
        text-decoration: none;
        transition: .3s;
    }

        .forgot-link:hover {
            color: #1f1f1f;
        }

    .login-btn {
        width: 100%;
        height: 55px;
        background: transparent;
        border: 1px solid #c5a992;
        color: #c5a992;
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
        transition: .4s;
    }

        .login-btn:hover {
            background: #c5a992;
            color: white;
        }

    p {
        color: #777;
    }

    a {
        color: #c5a992;
        text-decoration: none;
        transition: .3s;
    }

        a:hover {
            color: #1f1f1f;
        }

    .back-link {
        display: inline-block;
        margin-top: 10px;
    }

    .text-danger {
        font-size: 14px;
    }

    @@media(max-width:576px) {

        .account-box {
            width: 100%;
            padding: 35px 25px;
        }

            .account-box h2 {
                font-size: 38px;
            }

        .d-flex {
            flex-direction: column;
            gap: 15px;
            align-items: start !important;
        }
    }

</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}