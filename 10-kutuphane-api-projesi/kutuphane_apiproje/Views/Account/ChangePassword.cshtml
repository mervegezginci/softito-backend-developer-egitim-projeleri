@using kutuphane_apiproje.ViewModels
@model ChangePasswordViewModel

@{
    ViewData["Title"] = "Şifre Değiştir";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="account-container">
    <div class="account-box">

        <h2>Şifre Değiştir</h2>

        <form asp-action="ChangePassword" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-4">
                <label asp-for="Email" class="form-label">E-posta Adresi</label>
                <input asp-for="Email" class="form-control readonly-input" readonly />
            </div>

            <div class="mb-4">
                <label asp-for="NewPassword" class="form-label">Yeni Şifre</label>
                <input asp-for="NewPassword"
                       class="form-control"
                       placeholder="Yeni şifrenizi giriniz" />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmNewPassword" class="form-label">Şifre Tekrar</label>
                <input asp-for="ConfirmNewPassword"
                       class="form-control"
                       placeholder="Yeni şifrenizi tekrar giriniz" />
                <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="change-btn">
                Şifreyi Güncelle
            </button>

            <div class="text-center mt-4">
                <a asp-controller="Account"
                   asp-action="VerifyEmail"
                   class="back-link">
                    ← Geri Dön
                </a>
            </div>

        </form>

    </div>
</div>

<style>

    body {
        background: #f5f3ef;
        font-family: 'Inter', sans-serif;
    }

    .account-container {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 30px;
    }

    .account-box {
        width: 500px;
        background: #fff;
        border: 1px solid #e6e0d8;
        padding: 50px;
        box-shadow: 0 10px 30px rgba(0,0,0,.05);
    }

        .account-box h2 {
            text-align: center;
            font-family: Georgia, serif;
            font-size: 48px;
            font-weight: 400;
            color: #1f1f1f;
            margin-bottom: 40px;
        }

    .form-label {
        color: #666;
        font-size: 15px;
        margin-bottom: 10px;
    }

    .form-control {
        height: 55px;
        border-radius: 0;
        border: 1px solid #ddd;
        background: #faf9f7;
        padding: 15px;
        transition: .3s;
    }

        .form-control:focus {
            border-color: #c5a992;
            box-shadow: none;
            background: #fff;
        }

    .readonly-input {
        background: #f1eeea !important;
        color: #777;
    }

    .change-btn {
        width: 100%;
        height: 55px;
        border: 1px solid #c5a992;
        background: transparent;
        color: #c5a992;
        font-size: 14px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: .4s;
    }

        .change-btn:hover {
            background: #c5a992;
            color: white;
        }

    .back-link {
        color: #c5a992;
        text-decoration: none;
        transition: .3s;
    }

        .back-link:hover {
            color: #1f1f1f;
        }

    .text-danger {
        font-size: 14px;
    }

    @@media(max-width:576px) {

        .account-box {
            width: 100%;
            padding: 35px 25px;
        }

            .account-box h2 {
                font-size: 38px;
            }
    }

</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}