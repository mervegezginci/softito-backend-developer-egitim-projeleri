@using kutuphane_apiproje.ViewModels
@model VerifyEmailViewModel

@{
    ViewData["Title"] = "E-posta Doğrulama";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<style>
    body {
        background: #f5f3ef;
        font-family: 'Inter', sans-serif;
        color: #222;
    }

    .account-container {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px 20px;
    }

    .account-box {
        width: 500px;
        background: #fff;
        padding: 50px;
        border: 1px solid #e6e0d8;
        box-shadow: 0 15px 40px rgba(0,0,0,.05);
    }

        .account-box h2 {
            font-family: Georgia, serif;
            font-size: 48px;
            font-weight: 400;
            color: #1e1e1e;
            text-align: center;
            margin-bottom: 40px;
        }

    .form-label {
        color: #666;
        font-size: 15px;
        margin-bottom: 10px;
    }

    .form-control {
        height: 58px;
        border: 1px solid #ddd;
        border-radius: 0;
        background: #faf9f7;
        padding: 15px;
        font-size: 15px;
        transition: .3s;
    }

        .form-control:focus {
            border-color: #c5a992;
            box-shadow: none;
            background: white;
        }

    .verify-btn {
        width: 100%;
        height: 58px;
        border: 1px solid #c5a992;
        background: transparent;
        color: #c5a992;
        font-size: 14px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: .4s;
    }

        .verify-btn:hover {
            background: #c5a992;
            color: white;
        }

    .back-link {
        display: inline-block;
        margin-top: 25px;
        color: #777;
        text-decoration: none;
        transition: .3s;
    }

        .back-link:hover {
            color: #c5a992;
        }

    .text-danger {
        font-size: 14px;
    }

    @@media(max-width:576px) {
        .account-box {
            width: 100%;
            padding: 35px 25px;
        }

            .account-box h2 {
                font-size: 36px;
            }
    }
</style>

<div class="account-container">
    <div class="account-box">

        <h2>E-posta Doğrulama</h2>

        <form asp-action="VerifyEmail" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-4">
                <label asp-for="Email" class="form-label">
                    E-posta Adresi
                </label>

                <input asp-for="Email"
                       class="form-control"
                       placeholder="E-posta adresinizi giriniz" />

                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <input type="submit"
                   value="E-postayı Doğrula"
                   class="verify-btn" />

            <div class="text-center">
                <a asp-controller="Home"
                   asp-action="Index"
                   class="back-link">
                    ← Ana Sayfaya Dön
                </a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}