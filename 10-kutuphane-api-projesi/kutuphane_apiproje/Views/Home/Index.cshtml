<section id="quotation" class="align-center pb-5 mb-5">

	<div class="container">

		<div class="section-header align-center">
			<div class="title">
				<span>Okuyucularımız</span>
			</div>

			<h2 class="section-title">
				Okuyucu Değerlendirmeleri
			</h2>
		</div>

		<div class="review-slider">

			@foreach (var i in Model.Reviews)
			{
				<div class="review-item">

					<blockquote>

						<q>
							@i.Comment
						</q>

						<div class="review-stars">

							@for (int j = 0; j < i.Rating; j++)
							{
								<span>★</span>
							}

						</div>

						<h5 class="mt-3">
							@i.User?.UserName
						</h5>

					</blockquote>

				</div>
			}

		</div>

	</div>

</section>

<style>
	.review-slider{
    margin-top:40px;
}

.review-item{
    padding:25px;
}

.review-item blockquote{
    background:#F3F2EC;
    padding:45px;
    border-radius:10px;
    text-align:center;
    min-height:240px;
}

.review-item q{
    font-size:20px;
    font-style:italic;
    line-height:1.8;
    color:#444;
}

.review-stars{
    margin-top:20px;
    color:#C5A992;
    font-size:22px;
}

.review-item h5{
    margin-top:25px;
    color:#74642F;
}

	.author-card {
		background: #F3F2EC;
		border: 1px solid #E7E2D8;
		padding: 45px 25px;
		text-align: center;
		transition: .4s;
		position: relative;
		overflow: hidden;
		height: 100%;
	}

		.author-card:hover {
			background: #ECE8DF;
		}

	.author-content {
		position: relative;
		z-index: 2;
	}

	.author-country {
		display: block;
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 2px;
		color: #afafaf;
		margin-bottom: 15px;
	}

	.author-name {
		font-family: var(--heading-font);
		font-size: 30px;
		color: #2f2f2f;
		margin-bottom: 20px;
	}

	.author-divider {
		width: 40px;
		height: 2px;
		background: #C5A992;
		margin: 20px auto;
	}

	.author-book-count {
		color: #74642F;
		font-size: 15px;
		letter-spacing: 1px;
		text-transform: uppercase;
	}


	.stat-box {
		border-top: 1px solid #ddd;
		border-bottom: 1px solid #ddd;
		padding: 50px 20px;
		text-align: center;
		transition: .4s;
	}

		.stat-box:hover {
			background: #f8f7f2;
		}

		.stat-box h2 {
			font-family: var(--heading-font);
			font-size: 60px;
			color: #74642F;
			margin-bottom: 10px;
		}

		.stat-box span {
			text-transform: uppercase;
			letter-spacing: 2px;
			color: #999;
			font-size: 14px;
		}


	.review-stars {
		color: #C5A992;
		font-size: 20px;
		letter-spacing: 3px;
	}


	.review-slider .slick-prev,
	.review-slider .slick-next {
		width: 55px;
		height: 55px;
		background: #C5A992;
		border-radius: 50%;
		z-index: 999;
		transition: .3s;
	}

		.review-slider .slick-prev:hover,
		.review-slider .slick-next:hover {
			background: #2f2f2f;
		}

	.review-slider .slick-prev {
		left: -70px;
	}

	.review-slider .slick-next {
		right: -70px;
	}

		.review-slider .slick-prev:before,
		.review-slider .slick-next:before {
			color: white;
			font-size: 28px;
			opacity: 1;
		}


	.borrow-card {
		text-align: center;
		margin-bottom: 40px;
	}

		.borrow-card figure {
			background: #efeee8;
			padding: 25px;
			border: 1px solid #EAE8DF;
			margin-bottom: 25px;
			transition: .3s;
		}

		.borrow-card:hover figure {
			box-shadow: 0 10px 25px rgba(0,0,0,.08);
		}

	.borrow-image {
		width: 220px;
		height: 320px;
		object-fit: cover;
		margin: auto;
		display: block;
	}

	.borrow-card h3 {
		font-family: var(--heading-font);
		font-size: 34px;
		margin-bottom: 10px;
		color: #2f2f2f;
	}

	.borrow-card .author {
		display: block;
		color: #888;
		font-size: 18px;
		margin-bottom: 18px;
	}

	.borrow-category {
		color: #74642F;
		font-size: 26px;
		margin-bottom: 20px;
	}

	.borrow-buttons {
		display: flex;
		justify-content: center;
		gap: 10px;
		margin-bottom: 15px;
	}

	.borrow-info {
		margin-top: 15px;
		color: #666;
		font-size: 15px;
	}

	.status {
		display: inline-block;
		margin-top: 12px;
		padding: 6px 18px;
		border-radius: 25px;
		font-size: 13px;
		font-weight: 600;
	}

		.status.active {
			background: #ffc107;
			color: #222;
		}

		.status.returned {
			background: #28a745;
			color: white;
		}
</style>


@section Scripts{

	<script>

		$(function () {

			$('.review-slider').slick({
				slidesToShow:1,
				slidesToScroll:1,
				arrows:true,
				dots:true,
				autoplay:true,
				autoplaySpeed:3500
			});

		});

	</script>

}