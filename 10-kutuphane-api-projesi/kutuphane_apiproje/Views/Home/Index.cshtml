@model HomeViewModel

<style>
	#billboard .slider-item {
		display: flex;
		align-items: center;
	}

	#billboard .banner-image {
		width: 100%;
		height: 500px;
		object-fit: contain;
		background: #f3f2ec;
	}

	#billboard .banner-title {
		font-size: 60px;
		line-height: 1.1;
		margin-bottom: 20px;
	}

	#billboard .banner-content p {
		font-size: 17px;
		line-height: 1.7;
		margin-bottom: 30px;
	}

	.product-item .btn {
		height: auto !important;
		min-height: unset !important;
		padding: 2px 12px;
		align-items: center;
		justify-content: center;
		line-height: 1.2;
	}
</style>

<section id="billboard">

	<div class="container">
		<div class="row">

			<div class="main-slider pattern-overlay">
				<div class="slider-item">
					<div class="banner-content">
						<h2 class="banner-title">
							Bilginin Kapılarını Aralayan Kütüphane
						</h2>

						<p>
							Roman, tarih, bilim, psikoloji ve daha birçok kategoride yer alan
							eserleri inceleyebilir, kitapların durumunu görüntüleyebilir ve
							kütüphanemizdeki zengin koleksiyonu keşfedebilirsiniz.
						</p>

						<a href="#popular-books" class="btn btn-outline-accent btn-accent-arrow">
							Koleksiyonu İncele
							<i class="icon icon-ns-arrow-right"></i>
						</a>
					</div><!--banner-content-->
					<img src="https://static.ticimax.cloud/7367/uploads/urunresimleri/buyuk/kutuphane-posteri-95d-7b.jpg" alt="banner" class="banner-image">
				</div><!--slider-item-->


			</div><!--slider-->


		</div>
	</div>
	</div>

</section>

<section class="stats-section py-5">

	<div class="container">

		<div class="section-header align-center">
			<div class="title">
				<span>Kütüphane Verileri</span>
			</div>

			<h2 class="section-title">
				Genel Durum

			</h2>
		</div>

		<div class="row">

			<div class="col-md-3">
				<div class="stat-box">
					<h2>@Model.Books.Count()</h2>
					<span>Kitap</span>
				</div>
			</div>

			<div class="col-md-3">
				<div class="stat-box">
					<h2>@Model.Authors.Count()</h2>
					<span>Yazar</span>
				</div>
			</div>

			<div class="col-md-3">
				<div class="stat-box">
					<h2>@Model.Categories.Count()</h2>
					<span>Kategori</span>
				</div>
			</div>

			<div class="col-md-3">
				<div class="stat-box">
					<h2>@Model.UserCount</h2>
					<span>Üye</span>
				</div>
			</div>

		</div>

	</div>

</section>

<section id="popular-books" class="bookshelf py-5 my-5">
	<div class="container">
		<div class="row">
			<div class="col-md-12">

				<div class="section-header align-center">
					<div class="title">
						<span>Koleksiyonumuz</span>
					</div>
					<h2 class="section-title">Kitap Koleksiyonu</h2>
				</div>

				<ul class="tabs">
					<li data-tab-target="#all" class="active tab">
						Tümü
					</li>

					@foreach (var category in Model.Categories)
					{
						<li data-tab-target="#cat-@category.Id" class="tab">
							@category.CategoryName
						</li>
					}
				</ul>

				<div class="tab-content">
					<div id="all" data-tab-content class="active">
						<div class="row">

							@foreach (var book in Model.Books)
							{
								<div class="col-md-3">

									<div class="product-item">

										<figure class="product-style">
											<img src="@book.ImageUrl"
												 alt="@book.Title"
												 class="product-item">
										</figure>

										<figcaption>

											<h3>@book.Title</h3>

											<span>@book.AuthorName</span>

											<div class="item-price mb-3">
												@book.CategoryName
											</div>

											<div class="d-flex justify-content-center gap-2">

												<div class="button-group">

													<a asp-controller="Home"
													   asp-action="Details"
													   asp-route-id="@book.Id"
													   class="detail-btn">
														<i class="fa-solid fa-eye"></i>
														Detayları Gör
													</a>

													@if (book.IsAvailable)
													{
														<span class="status-btn available">
															<i class="fa-solid fa-circle-check"></i>
															Müsait
														</span>
													}
													else
													{
														<span class="status-btn borrowed">
															<i class="fa-solid fa-clock"></i>
															Ödünçte
														</span>
													}

												</div>
											</div>

											@if (!book.IsAvailable && book.DueDate.HasValue)
											{
												<div class="text-center mt-2">
													<small class="text-muted">
														<strong>Teslim:</strong>
														@book.DueDate.Value.ToString("dd.MM.yyyy")
													</small>
												</div>
											}

										</figcaption>

									</div>

								</div>
							}

						</div>
					</div>

					@foreach (var category in Model.Categories)
					{
						<div id="cat-@category.Id" data-tab-content>
							<div class="row">

								@foreach (var book in Model.Books.Where(x => x.CategoryId == category.Id))
								{
									<div class="col-md-3">
										<div class="product-item">

											<figure class="product-style">

												<img src="@book.ImageUrl"
													 alt="@book.Title"
													 class="product-item">

												@if (book.IsAvailable)
												{
													<button type="button" class="add-to-cart" data-product-tile="add-to-cart">
														<span>Müsait</span>
													</button>
												}
												else
												{
													<button type="button" class="add-to-cart" data-product-tile="add-to-cart">
														<span>Ödünçte</span>
													</button>
												}

											</figure>

											<figcaption>

												<h3>@book.Title</h3>

												<span>@book.AuthorName</span>

												<div class="item-price mb-3">
													@book.CategoryName
												</div>

												<div class="d-flex justify-content-center gap-2">
													<div class="button-group">

														<a asp-controller="Home"
														   asp-action="Details"
														   asp-route-id="@book.Id"
														   class="detail-btn">

															<i class="fa-solid fa-eye"></i>
															Detayları Gör

														</a>

														@if (book.IsAvailable)
														{
															<span class="status-btn available">

																<i class="fa-solid fa-circle-check"></i>
																Müsait

															</span>
														}
														else
														{
															<span class="status-btn borrowed">

																<i class="fa-solid fa-clock"></i>
																Ödünçte

															</span>
														}

													</div>
												</div>

												
											@if (!book.IsAvailable && book.DueDate.HasValue)
											{
												<div class="text-center mt-2">
													<small class="text-muted">
														<strong>Teslim:</strong>
														@book.DueDate.Value.ToString("dd.MM.yyyy")
													</small>
												</div>
											}

											</figcaption>

										</div>
									</div>
								}

							</div>
						</div>
					}
				</div>

			</div><!--inner-tabs-->

		</div>
	</div>
</section>

<section id="special-offer" class="bookshelf pb-5 mb-5">

	<div class="section-header align-center">
		<div class="title">
			<span>Eser Sahipleri</span>

		</div>
		<h2 class="section-title">Yazar Koleksiyonu</h2>
	</div>

	<div class="container">
		<div class="row">

			@foreach (var author in Model.Authors.Where(a => Model.Books.Count(x => x.AuthorId == a.Id) > 0))
			{
				<div class="col-lg-3 col-md-4 col-sm-6 mb-4">

					<div class="author-card">

						<div class="author-content">

							<span class="author-country">
								@author.Country
							</span>

							<h4 class="author-name">
								@author.FullName
							</h4>

							<div class="author-divider"></div>

							<span class="author-book-count">
								@Model.Books.Count(x => x.AuthorId == author.Id) Eser
							</span>

						</div>

					</div>

				</div>
			}
		</div>
	</div>
</section>

