<!DOCTYPE html>
<html lang="en">

<head>
    <title>BookSaw - Free Book Store HTML CSS Template</title>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="format-detection" content="telephone=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="author" content="">
    <meta name="keywords" content="">
    <meta name="description" content="">
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-4bw+/aepP/YC94hEpVNVgiZdgIC5+VKNBQNGCHeKRQN+PtmoHDEXuppvnDJzQIu9" crossorigin="anonymous">

    <link rel="stylesheet" type="text/css" href="~/booksaw-1.0.0/css/normalize.css">
    <link rel="stylesheet" type="text/css" href="~/booksaw-1.0.0/icomoon/icomoon.css">
    <link rel="stylesheet" type="text/css" href="~/booksaw-1.0.0/css/vendor.css">
    <link rel="stylesheet" type="text/css" href="~/booksaw-1.0.0/style.css">
    <link rel="stylesheet" href="~/css/mybooks.css">


    <style>
        .auth-login a {
            color: #333 !important;
        }

        .auth-register a {
            background: #c5a992;
            color: white !important;
            padding: 10px 20px;
            border-radius: 30px;
            transition: .3s;
        }

            .auth-register a:hover {
                background: #a9876b;
            }

        .menu-list > li > a {
            font-size: 14px !important;
            font-weight: 500;
            letter-spacing: 0.5px;
        }

        .auth-login a {
            font-size: 14px !important;
            color: #333 !important;
        }

        .auth-register a {
            background: #c5a992;
            color: white !important;
            padding: 8px 18px;
            border-radius: 25px;
            font-size: 13px !important;
            font-weight: 500;
            transition: .3s;
        }

            .auth-register a:hover {
                background: #a9876b;
            }

        .admin-panel-btn a {
            background: #2f2f2f !important;
            color: white !important;
            padding: 10px 20px !important;
            border-radius: 30px;
            font-size: 13px !important;
            font-weight: 600;
            letter-spacing: 1px;
            transition: .3s;
            border: 1px solid transparent;
        }

            .admin-panel-btn a:hover {
                background: #c5a992 !important;
                color: white !important;
                transform: translateY(-2px);
            }

        .user-menu a,
        .logout-btn a {
            display: flex !important;
            align-items: center;
            gap: 8px;
        }

        .logout-btn a {
            color: #a94442 !important;
            transition: .3s;
        }

            .logout-btn a:hover {
                color: #c5a992 !important;
            }
    </style>
</head>

<body data-bs-spy="scroll" data-bs-target="#header" tabindex="0">

    <div id="header-wrap">

        <header id="header">
            <div class="container-fluid">
                <div class="row">

                    <div class="col-md-2">
                        <div class="main-logo">
                            <a href="#"><img src="~/booksaw-1.0.0/images/main-logo.png" alt="logo"></a>
                        </div>

                    </div>

                    <div class="col-md-10">

                        <nav id="navbar">
                            <div class="main-menu stellarnav">
                                <ul class="menu-list">

                                    <li class="menu-item active">
                                        <a asp-controller="Home"
                                           asp-action="Index"
                                           asp-fragment="billboard">
                                            Ana Sayfa
                                        </a>
                                    </li>

                                    <li class="menu-item">
                                        <a asp-controller="Home"
                                           asp-action="Index"
                                           asp-fragment="popular-books">
                                            Kitaplar
                                        </a>
                                    </li>

                                    <li class="menu-item">
                                        <a asp-controller="Home"
                                           asp-action="Index"
                                           asp-fragment="special-offer">
                                            Yazarlar
                                        </a>
                                    </li>

                                    <li class="menu-item">
                                        <a asp-controller="Borrowing"
                                           asp-action="MyBooks">
                                            Ödünç Aldıklarım
                                        </a>
                                    </li>

                                    <li class="menu-item">
                                        <a asp-controller="Home"
                                           asp-action="Index"
                                           asp-fragment="quotation">
                                            Yorumlar
                                        </a>
                                    </li>

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li class="menu-item admin-panel-btn">
                                            <a asp-controller="Admin"
                                               asp-action="Index">
                                                <i class="icon icon-cog"></i>
                                                Admin Paneli
                                            </a>
                                        </li>
                                    }
                                    @if (User.Identity!.IsAuthenticated)
                                    {
                                        @if (User.Identity!.IsAuthenticated)
                                        {
                                            @* <li class="menu-item user-menu">
												<a asp-controller="Account" asp-action="Profile">
													<svg xmlns="http://www.w3.org/2000/svg"
														 width="18" height="18"
														 fill="currentColor"
														 viewBox="0 0 16 16">
														<path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" />
														<path d="M14 14s-1-4-6-4-6 4-6 4h12z" />
													</svg>
													Profilim
												</a>
											</li> *@

                                            <li class="menu-item logout-btn">
                                                <a asp-controller="Account" asp-action="Logout">
                                                    <svg xmlns="http://www.w3.org/2000/svg"
                                                         width="18"
                                                         height="18"
                                                         fill="currentColor"
                                                         viewBox="0 0 16 16">
                                                        <path fill-rule="evenodd"
                                                              d="M10.146 11.354a.5.5 0 0 1 0-.708L12.293 8.5H5.5a.5.5 0 0 1 0-1h6.793l-2.147-2.146a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708 0z" />
                                                        <path fill-rule="evenodd"
                                                              d="M13 14.5a.5.5 0 0 1-.5.5h-9A1.5 1.5 0 0 1 2 13.5v-11A1.5 1.5 0 0 1 3.5 1h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 0-.5.5v11a.5.5 0 0 0 .5.5h9a.5.5 0 0 1 .5.5z" />
                                                    </svg>
                                                    Çıkış Yap
                                                </a>
                                            </li>
                                        }
                                    }
                                    else
                                    {
                                        <li class="menu-item auth-login">
                                            <a asp-controller="Account" asp-action="Login">
                                                Giriş Yap
                                            </a>
                                        </li>

                                        <li class="menu-item auth-register">
                                            <a asp-controller="Account" asp-action="Register">
                                                Kayıt Ol
                                            </a>
                                        </li>
                                    }
                                </ul>

                                <div class="hamburger">
                                    <span class="bar"></span>
                                    <span class="bar"></span>
                                    <span class="bar"></span>
                                </div>

                            </div>
                        </nav>

                    </div>

                </div>
            </div>
        </header>

    </div><!--header-wrap-->
    @RenderBody()

    <footer id="footer">
        <div class="container">
            <div class="row">

                <div class="col-md-4">

                    <div class="footer-item">
                        <div class="company-brand">
                            <img src="~/booksaw-1.0.0/images/main-logo.png" alt="logo" class="footer-logo">
                            <p>
                                Bilgiye erişimi kolaylaştırmayı amaçlayan kütüphanemiz,
                                zengin kitap koleksiyonu ve düzenli ödünç verme sistemiyle
                                okuyucularına kaliteli bir hizmet sunmaktadır.
                            </p>
                        </div>
                    </div>

                </div>

                @* <div class="col-md-2">

                    <div class="footer-menu">
                        <h5>Hakkımızda</h5>
                        <ul class="menu-list">
                            <li><a href="#">Misyonumuz</a></li>
                            <li><a href="#">Vizyonumuz</a></li>
                            <li><a href="#">Ekibimiz</a></li>
                            <li><a href="#">İletişim</a></li>
                        </ul>
                    </div>

                </div> *@
                <div class="col-md-2">

                    <div class="footer-menu">
                        <h5>Keşfet</h5>
                        <ul class="menu-list">
                            <li>
                                <a asp-controller="Home"
                                   asp-action="Index"
                                   asp-fragment="billboard">
                                    Ana Sayfa
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Home"
                                   asp-action="Index"
                                   asp-fragment="popular-books">
                                    Kitaplar
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Home"
                                   asp-action="Index"
                                   asp-fragment="special-offer">
                                    Yazarlar
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Home"
                                   asp-action="Index"
                                   asp-fragment="quotation">
                                    Yorumlar
                                </a>
                            </li>
                        </ul>
                    </div>

                </div>
                <div class="col-md-2">

                    <div class="footer-menu">
                        <h5>Hesabım</h5>
                        <ul class="menu-list">
                            @if (User.Identity!.IsAuthenticated)
                            {
                                <li>
                                    <a asp-controller="Borrowing"
                                       asp-action="MyBooks">
                                        Ödünç Aldıklarım
                                    </a>
                                </li>

                                <li>
                                    <a asp-controller="Home"
                                       asp-action="Index"
                                       asp-fragment="quotation">
                                        Yorumlar
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li>
                                    <a asp-controller="Account"
                                       asp-action="Login">
                                        Giriş Yap
                                    </a>
                                </li>

                                <li>
                                    <a asp-controller="Account"
                                       asp-action="Register">
                                        Kayıt Ol
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>

                </div>
                <div class="col-md-2">

                    <div class="footer-menu">
                        <h5>Yardım</h5>
                        <ul class="menu-list">
                            <li><a href="#">Sık Sorulan Sorular</a></li>
                            <li><a href="#">Destek Merkezi</a></li>
                            <li><a href="#">Bize Ulaşın</a></li>
                        </ul>
                    </div>

                </div>

            </div>
            <!-- / row -->

        </div>
    </footer>

    <div id="footer-bottom">
        <div class="container">
            <div class="row">
                <div class="col-md-12">

                    <div class="copyright">
                        <div class="row">
                            <p>
                                © 2026 Kütüphane Yönetim Sistemi | Tüm Hakları Saklıdır.
                            </p>

                        </div>
                    </div><!--grid-->

                </div><!--footer-bottom-content-->
            </div>
        </div>
    </div>

    <script src="~/booksaw-1.0.0/js/jquery-1.11.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-HwwvtgBNo3bZJJLYd8oVXjrBZt8cqVSpeBNS5n7C8IVInixGAoxmnlMuBnhbgrkm"
            crossorigin="anonymous"></script>
    <script src="~/booksaw-1.0.0/js/plugins.js"></script>
    <script src="~/booksaw-1.0.0/js/script.js"></script>

    @RenderSection("Scripts", required: false)

</body>

</html>