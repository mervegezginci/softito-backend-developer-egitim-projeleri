@model kutuphane_apiproje.Models.Borrowing

@{
    ViewData["Title"] = "Yeni Ödünç";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="form-container">

    <div class="form-card">

        <div class="page-header">
            <span>Ödünç İşlemleri</span>
            <h2>Yeni Ödünç Oluştur</h2>
        </div>

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger"></div>

            <div class="form-box">

                <label>Kullanıcı</label>

                <select asp-for="UserId"
                        asp-items="ViewBag.UserId"
                        class="form-control">
                </select>

            </div>

            <div class="form-box">

                <label>Kitap</label>

                <select asp-for="BookId"
                        asp-items="ViewBag.BookId"
                        class="form-control">
                </select>

            </div>

            <div class="form-box">

                <label>Alış Tarihi</label>

                <input asp-for="BorrowDate"
                       type="date"
                       class="form-control" />

            </div>

            <div class="form-box">

                <label>Teslim Tarihi</label>

                <input asp-for="DueDate"
                       type="date"
                       class="form-control" />

            </div>

            <div class="form-box">

                <label>İade Tarihi</label>

                <input asp-for="ReturnDate"
                       type="date"
                       class="form-control" />

            </div>

            <div class="form-check mb-4">

                <input asp-for="IsReturned"
                       class="form-check-input" />

                <label asp-for="IsReturned"
                       class="form-check-label">
                    Kitap Teslim Edildi
                </label>

            </div>

            <button type="submit"
                    class="save-btn">
                Kaydet
            </button>

            <a asp-action="Index"
               class="back-btn">
                Geri Dön
            </a>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}