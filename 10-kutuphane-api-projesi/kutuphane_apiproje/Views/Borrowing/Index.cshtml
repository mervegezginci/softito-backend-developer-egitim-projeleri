@model IEnumerable<kutuphane_apiproje.Models.Borrowing>

@{
    ViewData["Title"] = "Ödünç İşlemleri";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="category-page">

    <div class="page-title-area">

        <div>
            <span>Yönetim Paneli</span>
            <h2>Ödünç İşlemleri</h2>
        </div>

        <a asp-action="Create"
           class="add-btn">
            + Yeni Ödünç
        </a>

    </div>

    <div class="category-table-card">

        <table class="category-table">

            <thead>
                <tr>
                    <th>Kullanıcı</th>
                    <th>Kitap</th>
                    <th>Alış Tarihi</th>
                    <th>Teslim Tarihi</th>
                    <th>İade Tarihi</th>
                    <th>Durum</th>
                    <th>İşlemler</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>@item.User.Name</td>

                        <td>@item.Book.Title</td>

                        <td>@item.BorrowDate.ToString("dd.MM.yyyy")</td>

                        <td>@item.DueDate.ToString("dd.MM.yyyy")</td>

                        <td>
                            @(item.ReturnDate.HasValue
                                                    ? item.ReturnDate.Value.ToString("dd.MM.yyyy")
                                                    : "-")
                    </td>

                        <td>

                        @if (item.IsReturned)
                            {
                                <span class="status returned">
                                    Teslim Edildi
                                </span>
                            }
                            else
                            {
                                <span class="status waiting">
                                    Devam Ediyor
                                </span>
                            }

                        </td>

                        <td>

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="edit-btn">
                                Düzenle
                            </a>

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="detail-btn">
                                Detay
                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>