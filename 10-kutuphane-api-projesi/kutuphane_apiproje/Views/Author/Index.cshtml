@model IEnumerable<kutuphane_apiproje.Models.Author>

@{
    ViewData["Title"] = "Yazarlar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="author-page">

    <div class="page-title-area">
        <div>
            <span>Yönetim Paneli</span>
            <h2>Yazarlar</h2>
        </div>
        <a asp-action="Create" class="add-btn">+ Yeni Yazar</a>
    </div>

    <!-- Arama Kutusu -->
    <form method="get" style="margin-bottom: 20px; max-width: 400px;">
        <div style="display:flex; gap:8px;">
            <input type="text" name="search" class="form-control" placeholder="Yazar adı veya ülke ara..."
                   value="@ViewBag.Search" id="txtSearch" style="border-radius:8px;" />
            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <a href="/Author/Index" class="btn btn-outline-secondary" style="border-radius:8px;">✕</a>
            }
        </div>
    </form>

    <div class="author-table-card">

        <table class="author-table">

            <thead>

                <tr>
                    <th>Yazar Adı</th>
                    <th>Ülke</th>
                    <th>İşlemler</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>@item.FullName</td>

                        <td>@item.Country</td>

                        <td>

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="edit-btn">
                                Düzenle
                            </a>

                            <form asp-action="Delete"
                                  asp-route-id="@item.Id"
                                  method="post"
                                  style="display:inline;">

                                @Html.AntiForgeryToken()

                                <button type="submit"
                                        class="delete-btn"
                                        onclick="return confirm('Bu yazarı silmek istediğinize emin misiniz?')">
                                    Sil
                                </button>

                            </form>
                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

