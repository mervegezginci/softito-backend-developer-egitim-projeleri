@model Realtor

@{
    Layout = "_AdminLayout";
}

<div class="card">
    <div class="card-header">
        <h4>Yeni Danışman Ekle</h4>
    </div>

    <div class="card-body">

        <form asp-action="Create" method="post">

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label>Ad Soyad</label>
                    <input asp-for="NameSurname"
                           class="form-control"
                           required />
                </div>

                <div class="col-md-6 mb-3">
                    <label>Telefon</label>
                    <input asp-for="Phone"
                           class="form-control" />
                </div>

                <div class="col-md-6 mb-3">
                    <label>Email</label>
                    <input asp-for="Email"
                           type="email"
                           class="form-control" />
                </div>

                <div class="col-md-6 mb-3">
                    <label>Fotoğraf Url</label>
                    <input asp-for="ImageUrl"
                           class="form-control" />
                </div>

            </div>

            <button type="submit" class="btn btn-success">
                Kaydet
            </button>

            <a asp-action="Index" class="btn btn-secondary">
                İptal
            </a>

        </form>

    </div>
</div>