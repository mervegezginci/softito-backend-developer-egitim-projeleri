@model PropertyType

@{
    Layout = "_AdminLayout";
}

<div class="card">
    <div class="card-header">
        <h4>İlan Türü Güncelle</h4>
    </div>

    <div class="card-body">

        <form asp-action="Edit" method="post">

            <input asp-for="Id" type="hidden" />

            <div class="mb-3">
                <label>Tür Adı</label>
                <input asp-for="TypeName"
                       class="form-control"
                       required />
            </div>

            <button type="submit"
                    class="btn btn-warning">
                Güncelle
            </button>

            <a asp-action="Index"
               class="btn btn-secondary">
                Geri Dön
            </a>

        </form>

    </div>
</div>