@model List<PropertyType>

@{
    Layout = "_AdminLayout";
}

<div class="card">
    <div class="card-header">
        <h4>İlan Türleri</h4>
    </div>

    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <a href="@Url.Action("Create", "PropertyType")" class="btn btn-primary">
                Yeni Tür Ekle
            </a>
            
            <form method="get" class="d-flex gap-2">
                <input type="text" name="search" class="form-control" placeholder="Tür ara..." value="@Context.Request.Query["search"]" style="width: 250px;" />
                <button type="submit" class="btn btn-secondary">Ara</button>
                @if (!string.IsNullOrEmpty(Context.Request.Query["search"]))
                {
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Temizle</a>
                }
            </form>
        </div>

        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Tür Adı</th>
                    <th width="200">İşlemler</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.TypeName</td>
                        <td>
                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-warning btn-sm">
                                Düzenle
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-danger btn-sm">
                                Sil
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>