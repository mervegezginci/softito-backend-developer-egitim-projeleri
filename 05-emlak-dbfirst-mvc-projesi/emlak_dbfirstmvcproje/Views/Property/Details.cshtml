@model Property
@{
    Layout = "_Layout";
}

<div class="container py-5 my-5">
    <div class="mb-4">
        <a href="/" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> İlanlara Geri Dön</a>
    </div>

    <div class="row g-5">
        <!-- Sol Bölüm: Resim, Özellikler ve Açıklama -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm overflow-hidden mb-4" style="border-radius: 16px;">
                <img src="@Model.ImageUrl" class="img-fluid w-100" style="max-height: 480px; object-fit: cover;" alt="@Model.Title" />
            </div>

            <div class="d-flex align-items-center gap-2 mb-3">
                <span class="badge bg-primary px-3 py-2 fs-6" style="border-radius: 20px;">@Model.PropertyType?.TypeName</span>
                <span class="badge bg-secondary px-3 py-2 fs-6" style="border-radius: 20px;"><i class="bi bi-geo-alt-fill"></i> @Model.City?.Name</span>
            </div>

            <h1 class="fw-bold text-white">@Model.Title</h1>
            <p class="text-white-50"><i class="bi bi-map"></i> @Model.Address</p>

            <hr class="my-4" style="border-color: rgba(255,255,255,0.1);">

            <h3 class="fw-bold text-white mb-3">Özellikler</h3>
            <div class="row g-3 mb-4">
                <div class="col-md-4 col-6">
                    <div class="p-3 rounded text-center" style="background-color: #1a293a; border: 1px solid #2b3d52;">
                        <i class="bi bi-door-open fs-3 text-primary"></i>
                        <div class="mt-2 text-white-50 small">Oda Sayısı</div>
                        <div class="fw-bold text-white fs-5">@Model.RoomCount</div>
                    </div>
                </div>
                <div class="col-md-4 col-6">
                    <div class="p-3 rounded text-center" style="background-color: #1a293a; border: 1px solid #2b3d52;">
                        <i class="bi bi-water fs-3 text-primary"></i>
                        <div class="mt-2 text-white-50 small">Banyo Sayısı</div>
                        <div class="fw-bold text-white fs-5">@Model.BathCount</div>
                    </div>
                </div>
                <div class="col-md-4 col-12">
                    <div class="p-3 rounded text-center" style="background-color: #1a293a; border: 1px solid #2b3d52;">
                        <i class="bi bi-grid-3x3-gap fs-3 text-primary"></i>
                        <div class="mt-2 text-white-50 small">Metrekare</div>
                        <div class="fw-bold text-white fs-5">@Model.SquareMeter m²</div>
                    </div>
                </div>
            </div>

            <hr class="my-4" style="border-color: rgba(255,255,255,0.1);">

            <h3 class="fw-bold text-white mb-3">Açıklama</h3>
            <p class="text-white-50" style="line-height: 1.8; white-space: pre-line;">
                @Model.Description
            </p>
        </div>

        <!-- Sağ Bölüm: Fiyat ve Danışman Bilgileri -->
        <div class="col-lg-4">
            <div class="position-sticky" style="top: 110px;">
                <!-- Fiyat Kartı -->
                <div class="card border-0 shadow-sm p-4 mb-4 text-center" style="border-radius: 16px; background-color: #1a293a; border: 1px solid #2b3d52;">
                    <div class="text-white-50 mb-1">Satış/Kira Bedeli</div>
                    <h2 class="fw-bold text-success">@Model.Price.ToString("N0") ₺</h2>
                </div>

                <!-- Danışman Kartı -->
                <div class="card border-0 shadow-sm p-4 text-center" style="border-radius: 16px; background-color: #1a293a; border: 1px solid #2b3d52;">
                    <h5 class="fw-bold text-white mb-4">Gayrimenkul Danışmanı</h5>
                    
                    @if (Model.Realtor != null)
                    {
                        <div class="mb-3">
                            <img src="@Model.Realtor.ImageUrl" class="rounded-circle border" style="width: 100px; height: 100px; object-fit: cover;" alt="@Model.Realtor.NameSurname" />
                        </div>
                        <h4 class="fw-bold text-white mb-1">@Model.Realtor.NameSurname</h4>
                        <div class="text-white-50 small mb-4">Evrem Emlak Uzmanı</div>

                        <div class="d-grid gap-2">
                            <a href="tel:@Model.Realtor.Phone" class="btn btn-primary py-2.5" style="border-radius: 8px;">
                                <i class="bi bi-telephone-fill"></i> @Model.Realtor.Phone
                            </a>
                            <a href="mailto:@Model.Realtor.Email" class="btn btn-outline-light py-2.5" style="border-radius: 8px;">
                                <i class="bi bi-envelope-fill"></i> @Model.Realtor.Email
                            </a>
                        </div>
                    }
                    else
                    {
                        <p class="text-white-50">Danışman bilgisi bulunamadı.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
