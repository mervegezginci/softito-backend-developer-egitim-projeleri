@model List<Property>
@{
    Layout = "_Layout";
}

<div class="container py-5 my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Arama Sonuçları</h2>
            <p class="text-muted">Kriterlerinize uygun toplam @Model.Count ilan listelenmektedir.</p>
        </div>
        <a href="/" class="btn btn-outline-primary"><i class="bi bi-arrow-left"></i> Geri Dön</a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-house-x text-muted" style="font-size: 4rem;"></i>
            <h4 class="mt-3 text-muted">Aramanıza uygun ilan bulunamadı.</h4>
            <p class="text-muted">Farklı filtre kriterleri belirleyerek tekrar arama yapabilirsiniz.</p>
            <a href="/" class="btn btn-primary mt-3">Anasayfaya Git</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-4 col-sm-6">
                    <div class="card h-100 shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
                        <img src="@item.ImageUrl" class="card-img-top" style="height: 220px; object-fit: cover;" alt="@item.Title" />
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="badge bg-primary">@item.PropertyType?.TypeName</span>
                                <span class="badge bg-secondary">@item.City?.Name</span>
                            </div>
                            <h5 class="card-title fw-bold text-dark">@item.Title</h5>
                            <p class="card-text text-muted small text-truncate">@item.Address</p>
                            <h4 class="text-success fw-bold">@item.Price.ToString("N0") ₺</h4>
                            
                            <div class="d-flex justify-content-between text-muted small border-top pt-2 mt-3">
                                <span><i class="bi bi-door-open"></i> @item.RoomCount oda</span>
                                <span><i class="bi bi-water"></i> @item.BathCount banyo</span>
                                <span><i class="bi bi-grid-3x3-gap"></i> @item.SquareMeter m²</span>
                            </div>
                            
                            <a href="/Property/Details/@item.Id" class="btn btn-primary w-100 mt-3" style="border-radius: 8px;">Detayları İncele</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
