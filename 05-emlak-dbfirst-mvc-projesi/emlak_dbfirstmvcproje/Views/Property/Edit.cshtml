@model Property

@{
    Layout = "_AdminLayout";
}

    <div class="card">
        <div class="card-header">
            <h4>İlan Güncelle</h4>
        </div>

        <div class="card-body">

            <form asp-action="Edit" method="post">

                <input type="hidden" asp-for="Id" />

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label>İlan Başlığı</label>
                        <input asp-for="Title" class="form-control" required />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Fiyat</label>
                        <input asp-for="Price" type="number" class="form-control" required />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Metrekare</label>
                        <input asp-for="SquareMeter" type="number" class="form-control" required />
                    </div>

                    <div class="col-md-3 mb-3">
                        <label>Oda Sayısı</label>
                        <input asp-for="RoomCount" class="form-control" required />
                    </div>

                    <div class="col-md-3 mb-3">
                        <label>Banyo Sayısı</label>
                        <input asp-for="BathCount" type="number" class="form-control" required />
                    </div>

                    <div class="col-md-12 mb-3">
                        <label>Adres</label>
                        <input asp-for="Address" class="form-control" required />
                    </div>

                    <div class="col-md-12 mb-3">
                        <label>Açıklama</label>
                        <textarea asp-for="Description" rows="3" class="form-control"></textarea>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Şehir</label>
                        <select asp-for="CityId" class="form-select" required>
                            @foreach (var city in ViewBag.Cities)
                            {
                                <option value="@city.Id">
                                    @city.Name
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>İlan Türü</label>
                        <select asp-for="PropertyTypeId" class="form-select" required>
                            @foreach (var type in ViewBag.Types)
                            {
                                <option value="@type.Id">
                                    @type.TypeName
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Danışman</label>
                        <select asp-for="RealtorId" class="form-select" required>
                            @foreach (var realtor in ViewBag.Realtors)
                            {
                                <option value="@realtor.Id">
                                    @realtor.NameSurname
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label>Resim Url</label>
                        <input asp-for="ImageUrl" class="form-control" />
                    </div>

                </div>

                <button type="submit" class="btn btn-warning">
                    Güncelle
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Geri Dön
                </a>

            </form>

        </div>
    </div>
