@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
}


<!-- Introduction -->
<div id="introduction" class="basic-1 bg-gray">
    <div class="container">
        <div class="row">
            <div class="col-xl-9">
                <h2>
                    Ofis tasarımı bizim tutkumuzdur ve bunu tamamladığımız projelerde görebilirsiniz
                </h2>

                <p>
                    Modern, işlevsel ve estetik çalışma alanları oluşturarak
                    işletmelerin ihtiyaçlarına uygun profesyonel çözümler sunuyoruz.
                </p>
            </div> <!-- end of col -->
        </div> <!-- end of row -->
    </div> <!-- end of container -->
</div> <!-- end of basic-1 -->
<!-- end of introduction -->
<!-- Details 1 -->
<div id="details" class="basic-2">
    <img class="decoration-star" src="images/decoration-star.svg" alt="alternative">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 col-xl-5">
                <div class="image-container">
                    <img class="img-fluid" src="~/yavin/images/details-1.png" alt="alternative">
                </div> <!-- end of image-container -->
            </div> <!-- end of col -->
            <div class="col-lg-6 col-xl-7">
                <div class="text-container">
                    <h2>Her ofis kendine özgü olmalı, birbirinin aynısı olmak zorunda değildir</h2>

                    <ul class="list-unstyled li-space-lg">
                        <li class="d-flex">
                            <i class="fas fa-square"></i>
                            <div class="flex-grow-1">
                                Kurumsal kimliğinize uygun modern ve özgün tasarımlar oluşturuyoruz.
                            </div>
                        </li>

                        <li class="d-flex">
                            <i class="fas fa-square"></i>
                            <div class="flex-grow-1">
                                Çalışan verimliliğini artıran ergonomik çalışma alanları tasarlıyoruz.
                            </div>
                        </li>

                        <li class="d-flex">
                            <i class="fas fa-square"></i>
                            <div class="flex-grow-1">
                                Mekân analizinden uygulama sürecine kadar profesyonel destek sağlıyoruz.
                            </div>
                        </li>

                        <li class="d-flex">
                            <i class="fas fa-square"></i>
                            <div class="flex-grow-1">
                                Estetik ve işlevselliği bir araya getirerek kalıcı çözümler sunuyoruz.
                            </div>
                        </li>
                    </ul>

                    <a class="btn-solid-reg" href="#contact">Teklif Al</a>
                </div> <!-- end of text-container -->
            </div> <!-- end of col -->
        </div> <!-- end of row -->
    </div> <!-- end of container -->
</div> <!-- end of basic-2 -->
<!-- end of details 1 -->
<!-- Services -->
<div id="services" class="cards-1 bg-gray">
    <div class="container">
        <div class="row">
            <div class="col-lg-5">
                <div class="text-container">
                    <h2>Hizmetlerimiz</h2>
                    <p>
                        İşletmenizin ihtiyaçlarına uygun profesyonel ofis tasarım
                        ve dekorasyon hizmetleri sunuyoruz.
                    </p>

                    <p>
                        Tasarımdan uygulamaya kadar tüm süreçlerde yanınızdayız.
                    </p>
                    <ul class="list-unstyled li-space-lg">
                        <div class="flex-grow-1">
                            Profesyonel proje planlama ve alan analizi hizmetleri
                        </div>

                        <div class="flex-grow-1">
                            Modern dekorasyon ve iç mimari çözümler
                        </div>

                        <div class="flex-grow-1">
                            Anahtar teslim ofis tasarım ve uygulama hizmetleri
                        </div>
                    </ul>
                </div> <!-- end of text-container -->
            </div> <!-- end of col -->
            <div class="col-lg-7">
                <div class="card-container">

                    @foreach (var i in Model.Services)
                    {
                        <div class="card">
                            <div class="card-icon">
                                <span class="@i.IconUrl"></span>
                            </div>
                            <div class="card-body">
                                <h5 class="card-title">@i.Title</h5>
                                <p>@i.Description</p>
                            </div>
                        </div>

                    }


                </div> <!-- end of container -->
            </div> <!-- end of col -->
        </div> <!-- end of row -->
    </div> <!-- end of container -->
</div> <!-- end of cards-1 -->
<!-- end of services -->
