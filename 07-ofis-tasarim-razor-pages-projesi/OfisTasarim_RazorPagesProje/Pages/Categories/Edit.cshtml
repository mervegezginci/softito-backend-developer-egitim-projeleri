@page
@model OfisTasarim_RazorPagesProje.Pages.Categories.EditModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Kategori Düzenle";
}

<div class="card card-admin p-4" style="max-width: 600px;">
    <h4 class="fw-bold mb-4 text-dark">Kategori Düzenle</h4>

    <form method="post">
        <!-- Hidden ID -->
        <input type="hidden" name="ID" value="@Model.categorybilgi.ID" />

        <div class="mb-3">
            <label for="Name" class="form-label fw-semibold">Kategori Adı</label>
            <input type="text" class="form-control" id="Name" name="Name" value="@Model.categorybilgi.Name" placeholder="Örn: Modern Ofis Tasarımları" required />
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-yavin-primary"><i class="fas fa-save me-1"></i> Değişiklikleri Kaydet</button>
            <a href="/Categories/Index" class="btn btn-outline-secondary">İptal</a>
        </div>
    </form>
</div>
