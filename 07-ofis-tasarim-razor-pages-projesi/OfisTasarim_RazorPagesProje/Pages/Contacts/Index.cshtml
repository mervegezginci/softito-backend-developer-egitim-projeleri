@page
@model OfisTasarim_RazorPagesProje.Pages.Contacts.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Mesajlar";
}

<div class="card card-admin p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0 text-dark">Gelen İletişim Talepleri</h4>
        <div class="d-flex gap-2 no-print">
            <button onclick="window.print()" class="btn btn-outline-secondary">
                <i class="fas fa-print me-1"></i> Yazdır / PDF
            </button>
            <button onclick="exportTableToCSV('contactsTable', 'mesajlar-raporu.csv')" class="btn btn-success">
                <i class="fas fa-file-excel me-1"></i> Excel İndir
            </button>
        </div>
    </div>

    <!-- Arama Kutusu -->
    <form method="get" class="mb-4 no-print">
        <div class="input-group">
            <input type="text" name="search" value="@Model.SearchTerm" class="form-control" placeholder="Ad, e-posta veya mesaj ara..." />
            <button class="btn btn-outline-primary" type="submit"><i class="fas fa-search"></i> Ara</button>
            @if (!string.IsNullOrEmpty(Model.SearchTerm))
            {
                <a href="/Contacts/Index" class="btn btn-outline-secondary"><i class="fas fa-times"></i> Temizle</a>
            }
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-hover align-middle" id="contactsTable">
            <thead class="table-light">
                <tr>
                    <th width="80">ID</th>
                    <th>Ad Soyad</th>
                    <th>Email</th>
                    <th>Tarih</th>
                    <th>Mesaj</th>
                    <th width="120" class="text-end no-print">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.listele.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">Gelen mesaj bulunmamaktadır.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model.listele)
                    {
                        <tr>
                            <td>@item.ID</td>
                            <td class="fw-semibold">@item.Name</td>
                            <td><a href="mailto:@item.Email">@item.Email</a></td>
                            <td class="text-muted small">@item.Date</td>
                            <td style="max-width: 300px; white-space: normal; word-break: break-all;">@item.Message</td>
                            <td class="text-end no-print">
                                <a href="/Contacts/Delete?id=@item.ID" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash-alt"></i> Sil</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Yazdırma Stilleri -->
<style>
    @@media print {
        body * {
            visibility: hidden;
        }
        .card, .card * {
            visibility: visible;
        }
        .card {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
            border: none !important;
            box-shadow: none !important;
        }
        .no-print, .btn {
            display: none !important;
        }
    }
</style>

<!-- CSV İndirme Script -->
<script>
    function exportTableToCSV(tableId, filename) {
        var csv = [];
        var rows = document.querySelectorAll("#" + tableId + " tr");
        
        for (var i = 0; i < rows.length; i++) {
            var row = [], cols = rows[i].querySelectorAll("td, th");
            for (var j = 0; j < cols.length; j++) {
                if (cols[j].classList.contains("no-print")) continue;
                var text = cols[j].innerText.replace(/"/g, '""').replace(/\n/g, ' ');
                row.push('"' + text + '"');
            }
            csv.push(row.join(";"));
        }
        
        var csvFile = new Blob(["\ufeff" + csv.join("\n")], { type: "text/csv;charset=utf-8;" });
        var downloadLink = document.createElement("a");
        downloadLink.download = filename;
        downloadLink.href = window.URL.createObjectURL(csvFile);
        downloadLink.style.display = "none";
        document.body.appendChild(downloadLink);
        downloadLink.click();
        document.body.removeChild(downloadLink);
    }
</script>