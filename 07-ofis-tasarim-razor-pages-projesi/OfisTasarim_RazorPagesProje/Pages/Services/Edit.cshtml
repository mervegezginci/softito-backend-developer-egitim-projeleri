@page
@model OfisTasarim_RazorPagesProje.Pages.Services.EditModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Hizmet Düzenle";
}

<div class="card card-admin p-4" style="max-width: 600px;">
    <h4 class="fw-bold mb-4 text-dark">Hizmet Düzenle</h4>

    @if (!string.IsNullOrEmpty(Model.errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i> @Model.errorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post">
        <!-- Hidden ID -->
        <input type="hidden" name="ID" value="@Model.servicebilgi.ID" />

        <div class="mb-3">
            <label for="Title" class="form-label fw-semibold">Hizmet Başlığı</label>
            <input type="text" class="form-control" id="Title" name="Title" value="@Model.servicebilgi.Title" placeholder="Örn: İç Mimari Planlama" required />
        </div>

        <div class="mb-3">
            <label for="Description" class="form-label fw-semibold">Açıklama</label>
            <textarea class="form-control" id="Description" name="Description" rows="4" placeholder="Hizmet detaylarını giriniz..." required>@Model.servicebilgi.Description</textarea>
        </div>

        <div class="mb-3">
            <label for="IconUrl" class="form-label fw-semibold">İkon Sınıfı (FontAwesome)</label>
            <input type="text" class="form-control" id="IconUrl" name="IconUrl" value="@Model.servicebilgi.IconUrl" placeholder="Örn: fas fa-couch" required />
            <small class="text-muted">Örnekler: <code>fas fa-couch</code>, <code>fas fa-pencil-ruler</code>, <code>fas fa-lightbulb</code></small>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-yavin-primary"><i class="fas fa-save me-1"></i> Değişiklikleri Kaydet</button>
            <a href="/Services/Index" class="btn btn-outline-secondary">İptal</a>
        </div>
    </form>
</div>
