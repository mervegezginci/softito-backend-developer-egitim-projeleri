<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Yavin Yönetim Paneli</title>
    
    <!-- CSS Varlıkları -->
    <link href="/yavin/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/yavin/css/fontawesome-all.min.css" rel="stylesheet" />
    
    <!-- Admin Özel CSS -->
    <style>
        body {
            font-family: "Work Sans", sans-serif;
            background-color: #f8f9fa;
        }

        #wrapper {
            display: flex;
            min-height: 100vh;
        }

        #sidebar {
            width: 250px;
            background: linear-gradient(180deg, #1f2b3e 0%, #111a28 100%);
            color: #ffffff;
            transition: all 0.3s;
        }

        #sidebar .sidebar-heading {
            padding: 1.5rem 1rem;
            font-size: 1.2rem;
            font-weight: 700;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            color: #ff3b3f; /* Yavin vurgu rengine uyumlu */
        }

        #sidebar .list-group-item {
            background-color: transparent;
            color: rgba(255, 255, 255, 0.75);
            border: none;
            padding: 1rem 1.5rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: all 0.2s;
        }

        #sidebar .list-group-item:hover, #sidebar .list-group-item.active {
            color: #ffffff;
            background-color: rgba(255, 255, 255, 0.08);
            border-left: 4px solid #0056b3;
            padding-left: 1.25rem;
        }

        #content-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }

        .navbar-admin {
            background-color: #ffffff;
            border-bottom: 1px solid #e3e6f0;
            padding: 1rem 1.5rem;
        }

        .card-admin {
            border: none;
            border-radius: 12px;
            box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.05);
        }

        .btn-yavin-primary {
            background-color: #0056b3;
            color: white;
            border: none;
            border-radius: 8px;
            padding: 0.5rem 1.25rem;
            font-weight: 500;
        }
        .btn-yavin-primary:hover {
            background-color: #004085;
            color: white;
        }

        .btn-yavin-danger {
            background-color: #e3342f;
            color: white;
            border: none;
            border-radius: 8px;
            padding: 0.5rem 1.25rem;
            font-weight: 500;
        }
        .btn-yavin-danger:hover {
            background-color: #cc1f1a;
            color: white;
        }
    </style>
</head>
<body>
    <div id="wrapper">
        <!-- Sol Menü (Sidebar) -->
        <div id="sidebar">
            <div class="sidebar-heading d-flex align-items-center gap-2">
                <img src="/yavin/images/logo.svg" alt="Yavin Logo" style="height: 28px;" />
                <span class="text-white fw-bold">Yavin</span>
                <span class="badge bg-danger ms-1" style="font-size: 0.65rem; padding: 3px 6px; background-color: #ff3b3f !important;">PANEL</span>
            </div>
            <div class="list-group list-group-flush mt-3">
                <a href="/Admin/Index" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["page"]?.ToString() == "/Admin/Index" ? "active" : "")">
                    <i class="fas fa-tachometer-alt"></i> Panel Özeti
                </a>
                <a href="/Categories/Index" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Categories/") == true ? "active" : "")">
                    <i class="fas fa-list"></i> Kategoriler
                </a>
                <a href="/Services/Index" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Services/") == true ? "active" : "")">
                    <i class="fas fa-cogs"></i> Hizmetler
                </a>
                <a href="/Projects/Index" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Projects/") == true ? "active" : "")">
                    <i class="fas fa-project-diagram"></i> Projeler
                </a>
                <a href="/Contacts/Index" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Contacts/") == true ? "active" : "")">
                    <i class="fas fa-envelope"></i> İletişim Talepleri
                </a>
                <a href="/" class="list-group-item list-group-item-action mt-5 text-warning">
                    <i class="fas fa-external-link-alt"></i> Siteye Dön
                </a>
            </div>
        </div>

        <!-- Sağ İçerik Bölümü -->
        <div id="content-wrapper">
            <!-- Üst Bar (Navbar) -->
            <nav class="navbar navbar-expand navbar-light navbar-admin d-flex justify-content-between align-items-center">
                <h5 class="m-0 fw-bold text-secondary">
                    <i class="fas fa-bars me-2"></i> @ViewData["Title"]
                </h5>
                <div class="d-flex align-items-center gap-3">
                    <span class="text-muted small">Hoş Geldiniz, <strong>Yönetici</strong></span>
                    <i class="fas fa-user-circle fs-3 text-secondary"></i>
                </div>
            </nav>

            <!-- Sayfa İçeriği -->
            <main class="container-fluid p-4">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- JS Varlıkları -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
