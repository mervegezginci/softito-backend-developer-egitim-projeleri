@model IEnumerable<sporkulubu_mvc.Models.MemberViewModel>
@{
    ViewData["Title"] = "Üyeler";
    string keyword = ViewBag.Keyword as string ?? "";
    bool? isActive = ViewBag.IsActive as bool?;
}

<div class="row mb-4 align-items-center">
    <div class="col">
        <h2 class="fw-bold text-dark m-0">Kulüp Üyeleri</h2>
        <p class="text-muted mb-0">Kulübümüze kayıtlı sporcular, üyelik durumları ve kayıt tarihleri.</p>
    </div>
    <div class="col-auto d-flex gap-2">
        <a asp-action="ExportPdf" class="btn btn-light text-danger border-danger-subtle">
            <i class="fa-solid fa-file-pdf me-2"></i>PDF İndir
        </a>
        <a asp-action="ExportExcel" class="btn btn-light text-success border-success-subtle">
            <i class="fa-solid fa-file-excel me-2"></i>Excel İndir
        </a>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fa-solid fa-user-plus me-2"></i>Yeni Üye Ekle
        </a>
    </div>
</div>

<!-- Search Panel -->
<div class="card border-0 bg-white shadow-sm mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label fw-semibold">İsim veya E-posta ile Arama</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                    <input type="text" name="keyword" class="form-control border-start-0" placeholder="Aramak için yazın..." value="@keyword"/>
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold">Üyelik Durumu</label>
                <select name="isActive" class="form-select">
                    <option value="">Tüm Üyeler</option>
                    <option value="true" selected="@(isActive == true)">Aktif Üyeler</option>
                    <option value="false" selected="@(isActive == false)">Pasif Üyeler</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fa-solid fa-filter me-2"></i>Filtrele
                </button>
                <a asp-action="Index" class="btn btn-light w-100">
                    Temizle
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Members Table -->
<div class="card border-0 bg-white shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Üye Bilgisi</th>
                        <th>E-posta</th>
                        <th>Telefon</th>
                        <th>Kayıt Tarihi</th>
                        <th>Durum</th>
                        <th class="pe-4 text-end" style="width: 150px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fa-regular fa-folder-open mb-2" style="font-size: 2.5rem; display: block;"></i>
                                Arama kriterlerine uygun üye bulunamadı.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="bg-light rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 35px; height: 35px; color: #10b981;">
                                            <i class="fa-solid fa-user"></i>
                                        </div>
                                        <div class="fw-bold text-dark">@item.FirstName @item.LastName</div>
                                    </div>
                                </td>
                                <td>@item.Email</td>
                                <td>@(string.IsNullOrEmpty(item.Phone) ? "-" : item.Phone)</td>
                                <td class="text-muted">@item.JoinDate.ToString("dd.MM.yyyy")</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge badge-active"><i class="fa-solid fa-circle-check me-1"></i>Aktif Üye</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-passive"><i class="fa-solid fa-circle-xmark me-1"></i>Pasif Üye</span>
                                    }
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.MemberId" class="btn btn-sm btn-light border-primary-subtle text-primary">
                                            <i class="fa-regular fa-pen-to-square"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.MemberId" method="post" onsubmit="return confirm('Bu üye kaydını silmek istediğinize emin misiniz? Bu işlem üyeye ait tüm antrenman seanslarını da silecektir.');" style="display:inline;">
                                            <button type="submit" class="btn btn-sm btn-light border-danger-subtle text-danger">
                                                <i class="fa-regular fa-trash-can"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
