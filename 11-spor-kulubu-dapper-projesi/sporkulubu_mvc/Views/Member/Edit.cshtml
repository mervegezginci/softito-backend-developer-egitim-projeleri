@model sporkulubu_mvc.Models.MemberViewModel
@{
    ViewData["Title"] = "Üye Bilgilerini Düzenle";
}

<div class="row mb-4">
    <div class="col">
        <h2 class="fw-bold text-dark m-0">Üye Bilgilerini Düzenle</h2>
        <p class="text-muted mb-0">Üyenin iletişim bilgilerini ve kulüpteki aktiflik durumunu güncelleyin.</p>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card border-0 bg-white shadow-sm p-4">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="MemberId"/>
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FirstName" class="form-label"></label>
                        <input asp-for="FirstName" class="form-control"/>
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="LastName" class="form-label"></label>
                        <input asp-for="LastName" class="form-control"/>
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" type="email" class="form-control"/>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Phone" class="form-label"></label>
                    <input asp-for="Phone" class="form-control"/>
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>

                <div class="mb-4 form-check form-switch ps-5">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox"/>
                    <label asp-for="IsActive" class="form-check-label fw-semibold text-dark">Üye Aktif mi?</label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-solid fa-floppy-disk me-2"></i>Değişiklikleri Kaydet
                    </button>
                    <a asp-action="Index" class="btn btn-light">
                        İptal
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
