@model IEnumerable<sporkulubu_mvc.Models.TrainingViewModel>
@{
    ViewData["Title"] = "Antrenmanlar";
}

<div class="row mb-4 align-items-center">
    <div class="col">
        <h2 class="fw-bold text-dark m-0">Antrenman Seansları</h2>
        <p class="text-muted mb-0">Planlanan veya tamamlanan kişisel/grup antrenman ders programı.</p>
    </div>
    <div class="col-auto">
        <a asp-action="Create" class="btn btn-primary">
            <i class="fa-solid fa-plus me-2"></i>Yeni Seans Planla
        </a>
    </div>
</div>

<div class="card border-0 bg-white shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Üye Bilgisi</th>
                        <th>Antrenör</th>
                        <th>Branş</th>
                        <th>Tarih ve Saat</th>
                        <th>Süre</th>
                        <th>Seans Ücreti</th>
                        <th class="pe-4 text-end" style="width: 150px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="fa-regular fa-folder-open mb-2" style="font-size: 2.5rem; display: block;"></i>
                                Planlanmış antrenman seansı bulunamadı.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">@item.MemberName</td>
                                <td>
                                    <div class="fw-semibold">@item.CoachName</div>
                                </td>
                                <td>
                                    <span class="badge bg-light text-primary border border-primary-subtle">
                                        @item.BranchName
                                    </span>
                                </td>
                                <td class="text-muted">@item.TrainingDate.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@item.DurationMinutes dk</td>
                                <td class="fw-bold text-success">@item.Fee.ToString("C2")</td>
                                <td class="pe-4 text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.TrainingId" class="btn btn-sm btn-light border-primary-subtle text-primary">
                                            <i class="fa-regular fa-pen-to-square"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.TrainingId" method="post" onsubmit="return confirm('Bu antrenman seans kaydını silmek istediğinize emin misiniz?');" style="display:inline;">
                                            <button type="submit" class="btn btn-sm btn-light border-danger-subtle text-danger">
                                                <i class="fa-regular fa-trash-can"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
