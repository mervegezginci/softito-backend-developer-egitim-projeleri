@{
    ViewData["Title"] = "Hoş Geldiniz";
    Layout = "_Layout";
}

<!-- Hero Section -->
<div class="hero-section text-white py-5 px-4 rounded-4 mb-5 shadow-lg" style="background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #311042 100%); position: relative; overflow: hidden;">
    <div class="row align-items-center py-5">
        <div class="col-lg-7 ps-lg-5 text-center text-lg-start">
            <span class="badge bg-primary px-3 py-2 mb-3 text-uppercase fw-bold tracking-wider" style="font-size: 0.8rem; letter-spacing: 1.5px; box-shadow: 0 4px 10px rgba(99, 102, 241, 0.3);">SPOR KULÜBÜ BİLGİ SİSTEMİ</span>
            <h1 class="display-3 fw-bold mb-3 lh-sm text-gradient" style="background: linear-gradient(135deg, #ffffff 40%, #c084fc 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Limitlerini Zorla,<br>Gücünü Keşfet!</h1>
            <p class="lead text-slate-300 mb-4 fs-5" style="color: #94a3b8; max-width: 580px;">Branşlar, antrenörler, üyeler ve antrenman seanslarını tek bir merkezden yönetin. Gelişmiş veri analitiği ve modern raporlama özellikleriyle sporcularınızın gelişimini takip edin.</p>
            
            <div class="d-flex flex-wrap justify-content-center justify-content-lg-start gap-3">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="/Home/Dashboard" class="btn btn-primary btn-lg px-4 py-3">
                        <i class="fa-solid fa-chart-pie me-2"></i>Yönetim Paneline Git
                    </a>
                }
                else
                {
                    <a href="/Account/Login" class="btn btn-primary btn-lg px-4 py-3">
                        <i class="fa-solid fa-right-to-bracket me-2"></i>Yönetici Girişi Yap
                    </a>
                    <a href="/Account/Register" class="btn btn-outline-light btn-lg px-4 py-3" style="border-radius: 12px;">
                        <i class="fa-solid fa-user-plus me-2"></i>Yeni Kayıt Oluştur
                    </a>
                }
            </div>
        </div>
        <div class="col-lg-5 text-center mt-5 mt-lg-0">
            <div class="position-relative d-inline-block">
                <!-- Large decorative glowing circle -->
                <div class="position-absolute bg-primary rounded-circle blur-lg" style="width: 250px; height: 250px; opacity: 0.15; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 0; filter: blur(50px);"></div>
                <i class="fa-solid fa-dumbbell text-primary display-1 rotate-15 position-relative" style="font-size: 10rem; opacity: 0.85; filter: drop-shadow(0 0 30px rgba(99, 102, 241, 0.4)); z-index: 1;"></i>
            </div>
        </div>
    </div>
</div>

<!-- Features Section -->
<div class="row g-4 mb-5">
    <div class="col-12 text-center mb-2">
        <h2 class="fw-bold text-dark">Sistem Özellikleri ve Yetenekleri</h2>
        <p class="text-muted" style="max-width: 600px; margin: 0 auto;">Dapper ORM ve SQL Stored Procedure mimarisi üzerine kurulan ultra performanslı yönetim paneli özellikleri.</p>
    </div>
    
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm p-4 bg-white">
            <div class="rounded-circle bg-light p-3 d-inline-flex align-items-center justify-content-center mb-3" style="color: #6366f1; width: 60px; height: 60px;">
                <i class="fa-solid fa-basketball fs-3"></i>
            </div>
            <h5 class="fw-bold text-dark">Dinamik Branş Yönetimi</h5>
            <p class="text-muted small mb-0">Futbol, Tenis, Yüzme, Kick Boks gibi farklı spor branşlarını tanımlayın, düzenleyin ve sistem genelinde aktif olarak ilişkilendirin.</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm p-4 bg-white">
            <div class="rounded-circle bg-light p-3 d-inline-flex align-items-center justify-content-center mb-3" style="color: #10b981; width: 60px; height: 60px;">
                <i class="fa-solid fa-user-tie fs-3"></i>
            </div>
            <h5 class="fw-bold text-dark">Antrenör Atamaları</h5>
            <p class="text-muted small mb-0">Uzman eğitmenlerin iletişim bilgilerini ve sorumlu oldukları spor branşlarını atayın, seans yüklerini ve hasılat verilerini inceleyin.</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm p-4 bg-white">
            <div class="rounded-circle bg-light p-3 d-inline-flex align-items-center justify-content-center mb-3" style="color: #f59e0b; width: 60px; height: 60px;">
                <i class="fa-solid fa-calendar-check fs-3"></i>
            </div>
            <h5 class="fw-bold text-dark">Seans Programlama</h5>
            <p class="text-muted small mb-0">Üyelerinize ait özel ders ve antrenman seanslarını saat, süre ve ücret bazlı planlayın, hasılat kayıtlarını Stored Procedure'lar ile hızlıca işleyin.</p>
        </div>
    </div>
</div>

<!-- Stats Banner Section -->
<div class="card border-0 shadow-sm bg-white p-4 mb-5">
    <div class="row text-center g-4">
        <div class="col-6 col-md-3">
            <h2 class="fw-bold text-primary m-0">1500+</h2>
            <small class="text-muted text-uppercase fw-semibold" style="font-size: 0.75rem;">Aktif Sporcu</small>
        </div>
        <div class="col-6 col-md-3">
            <h2 class="fw-bold text-success m-0">20+</h2>
            <small class="text-muted text-uppercase fw-semibold" style="font-size: 0.75rem;">Uzman Antrenör</small>
        </div>
        <div class="col-6 col-md-3">
            <h2 class="fw-bold text-warning m-0">10+</h2>
            <small class="text-muted text-uppercase fw-semibold" style="font-size: 0.75rem;">Spor Branşı</small>
        </div>
        <div class="col-6 col-md-3">
            <h2 class="fw-bold text-danger m-0">0.05 ms</h2>
            <small class="text-muted text-uppercase fw-semibold" style="font-size: 0.75rem;">Dapper SP Hızı</small>
        </div>
    </div>
</div>

<!-- Extra Polished Features Banner -->
<div class="row g-4 align-items-center mb-4">
    <div class="col-lg-6">
        <h3 class="fw-bold text-dark mb-3">Güçlü Veri Analizi ve PDF / Excel Çıktıları</h3>
        <p class="text-muted">Tek tıkla tüm sporcularınızın ve antrenman seanslarınızın listelerini profesyonel formatlarda raporlayın. iTextSharp ile Türkçe karakter destekli PDF listeleri indirin veya EPPlus ile detaylı Excel dosyaları oluşturarak paylaşın.</p>
        <ul class="list-unstyled mt-3">
            <li class="mb-2"><i class="fa-solid fa-circle-check text-success me-2"></i> Türkçe Harf Uyumlu iTextSharp PDF Çıktıları</li>
            <li class="mb-2"><i class="fa-solid fa-circle-check text-success me-2"></i> Hücre Boyutlandırmalı EPPlus Excel Raporları</li>
            <li class="mb-2"><i class="fa-solid fa-circle-check text-success me-2"></i> Veritabanında Direkt Stored Procedure Hızı</li>
        </ul>
    </div>
    <div class="col-lg-6 text-center">
        <div class="p-4 bg-light rounded-4 border">
            <i class="fa-solid fa-file-invoice-dollar text-primary display-3 mb-3 d-block" style="filter: drop-shadow(0 4px 10px rgba(99, 102, 241, 0.2));"></i>
            <h6 class="fw-bold text-dark">Raporlama ve Finansal Takip</h6>
            <p class="text-muted small mb-0" style="max-width: 400px; margin: 0 auto;">Hangi spor branşının ne kadar hasılat getirdiğini, antrenörlerin seans bazlı ortalamalarını ve en aktif üyelerin finansal dökümünü anlık izleyin.</p>
        </div>
    </div>
</div>

<style>
    /* Subtle rotation animation on page load */
    .rotate-15 {
        transform: rotate(-15deg);
        transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .hero-section:hover .rotate-15 {
        transform: rotate(5deg) scale(1.05);
    }
</style>
