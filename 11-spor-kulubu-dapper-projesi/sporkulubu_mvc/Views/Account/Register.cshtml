@model sporkulubu_mvc.Models.RegisterViewModel
@{
    ViewData["Title"] = "Kaydol";
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Sisteme Kaydol - Spor Kulübü</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <style>
        body { 
            font-family: 'Outfit', sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%); 
            min-height: 100vh; 
            display: flex; 
            align-items: center; 
        }
        .card { 
            border: none; 
            border-radius: 20px; 
            box-shadow: 0 20px 60px rgba(0,0,0,0.4); 
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
        }
        .brand-icon { 
            font-size: 3.5rem; 
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .btn-brand { 
            background: linear-gradient(135deg, #6366f1, #8b5cf6); 
            border: none; 
            border-radius: 12px;
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
        }
        .btn-brand:hover { 
            background: linear-gradient(135deg, #4f46e5, #7c3aed); 
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(99, 102, 241, 0.4);
        }
        .form-control, .form-select {
            border: 1px solid #cbd5e1;
            border-radius: 12px;
            padding: 10px 16px;
        }
        .form-control:focus, .form-select:focus { 
            border-color: #6366f1; 
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.15); 
        }
    </style>
</head>
<body>
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card p-4">
                <div class="text-center mb-4">
                    <i class="fa-solid fa-user-plus brand-icon"></i>
                    <h4 class="mt-2 fw-bold text-dark">Kayıt Ol</h4>
                    <p class="text-muted">Yeni Yönetici Hesabı Oluşturun</p>
                </div>
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger" style="border-radius: 10px; font-size: 0.9rem;">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        { <div><i class="fa-solid fa-triangle-exclamation me-2"></i>@error.ErrorMessage</div> }
                    </div>
                }
                <form asp-action="Register" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Kullanıcı Adı</label>
                        <input asp-for="Username" class="form-control" placeholder="yönetici_adı"/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">E-posta</label>
                        <input asp-for="Email" class="form-control" placeholder="ornek@sporkulubu.com"/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Şifre</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="••••••••"/>
                    </div>
                    <input type="hidden" asp-for="Role" value="User" />
                    <button type="submit" class="btn btn-brand btn-lg w-100 text-white fw-bold">
                        <i class="fa-solid fa-user-check me-2"></i>Kayıt İşlemini Tamamla
                    </button>
                </form>
                <hr/>
                <div class="text-center">
                    <small class="text-muted">Zaten hesabınız var mı? <a asp-action="Login" class="text-primary fw-bold text-decoration-none">Giriş Yapın</a></small>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>
