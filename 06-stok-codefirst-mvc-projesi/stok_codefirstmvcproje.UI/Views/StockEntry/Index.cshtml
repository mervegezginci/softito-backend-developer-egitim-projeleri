@model List<StockEntry>

<div class="card shadow-sm border-0">

    <div class="card-header d-flex justify-content-between align-items-center bg-white py-3">

        <h4 class="mb-0">Depoya Girişler</h4>

        <div class="d-flex gap-2">
            <button onclick="window.print()" class="btn btn-outline-secondary">
                <i class="bx bx-printer me-1"></i> Yazdır / PDF
            </button>
            <button onclick="exportTableToCSV('stockEntriesTable', 'stok-giris-raporu.csv')" class="btn btn-success">
                <i class="bx bx-file me-1"></i> Excel İndir
            </button>
            <a asp-controller="StockEntry"
               asp-action="Create"
               class="btn btn-primary">
                Yeni Giriş
            </a>
        </div>

    </div>

    <div class="card-body">

        <table class="table table-bordered table-hover align-middle" id="stockEntriesTable">

            <thead>
                <tr>
                    <th>ID</th>
                    <th>Ürün</th>
                    <th>Tedarikçi</th>
                    <th>Adet</th>
                    <th>Tarih</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td class="fw-semibold">@item.Product.Name</td>
                        <td>@item.Supplier.CompanyName</td>
                        <td class="fw-bold text-success">+@item.Quantity</td>
                        <td>@item.EntryDate.ToString("dd.MM.yyyy")</td>
                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

<!-- Yazdırma Modu CSS -->
<style>
    @@media print {
        body * {
            visibility: hidden;
        }
        .card, .card * {
            visibility: visible;
        }
        .card {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
            border: none !important;
            box-shadow: none !important;
        }
        .btn, .navbar, .layout-menu {
            display: none !important;
        }
    }
</style>

<!-- CSV Export Javascript -->
<script>
    function exportTableToCSV(tableId, filename) {
        var csv = [];
        var rows = document.querySelectorAll("#" + tableId + " tr");
        
        for (var i = 0; i < rows.length; i++) {
            var row = [], cols = rows[i].querySelectorAll("td, th");
            
            for (var j = 0; j < cols.length; j++) {
                var text = cols[j].innerText.replace(/"/g, '""');
                row.push('"' + text + '"');
            }
            csv.push(row.join(";"));
        }
        
        var csvFile = new Blob(["\ufeff" + csv.join("\n")], { type: "text/csv;charset=utf-8;" });
        var downloadLink = document.createElement("a");
        downloadLink.download = filename;
        downloadLink.href = window.URL.createObjectURL(csvFile);
        downloadLink.style.display = "none";
        document.body.appendChild(downloadLink);
        downloadLink.click();
        document.body.removeChild(downloadLink);
    }
</script>