@model List<stok_codefirstmvcproje.model.Category>

<div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="mb-0">Kategoriler</h4>

                <a href="@Url.Action("Create", "Category")"
                   class="btn btn-dark">
                    Yeni Kategori
                </a>
            </div>
        </div>

        <div class="card-body">

            <form method="get" class="mb-4">
                <input type="text"
                       name="search"
                       class="form-control"
                       placeholder="Kategori Ara..." />
            </form>

            <table id="categoryTable" class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Kategori Adı</th>
                        <th width="180">İşlemler</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CategoryName</td>

                            <td>
                                <a href="@Url.Action("Edit", "Category", new { id = item.Id })"
                                   class="btn btn-sm btn-outline-primary">
                                    Düzenle
                                </a>

                                <a href="@Url.Action("Delete", "Category", new { id = item.Id })"
                                   class="btn btn-sm btn-outline-danger">
                                    Sil
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>
