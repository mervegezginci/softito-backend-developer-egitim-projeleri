@model stok_codefirstmvcproje.model.Product

@using Microsoft.AspNetCore.Mvc.Rendering

<div>

    <div class="card shadow-sm border-0">

        <div class="card-header bg-white">
            <h4>Ürün Düzenle</h4>
        </div>

        <div class="card-body">

            <form method="post"
                  action="@Url.Action("Edit","Product")">

                <input type="hidden"
                       name="Id"
                       value="@Model.Id" />

                <div class="mb-3">
                    <label>Ürün Adı</label>
                    <input type="text"
                           name="Name"
                           value="@Model.Name"
                           class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Stok</label>
                    <input type="number"
                           name="StockQty"
                           value="@Model.StockQty"
                           class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Fiyat</label>
                    <input asp-for="UnitPrice"
                           type="number"
                           step="0.01"
                           class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Kategori</label>
                    <select name="CategoryId"
                            class="form-select"
                            asp-items="ViewBag.Categories">
                    </select>
                </div>

                <div class="mb-3">
                    <label>Tedarikçi</label>
                    <select name="SupplierId"
                            class="form-select"
                            asp-items="ViewBag.Suppliers">
                    </select>
                </div>

                <button class="btn btn-dark">
                    Güncelle
                </button>

            </form>

        </div>

    </div>

</div>