<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>

    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
            color: #1e293b;
            margin: 0;
            padding: 0;
        }

        #wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar Styling */
        #sidebar {
            width: 260px;
            background-color: #0f172a;
            color: #94a3b8;
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            border-right: 1px solid #1e293b;
        }

        .sidebar-heading {
            padding: 1.5rem;
            font-size: 1.1rem;
            font-weight: 800;
            color: #ffffff;
            border-bottom: 1px solid #1e293b;
        }

        .list-group-item {
            background-color: transparent;
            color: #94a3b8;
            border: none;
            padding: 0.8rem 1.5rem;
            font-size: 0.95rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: all 0.2s ease;
            text-decoration: none;
        }

        .list-group-item:hover {
            background-color: #1e293b;
            color: #ffffff;
        }

        .list-group-item.active {
            background-color: #2563eb;
            color: #ffffff;
            font-weight: 600;
            border-radius: 6px;
            margin: 0 10px;
            padding-left: calc(1.5rem - 10px);
        }

        /* Content Area */
        #content-wrapper {
            flex-grow: 1;
            padding: 2rem;
            overflow-y: auto;
        }

        .card-admin {
            border-radius: 12px;
            border: none;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -2px rgba(0, 0, 0, 0.05);
        }

        .table thead {
            background-color: #f1f5f9;
        }

        .table th {
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            color: #64748b;
        }

        /* Print media settings */
        @@media print {
            #sidebar {
                display: none !important;
            }
            #content-wrapper {
                padding: 0 !important;
                width: 100% !important;
            }
            .no-print, .btn {
                display: none !important;
            }
        }
    </style>
</head>
<body>
    <div id="wrapper">
        <!-- Sidebar -->
        <div id="sidebar" class="no-print">
            <div class="sidebar-heading d-flex align-items-center gap-2">
                <i class="fas fa-graduation-cap text-primary fs-4"></i>
                <span class="text-white">EduPlatform</span>
                <span class="badge bg-danger ms-auto" style="font-size: 0.6rem; padding: 3px 6px;">ADMIN</span>
            </div>
            <div class="list-group list-group-flush mt-3 flex-grow-1">
                <a href="/Admin" class="list-group-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")">
                    <i class="fas fa-chart-line fs-5"></i> Raporlar
                </a>
                <a href="/Category" class="list-group-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")">
                    <i class="fas fa-tags fs-5"></i> Kategoriler
                </a>
                <a href="/Course" class="list-group-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Course" ? "active" : "")">
                    <i class="fas fa-book-open fs-5"></i> Kurslar
                </a>
                <a href="/Enrollment" class="list-group-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Enrollment" ? "active" : "")">
                    <i class="fas fa-user-graduate fs-5"></i> Başvurular
                </a>
            </div>
            <div class="p-3 border-top border-1 border-secondary">
                <a href="/" class="btn btn-outline-secondary w-100 btn-sm text-white border-secondary rounded-pill">
                    <i class="fas fa-globe me-1"></i> Siteye Git
                </a>
            </div>
        </div>

        <!-- Content Area -->
        <div id="content-wrapper">
            @RenderBody()
        </div>
    </div>

    <!-- Bootstrap Bundle JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
