<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - EduPlatform</title>
    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- FontAwesome for Premium Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Custom site.css -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true">
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
            color: #1e293b;
        }
        .navbar-brand {
            font-weight: 800;
            letter-spacing: -0.5px;
            color: #2563eb !important;
        }
        .nav-link {
            font-weight: 500;
            color: #475569 !important;
            transition: color 0.2s ease;
        }
        .nav-link:hover {
            color: #2563eb !important;
        }
        /* Footer Stilleri */
        footer {
            background-color: #0f172a;
            color: #94a3b8;
            border-top: 1px solid #1e293b;
        }
        footer a {
            color: #cbd5e1;
            text-decoration: none;
            transition: color 0.2s ease;
        }
        footer a:hover {
            color: #3b82f6;
        }
        footer hr {
            border-color: #1e293b;
        }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg bg-white border-bottom py-3 sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="/">
                <i class="fas fa-graduation-cap text-primary fs-3"></i>
                <span>EduPlatform</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav" aria-controls="nav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav ms-auto align-items-center gap-2">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Anasayfa</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/#categories">Kategoriler</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/#courses">Kurslar</a>
                    </li>
                    <li class="nav-item ms-lg-2">
                        <a class="btn btn-primary btn-sm px-3 rounded-pill fw-semibold text-white" href="/Admin">
                            <i class="fas fa-user-shield me-1"></i> Yönetim Paneli
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="py-5 mt-5">
        <div class="container">
            <div class="row g-4 justify-content-between">
                <div class="col-lg-4 col-md-6">
                    <a class="navbar-brand d-flex align-items-center gap-2 text-white mb-3" href="/">
                        <i class="fas fa-graduation-cap text-primary fs-3"></i>
                        <span class="text-white">EduPlatform</span>
                    </a>
                    <p class="small text-muted mb-0">Javascript ve modern web teknolojileri odağında hazırlanmış, Türkiye'nin lider yazılım eğitimi platformu.</p>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h6 class="text-white fw-bold mb-3">Hızlı Bağlantılar</h6>
                    <ul class="list-unstyled small d-flex flex-column gap-2">
                        <li><a href="/"><i class="fas fa-angle-right me-1 text-primary"></i> Anasayfa</a></li>
                        <li><a href="/#categories"><i class="fas fa-angle-right me-1 text-primary"></i> Kategoriler</a></li>
                        <li><a href="/#courses"><i class="fas fa-angle-right me-1 text-primary"></i> Kurslar</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h6 class="text-white fw-bold mb-3">İletişim</h6>
                    <ul class="list-unstyled small d-flex flex-column gap-2 text-muted">
                        <li><i class="fas fa-map-marker-alt me-2 text-primary"></i> Beşiktaş, İstanbul, Türkiye</li>
                        <li><i class="fas fa-envelope me-2 text-primary"></i> destek@eduplatform.com</li>
                        <li><i class="fas fa-phone me-2 text-primary"></i> +90 (212) 555 0199</li>
                    </ul>
                </div>
            </div>
            <hr class="my-4">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3 small">
                <p class="mb-0">© 2026 EduPlatform. Tüm Hakları Saklıdır.</p>
                <div class="d-flex gap-3 text-white fs-5">
                    <a href="#" class="text-muted"><i class="fab fa-facebook-f"></i></a>
                    <a href="#" class="text-muted"><i class="fab fa-twitter"></i></a>
                    <a href="#" class="text-muted"><i class="fab fa-linkedin-in"></i></a>
                    <a href="#" class="text-muted"><i class="fab fa-github"></i></a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap Bundle JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
