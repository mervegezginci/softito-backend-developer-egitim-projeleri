                        </li>

                        <li class="nav-item">
                            <a class="nav-link link-secondary ps-0" href="#comments">
                                Müşteri Yorumları
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link link-secondary ps-0" href="#addcomment">
                                Yorum Yap
                            </a>
                        </li>

                    </ul>
                </div>

                @* <div class="col-12 col-lg-6 col-xl-3 border-end p-5">
                    <h3 class="h6 mb-3">Kahve Menüsü</h3>

                    <ul class="nav flex-column">

                        @foreach (var item in (List<Product>)ViewBag.Products)
