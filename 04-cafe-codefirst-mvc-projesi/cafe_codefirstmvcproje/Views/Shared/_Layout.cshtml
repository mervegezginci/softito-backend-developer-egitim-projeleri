                    </svg>
                    <address class="text-secondary mt-3">
                        <strong>Evrem Cafe</strong><br>
                        Taze Kahve ve Lezzetli Molalar<br>
                        Sakarya, Türkiye<br>
                        <abbr title="Telefon">T:</abbr>
                        +90 555 555 55 55
                    </address>
                </div>
                <div class="col-12 col-lg-6 col-xl-3 border-end p-5">
                    <h3 class="h6 mb-3">Kurumsal</h3>

                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link link-secondary ps-0" href="#products">
                                Ürünler
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link link-secondary ps-0" href="#aboutus">
                                Hakkımızda
