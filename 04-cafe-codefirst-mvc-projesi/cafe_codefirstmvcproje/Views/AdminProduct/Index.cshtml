@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@model List<Product>

<h2>Ürünler</h2>

<a href="@Url.Action("Create", "AdminProduct")" class="btn btn-primary mb-3">
    Yeni Ürün
</a>

<form method="get" action="@Url.Action("Index", "AdminProduct")" class="mb-3">
    <div class="input-group">
        <input type="text"
               name="search"
               value="@Context.Request.Query["search"]"
               class="form-control"
               placeholder="Ürün ara..." />
    </div>
</form>

<table class="table table-bordered">

    <tr>
        <th>Ürün</th>
        <th>Fiyat</th>
        <th>Popüler</th>
        <th>Sil</th>
        <th>Güncelle</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.ProductName</td>
            <td>@item.Price ₺</td>

            <td>
                @(item.IsPopular ? "Evet" : "Hayır")
            </td>

            <td>
                <a href="@Url.Action("Delete", "AdminProduct", new { id = item.Id })"
                   class="btn btn-danger">
                    Sil
                </a>
            </td>

            <td>
                <a href="@Url.Action("Update", "AdminProduct", new { id = item.Id })"
                   class="btn btn-warning">
                    Güncelle
                </a>
            </td>

        </tr>
    }

</table>