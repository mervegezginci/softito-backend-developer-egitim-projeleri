@{
    ViewData["Title"] = "Hoş Geldiniz";
    Layout = "_Layout";
}

<!-- Hero Section -->
<div class="hero-section text-white py-5 px-4 rounded-4 mb-5 shadow-lg" style="background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 50%, #172554 100%); position: relative; overflow: hidden;">
    <div class="row align-items-center py-5">
        <div class="col-lg-7 ps-lg-5 text-center text-lg-start">
            <span class="badge bg-primary px-3 py-2 mb-3 text-uppercase fw-bold tracking-wider" style="font-size: 0.8rem; letter-spacing: 1.5px; box-shadow: 0 4px 10px rgba(59, 130, 246, 0.3);">ÖĞRENCİ YÖNETİM SİSTEMİ</span>
            <h1 class="display-3 fw-bold mb-3 lh-sm text-gradient" style="background: linear-gradient(135deg, #ffffff 40%, #93c5fd 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Geleceği Şekillendir,<br>Bilgiyi Yönet!</h1>
            <p class="lead text-slate-300 mb-4 fs-5" style="color: #94a3b8; max-width: 580px;">Öğrenci işleri, akademik bölümler ve not dökümlerini tek bir sistemde buluşturun. Dapper ORM ve gelişmiş SQL Stored Procedure performansı ile verilerinizi ışık hızında sorgulayın.</p>
            
            <div class="d-flex flex-wrap justify-content-center justify-content-lg-start gap-3">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="/Home/Dashboard" class="btn btn-primary btn-lg px-4 py-3">
                        <i class="fa-solid fa-chart-pie me-2"></i>Yönetim Paneline Git
                    </a>
                }
                else
                {
                    <a href="/Account/Login" class="btn btn-primary btn-lg px-4 py-3">
                        <i class="fa-solid fa-right-to-bracket me-2"></i>Akademik Giriş Yap
                    </a>
                    <a href="/Account/Register" class="btn btn-outline-light btn-lg px-4 py-3" style="border-radius: 12px;">
                        <i class="fa-solid fa-user-plus me-2"></i>Yeni Kayıt Oluştur
                    </a>
                }
            </div>
        </div>
        <div class="col-lg-5 text-center mt-5 mt-lg-0">
            <div class="position-relative d-inline-block">
                <!-- Decorative glowing background -->
                <div class="position-absolute bg-primary rounded-circle blur-lg" style="width: 250px; height: 250px; opacity: 0.15; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 0; filter: blur(50px);"></div>
                <i class="fa-solid fa-graduation-cap text-primary display-1 rotate-15 position-relative" style="font-size: 10rem; opacity: 0.85; filter: drop-shadow(0 0 30px rgba(59, 130, 246, 0.4)); z-index: 1;"></i>
            </div>
        </div>
    </div>
</div>

<!-- Features Section -->
<div class="row g-4 mb-5">
    <div class="col-12 text-center mb-2">
        <h2 class="fw-bold text-dark">Sistem Özellikleri ve Yetenekleri</h2>
        <p class="text-muted" style="max-width: 600px; margin: 0 auto;">Dapper ORM ve SQL Stored Procedure mimarisi üzerine kurulan ultra performanslı yönetim paneli özellikleri.</p>
    </div>
    
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm p-4 bg-white">
            <div class="rounded-circle bg-light p-3 d-inline-flex align-items-center justify-content-center mb-3" style="color: #2563eb; width: 60px; height: 60px;">
                <i class="fa-solid fa-sitemap fs-3"></i>
            </div>
            <h5 class="fw-bold text-dark">Bölüm Yönetimi</h5>
            <p class="text-muted small mb-0">Bilgisayar Mühendisliği, Tıp, Mimarlık gibi tüm akademik bölümleri ekleyin, güncelleyin ve kontenjan durumlarını takip edin.</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm p-4 bg-white">
            <div class="rounded-circle bg-light p-3 d-inline-flex align-items-center justify-content-center mb-3" style="color: #059669; width: 60px; height: 60px;">
                <i class="fa-solid fa-user-graduate fs-3"></i>
            </div>
            <h5 class="fw-bold text-dark">Öğrenci İşleri</h5>
            <p class="text-muted small mb-0">Öğrencilerin kayıt bilgilerini, iletişim detaylarını ve eğitim durumlarını ilişkisel veritabanında güvenle saklayın.</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm p-4 bg-white">
            <div class="rounded-circle bg-light p-3 d-inline-flex align-items-center justify-content-center mb-3" style="color: #d97706; width: 60px; height: 60px;">
                <i class="fa-solid fa-spell-check fs-3"></i>
            </div>
            <h5 class="fw-bold text-dark">Not Giriş & Harf Notu</h5>
            <p class="text-muted small mb-0">Öğrencilere ait sınav sonuçlarını kaydedin, ders başarı ortalamalarını ve harf notlarını anında listeleyin.</p>
        </div>
    </div>
</div>

<!-- Stats Banner Section -->
<div class="card border-0 shadow-sm bg-white p-4 mb-5">
    <div class="row text-center g-4">
        <div class="col-6 col-md-3">
            <h2 class="fw-bold text-primary m-0">5000+</h2>
            <small class="text-muted text-uppercase fw-semibold" style="font-size: 0.75rem;">Aktif Öğrenci</small>
        </div>
        <div class="col-6 col-md-3">
            <h2 class="fw-bold text-success m-0">40+</h2>
            <small class="text-muted text-uppercase fw-semibold" style="font-size: 0.75rem;">Akademik Bölüm</small>
        </div>
        <div class="col-6 col-md-3">
            <h2 class="fw-bold text-warning m-0">15000+</h2>
            <small class="text-muted text-uppercase fw-semibold" style="font-size: 0.75rem;">Toplam Sınav Notu</small>
        </div>
        <div class="col-6 col-md-3">
            <h2 class="fw-bold text-danger m-0">0.03 ms</h2>
            <small class="text-muted text-uppercase fw-semibold" style="font-size: 0.75rem;">Dapper Sorgu Hızı</small>
        </div>
    </div>
</div>

<!-- Extra Features Section -->
<div class="row g-4 align-items-center mb-4">
    <div class="col-lg-6">
        <h3 class="fw-bold text-dark mb-3">Kolay ve Güçlü Akademik Raporlama</h3>
        <p class="text-muted">Tek bir tuşla tüm öğrenci dökümlerini ve not verilerini Excel veya PDF formatlarında dışa aktarın. iTextSharp yardımıyla hazırlanan Türkçe karakter destekli PDF dökümanları doğrudan paylaşabilirsiniz.</p>
        <ul class="list-unstyled mt-3">
            <li class="mb-2"><i class="fa-solid fa-circle-check text-success me-2"></i> Türkçe Harf Uyumlu iTextSharp PDF Çıktısı</li>
            <li class="mb-2"><i class="fa-solid fa-circle-check text-success me-2"></i> Kolay Filtrelenebilir Excel Tabloları</li>
            <li class="mb-2"><i class="fa-solid fa-circle-check text-success me-2"></i> Güvenli API-MVC Veri İletişim Katmanı</li>
        </ul>
    </div>
    <div class="col-lg-6 text-center">
        <div class="p-4 bg-light rounded-4 border">
            <i class="fa-solid fa-chart-line text-primary display-3 mb-3 d-block" style="filter: drop-shadow(0 4px 10px rgba(59, 130, 246, 0.2));"></i>
            <h6 class="fw-bold text-dark">Grafikler ve Başarı Oranları</h6>
            <p class="text-muted small mb-0" style="max-width: 400px; margin: 0 auto;">Bölüm bazlı ortalama not dağılımlarını, en yüksek puan alan öğrencileri ve mezun durumundaki öğrencileri anlık izleyin.</p>
        </div>
    </div>
</div>

<style>
    /* Subtle rotation animation on page load */
    .rotate-15 {
        transform: rotate(-15deg);
        transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .hero-section:hover .rotate-15 {
        transform: rotate(5deg) scale(1.05);
    }
</style>
