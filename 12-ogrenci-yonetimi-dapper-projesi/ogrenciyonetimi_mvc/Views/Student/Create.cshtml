@model ogrenciyonetimi_mvc.Models.StudentViewModel
@{
    ViewData["Title"] = "Yeni Öğrenci Ekle";
}

<div class="mb-4">
    <h2 class="fw-bold text-dark m-0"><i class="fa-solid fa-user-plus me-2 text-primary"></i>Yeni Öğrenci Ekle</h2>
    <p class="text-muted">Öğrencinin kişisel ve akademik bilgilerini girerek sisteme kaydedin.</p>
</div>

<div class="card border-0 shadow-sm bg-white" style="max-width: 650px;">
    <div class="card-title-bar">
        <span class="text-dark fw-bold"><i class="fa-solid fa-graduation-cap me-2 text-primary"></i>Öğrenci Bilgi Formu</span>
        <a href="/Student" class="btn btn-sm btn-light">İptal</a>
    </div>
    <div class="card-body p-4">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger border-0 mb-4" style="border-radius: 12px; background: #fdf2f2; color: #d63031;">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                { <div><i class="fa-solid fa-triangle-exclamation me-2"></i>@error.ErrorMessage</div> }
            </div>
        }
        <form asp-action="Create" method="post">
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold text-dark">Adı <span class="text-danger">*</span></label>
                    <input asp-for="FirstName" class="form-control px-3 py-2" style="border-radius: 10px;" placeholder="Ahmet" required/>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold text-dark">Soyadı <span class="text-danger">*</span></label>
                    <input asp-for="LastName" class="form-control px-3 py-2" style="border-radius: 10px;" placeholder="Yılmaz" required/>
                </div>
            </div>
            
            <div class="mb-3">
                <label class="form-label fw-semibold text-dark">E-posta Adresi <span class="text-danger">*</span></label>
                <input asp-for="Email" type="email" class="form-control px-3 py-2" style="border-radius: 10px;" placeholder="ahmet.yilmaz@universite.edu.tr" required/>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold text-dark">Telefon Numarası</label>
                <input asp-for="Phone" class="form-control px-3 py-2" style="border-radius: 10px;" placeholder="0555 123 45 67"/>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-semibold text-dark">Akademik Bölüm <span class="text-danger">*</span></label>
                    <select asp-for="DepartmentId" class="form-select px-3 py-2" style="border-radius: 10px;" required>
                        @foreach (var dept in (IEnumerable<ogrenciyonetimi_mvc.Models.DepartmentViewModel>)ViewBag.Departments)
                        {
                            <option value="@dept.DepartmentId">@dept.DepartmentName</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold text-dark">Sınıf Seviyesi <span class="text-danger">*</span></label>
                    <select asp-for="GradeLevel" class="form-select px-3 py-2" style="border-radius: 10px;" required>
                        <option value="1">1. Sınıf</option>
                        <option value="2">2. Sınıf</option>
                        <option value="3">3. Sınıf</option>
                        <option value="4">4. Sınıf</option>
                    </select>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4 py-2">
                    <i class="fa-solid fa-circle-check me-2"></i>Öğrenciyi Kaydet
                </button>
                <a href="/Student" class="btn btn-light px-4 py-2">Geri Dön</a>
            </div>
        </form>
    </div>
</div>
