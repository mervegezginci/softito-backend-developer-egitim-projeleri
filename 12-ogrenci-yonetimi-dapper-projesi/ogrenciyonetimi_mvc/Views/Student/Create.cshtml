@model ogrenciyonetimi_mvc.Models.StudentViewModel
@{
    ViewData["Title"] = "Yeni Öğrenci Ekle";
}

<div class="mb-4">
    <h2 class="fw-bold"><i class="fa-solid fa-user-plus me-2 text-primary"></i>Yeni Öğrenci Ekle</h2>
</div>

<div class="card" style="max-width:600px;">
    <div class="card-header"><i class="fa-solid fa-graduation-cap me-2"></i>Öğrenci Bilgileri</div>
    <div class="card-body">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                { <div>@error.ErrorMessage</div> }
            </div>
        }
        <form asp-action="Create" method="post">
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Adı <span class="text-danger">*</span></label>
                    <input asp-for="FirstName" class="form-control" placeholder="Ahmet"/>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Soyadı <span class="text-danger">*</span></label>
                    <input asp-for="LastName" class="form-control" placeholder="Yılmaz"/>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">E-posta Adresi <span class="text-danger">*</span></label>
                <input asp-for="Email" type="email" class="form-control" placeholder="ahmet@universite.edu.tr"/>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Telefon</label>
                <input asp-for="Phone" class="form-control" placeholder="0555 123 45 67"/>
            </div>
            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Bölüm <span class="text-danger">*</span></label>
                    <select asp-for="DepartmentId" class="form-select">
                        @foreach (var dept in (IEnumerable<ogrenciyonetimi_mvc.Models.DepartmentViewModel>)ViewBag.Departments)
                        {
                            <option value="@dept.DepartmentId">@dept.DepartmentName</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Sınıf Seviyesi <span class="text-danger">*</span></label>
                    <select asp-for="GradeLevel" class="form-select">
                        <option value="1">1. Sınıf</option>
                        <option value="2">2. Sınıf</option>
                        <option value="3">3. Sınıf</option>
                        <option value="4">4. Sınıf</option>
                    </select>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="fa-solid fa-save me-1"></i>Öğrenciyi Kaydet</button>
                <a href="/Student" class="btn btn-outline-secondary">İptal</a>
            </div>
        </form>
    </div>
</div>
