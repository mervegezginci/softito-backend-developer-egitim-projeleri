<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Öğrenci Yönetim</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
    <style>
        body { background: #f4f6f9; }
        .navbar { background: linear-gradient(135deg, #3498db, #2c3e50) !important; }
        .navbar-brand, .nav-link { color: white !important; }
        .nav-link:hover { color: #d4e6f1 !important; }
        .sidebar { background: white; min-height: calc(100vh - 56px); border-right: 1px solid #dee2e6; padding: 20px 0; }
        .sidebar .nav-link { color: #555; padding: 10px 20px; border-radius: 8px; margin: 2px 10px; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { background: #3498db; color: white !important; }
        .sidebar .nav-link i { width: 20px; }
        .main-content { padding: 25px; }
        .card { border: none; border-radius: 12px; box-shadow: 0 2px 15px rgba(0,0,0,0.08); }
        .card-header { border-radius: 12px 12px 0 0 !important; background: linear-gradient(135deg, #3498db, #2c3e50); color: white; }
        .btn-primary { background: #3498db; border-color: #3498db; }
        .btn-primary:hover { background: #2980b9; border-color: #2980b9; }
    </style>
</head>
<body>
<nav class="navbar navbar-expand-lg">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="/Student">
            <i class="fa-solid fa-graduation-cap me-2"></i>Öğrenci Yönetimi (API Tüketici)
        </a>
        <div class="ms-auto d-flex align-items-center gap-3">
            <span class="text-white"><i class="fa-solid fa-user me-1"></i>@User.Identity?.Name</span>
            <a href="/Account/Logout" class="btn btn-outline-light btn-sm">
                <i class="fa-solid fa-right-from-bracket me-1"></i>Çıkış
            </a>
        </div>
    </div>
</nav>

<div class="d-flex">
    <div class="sidebar" style="width:220px; min-width:220px;">
        <nav class="nav flex-column">
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Student" ? "active" : "")" href="/Student">
                <i class="fa-solid fa-users me-2"></i>Öğrenciler
            </a>
            <hr class="mx-3"/>
            <a class="nav-link" href="/Student/ExportPdf">
                <i class="fa-solid fa-file-pdf me-2 text-danger"></i>Rapor PDF
            </a>
            <a class="nav-link" href="/Student/ExportExcel">
                <i class="fa-solid fa-file-excel me-2 text-success"></i>Rapor Excel
            </a>
        </nav>
    </div>
    <div class="main-content flex-grow-1">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="fa-solid fa-triangle-exclamation me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
