@model IEnumerable<ogrenciyonetimi_mvc.Models.DepartmentViewModel>
@{
    ViewData["Title"] = "Akademik Bölümler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-dark m-0"><i class="fa-solid fa-building me-2 text-primary"></i>Bölüm Yönetimi</h2>
        <p class="text-muted mb-0">Üniversite bünyesindeki tüm akademik bölümleri ekleyebilir, güncelleyebilir ve silebilirsiniz.</p>
    </div>
    <a href="/Department/Create" class="btn btn-primary">
        <i class="fa-solid fa-plus me-1"></i>Yeni Bölüm Tanımla
    </a>
</div>

<!-- Tablo -->
<div class="card border-0 shadow-sm bg-white" style="max-width: 800px;">
    <div class="card-title-bar">
        <span class="text-dark fw-bold"><i class="fa-solid fa-list me-2 text-primary"></i>Kayıtlı Bölümler (@Model.Count() adet)</span>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4" style="width: 100px;">ID</th>
                    <th>Bölüm Adı</th>
                    <th class="pe-4 text-end" style="width: 150px;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-semibold text-muted">@item.DepartmentId</td>
                        <td class="fw-bold text-dark">@item.DepartmentName</td>
                        <td class="pe-4 text-end">
                            <a href="/Department/Edit/@item.DepartmentId" class="btn btn-sm btn-outline-primary me-1" style="border-radius: 8px;">
                                <i class="fa-solid fa-pen"></i>
                            </a>
                            <form method="post" action="/Department/Delete/@item.DepartmentId" class="d-inline"
                                  onsubmit="return confirm('Bölümü silmek istediğinizden emin misiniz?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius: 8px;">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="3" class="text-center text-muted py-4">Kayıtlı bölüm bulunamadı.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
