@model IEnumerable<ogrenciyonetimi_mvc.Models.GradeViewModel>
@{
    ViewData["Title"] = "Not Sistemi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-dark m-0"><i class="fa-solid fa-file-signature me-2 text-primary"></i>Not Yönetim Paneli</h2>
        <p class="text-muted mb-0">Öğrencilerinize ait ders notu girişlerini, puanlarını ve sınav kayıtlarını yönetin.</p>
    </div>
    <a href="/Grade/Create" class="btn btn-primary">
        <i class="fa-solid fa-plus me-1"></i>Yeni Not Girişi Yap
    </a>
</div>

<!-- Tablo -->
<div class="card border-0 shadow-sm bg-white">
    <div class="card-title-bar">
        <span class="text-dark fw-bold"><i class="fa-solid fa-list me-2 text-primary"></i>Girilen Sınav Notları (@Model.Count() adet)</span>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4" style="width: 80px;">ID</th>
                    <th>Öğrenci Adı Soyadı</th>
                    <th>Ders Adı</th>
                    <th>Not / Puan</th>
                    <th>Giriş Tarihi</th>
                    <th class="pe-4 text-end" style="width: 150px;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-semibold text-muted">#@item.GradeId</td>
                        <td class="fw-bold text-dark">@item.StudentName</td>
                        <td><span class="badge bg-light text-primary border border-primary-subtle">@item.CourseName</span></td>
                        <td>
                            @if (item.Score >= 50)
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle" style="font-size: 0.9rem; padding: 6px 12px;">@item.Score / 100</span>
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle text-danger border border-danger-subtle" style="font-size: 0.9rem; padding: 6px 12px;">@item.Score / 100</span>
                            }
                        </td>
                        <td class="text-muted small">@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="pe-4 text-end">
                            <a href="/Grade/Edit/@item.GradeId" class="btn btn-sm btn-outline-primary me-1" style="border-radius: 8px;">
                                <i class="fa-solid fa-pen"></i>
                            </a>
                            <form method="post" action="/Grade/Delete/@item.GradeId" class="d-inline"
                                  onsubmit="return confirm('Bu not kaydını silmek istediğinizden emin misiniz?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius: 8px;">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Kayıtlı not girişi bulunamadı.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
