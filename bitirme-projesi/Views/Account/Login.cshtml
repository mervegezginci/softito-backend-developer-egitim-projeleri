@model seyahat_projesi.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="auth-page-container">
    <div class="auth-card">
        <h2>Tekrar Hoş Geldiniz</h2>
        <p>GM Travel hesabınıza giriş yaparak planlarınızı yönetin.</p>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success" style="display:block;">
                @TempData["SuccessMessage"]
            </div>
        }

        <form asp-action="Login" method="post">
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:block; margin-bottom: 1rem;"></div>
            }

            <div class="form-group">
                <label asp-for="Email">E-posta Adresi</label>
                <input asp-for="Email" class="form-control" placeholder="ornek@domain.com" required />
                <span asp-validation-for="Email" style="color:var(--accent-orange); font-size:0.8rem;"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Şifre</label>
                <input asp-for="Password" class="form-control" placeholder="••••••••" required />
                <span asp-validation-for="Password" style="color:var(--accent-orange); font-size:0.8rem;"></span>
            </div>

            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 1.5rem; width:100%;">
                <div class="form-group" style="flex-direction:row; align-items:center; gap:0.5rem; cursor:pointer; margin-bottom:0;">
                    <input asp-for="RememberMe" style="cursor:pointer;" />
                    <label asp-for="RememberMe" style="cursor:pointer; margin-bottom:0;">Beni Hatırla</label>
                </div>
                <a href="/Account/ForgotPassword" style="font-size:0.85rem; color:var(--accent-teal); text-decoration:none; font-weight: 500;">Şifremi Unuttum</a>
            </div>

            <button type="submit" class="btn btn-teal" style="width: 100%; justify-content: center; padding: 0.8rem; border-radius:8px;">Giriş Yap</button>
        </form>

        <div class="auth-footer">
            Hesabınız yok mu? <a href="/Account/Register">Hemen Kayıt Olun</a>
        </div>
    </div>
</div>
