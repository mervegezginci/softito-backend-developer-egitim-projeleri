@{
    ViewData["Title"] = "Şifremi Unuttum";
}

<div class="auth-page-container">
    <div class="auth-card">
        <h2>Şifremi Unuttum</h2>
        <p>E-posta adresinizi girerek şifre sıfırlama bağlantısını talep edebilirsiniz.</p>

        <form asp-action="ForgotPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:block; margin-bottom: 1rem;"></div>

            <div class="form-group">
                <label for="email">E-posta Adresi</label>
                <input type="email" id="email" name="email" class="form-control" placeholder="ornek@domain.com" required />
            </div>

            <button type="submit" class="btn btn-teal" style="width: 100%; justify-content: center; margin-top: 1.5rem; padding: 0.8rem; border-radius:8px;">Sıfırlama Bağlantısı Gönder</button>
        </form>

        <div class="auth-footer">
            Şifrenizi hatırladınız mı? <a href="/Account/Login">Giriş Yapın</a>
        </div>
    </div>
</div>
