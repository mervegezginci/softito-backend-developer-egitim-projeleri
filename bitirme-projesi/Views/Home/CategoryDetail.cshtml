@model IEnumerable<seyahat_projesi.Model.Tour>
@{
    var category = ViewBag.Category as seyahat_projesi.Model.Category;
    ViewData["Title"] = category?.Name + " Seyahatleri";

    // Set custom background images and taglines based on category names
    string imageUrl = "https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?w=1600&auto=format&fit=crop&q=80";
    string subtitle = "Eşsiz Rotalar ve Unutulmaz Seyahat Deneyimleri";
    
    if (category?.Name == "Kültür")
    {
        imageUrl = "https://images.unsplash.com/photo-1552832230-c0197dd311b5?w=1600&auto=format&fit=crop&q=80"; // Rome Colosseum
        subtitle = "Tarihin ve Kültürün Köklerine Doğru Eşsiz Yolculuklar";
    }
    else if (category?.Name == "Doğa & Macera")
    {
        imageUrl = "https://images.unsplash.com/photo-1501555088652-021faa106b9b?w=1600&auto=format&fit=crop&q=80"; // Mountain hike
        subtitle = "Doğanın Kucağında Heyecan ve Huzur Dolu Maceralar";
    }
    else if (category?.Name == "Ege-Akdeniz")
    {
        imageUrl = "https://images.unsplash.com/photo-1499793983690-e29da59ef1c2?w=1600&auto=format&fit=crop&q=80"; // Turquoise beach
        subtitle = "Güneşin ve Mavi Suların Buluştuğu Ayrıcalıklı Rotalar";
    }
}

<link rel="stylesheet" href="~/css/premium-travel.css" asp-append-version="true" />

<div class="premium-page-container">
    <!-- Category Detail Hero Header -->
    <header class="premium-hero-header" style="background: linear-gradient(rgba(15, 23, 42, 0.6), rgba(15, 23, 42, 0.95)), url('@imageUrl') center/cover;">
        <span class="premium-mini-tag" style="background: rgba(255, 255, 255, 0.1); color: white; border: 1px solid rgba(255, 255, 255, 0.2);">Kategori</span>
        <h1>@category?.Name Turları</h1>
        <p>@category?.Description</p>
        <div style="font-size: 0.95rem; color: #cbd5e1; font-weight: 600; letter-spacing: 0.5px; margin-top: 1rem;">@subtitle</div>
    </header>

    <!-- Tours Grid under Category -->
    <main style="max-width: 1200px; margin: 5rem auto; padding: 0 1.5rem;">
        <div class="premium-section-header">
            <span class="premium-mini-tag">Seyahat Paketleri</span>
            <h2>@category?.Name Kategorisindeki Turlar</h2>
        </div>

        <div class="premium-tours-grid">
            @if (Model == null || !Model.Any())
            {
                <div class="no-results-card" style="grid-column: 1 / -1; text-align: center; padding: 4rem 2rem; background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 20px; box-shadow: var(--card-shadow); max-width: 600px; margin: 2rem auto; display: flex; flex-direction: column; align-items: center; gap: 1.25rem;">
                    <div style="font-size: 3rem; width: 70px; height: 70px; background: rgba(13, 148, 136, 0.08); color: var(--accent-teal); border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 15px rgba(13, 148, 136, 0.1);">
                        <svg class="lucide-icon" style="width:32px; height:32px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect><line x1="16" x2="16" y1="2" y2="6"></line><line x1="8" x2="8" y1="2" y2="6"></line><line x1="3" x2="21" y1="10" y2="10"></line></svg>
                    </div>
                    <h3 style="font-size: 1.5rem; font-weight: 700; color: var(--text-primary); margin: 0;">Bu Kategoride Tur Bulunmuyor</h3>
                    <p style="color: var(--text-secondary); line-height: 1.6; margin: 0; max-width: 450px;">
                        Bu kategoride şu anda yayında olan bir seyahat programımız bulunmamaktadır. En kısa sürede yeni rotalar eklenecektir.
                    </p>
                    <a href="/Categories" class="premium-btn premium-btn-primary" style="padding: 0.75rem 2rem; border-radius: 50px; text-decoration: none; margin-top: 0.5rem; display: inline-block;">Kategorilere Geri Dön</a>
                </div>
            }
            else
            {
                foreach (var tour in Model)
                {
                    string categoryBadge = tour.Category?.Name ?? "Popüler";
                    if (categoryBadge == "Ege-Akdeniz") categoryBadge = "Lüks & Deniz";
                    else if (categoryBadge == "Kültür") categoryBadge = "Kültür & Doğa";
                    else if (categoryBadge == "Doğa & Macera") categoryBadge = "Macera & Huzur";

                    <div class="premium-tour-card">
                        <div class="premium-tour-img-container">
                            <img src="@tour.ImageUrl" alt="@tour.Title" class="premium-tour-img">
                            <span class="premium-tour-badge">@categoryBadge</span>
                            <span class="premium-tour-duration">@tour.DurationDays Gün</span>
                        </div>
                        <div class="premium-tour-body">
                            <div class="premium-tour-rating">
                                <svg class="lucide-icon" style="color:#eab308; fill:#eab308;" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                                @tour.AverageRating.ToString("F1") <span>(@tour.ReviewCount Değerlendirme)</span>
                            </div>
                            <h3 class="premium-tour-title">@tour.Title</h3>
                            <p class="premium-tour-desc">@tour.Description</p>
                            
                            <div class="premium-tour-info-row">
                                <span class="premium-tour-info-item">
                                    <svg class="lucide-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                                    @tour.Location
                                </span>
                                <span class="premium-tour-info-item">
                                    <svg class="lucide-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect><line x1="16" x2="16" y1="2" y2="6"></line><line x1="8" x2="8" y1="2" y2="6"></line><line x1="3" x2="21" y1="10" y2="10"></line></svg>
                                    @tour.StartDate.ToString("dd MMM") - @tour.EndDate.ToString("dd MMM")
                                </span>
                            </div>
                            
                            <div class="premium-tour-guide-row">
                                <svg class="lucide-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                                Rehber: <strong>@tour.Guide?.FullName</strong>
                            </div>

                            <div class="premium-tour-footer">
                                <div style="display:flex; justify-content:space-between; align-items:flex-end; width:100%;">
                                    <div class="premium-tour-price-box">
                                        <span class="premium-tour-price-label">Kişi Başı</span>
                                        <span class="premium-tour-price-val">@tour.Price.ToString("N0") TL</span>
                                    </div>
                                    <div style="font-size:0.8rem; color:var(--text-muted); font-weight:600; margin-bottom: 2px;">Kontenjan: @tour.Capacity</div>
                                </div>
                                <div class="premium-tour-actions">
                                    <a href="/Home/Detail/@tour.Id" class="premium-btn premium-btn-secondary">İncele</a>
                                    <a href="/Booking/Checkout?tourId=@tour.Id" class="premium-btn premium-btn-primary">Rezerve Et</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </main>
</div>
