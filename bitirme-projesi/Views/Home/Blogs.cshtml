@model IEnumerable<seyahat_projesi.Model.Blog>
@{
    ViewData["Title"] = "Seyahat Blogu";
    
    // Varied aspect ratio travel images for beautiful masonry flow
    var masonryImages = new[] {
        "https://images.unsplash.com/photo-1527838832700-50592524df7e?w=600&auto=format&fit=crop&q=80", // Cappadocia - Landscape
        "https://images.unsplash.com/photo-1506012787146-f92b2d7d6d96?w=600&auto=format&fit=crop&q=80", // Balloon - Portrait
        "https://images.unsplash.com/photo-1488646953014-85cb44e25828?w=600&auto=format&fit=crop&q=80", // Map - Landscape
        "https://images.unsplash.com/photo-1533105079780-92b9be482077?w=600&auto=format&fit=crop&q=80", // Santorini - Portrait
        "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=600&auto=format&fit=crop&q=80", // Beach - Landscape
        "https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?w=600&auto=format&fit=crop&q=80", // Boat - Landscape
        "https://images.unsplash.com/photo-1519046904884-53103b34b206?w=600&auto=format&fit=crop&q=80", // Beach chair - Portrait
        "https://images.unsplash.com/photo-1501785888041-af3ef285b470?w=600&auto=format&fit=crop&q=80", // Alps - Landscape
        "https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?w=600&auto=format&fit=crop&q=80", // Tent/Stars - Portrait
        "https://images.unsplash.com/photo-1505118380757-91f5f5632de0?w=600&auto=format&fit=crop&q=80"  // Seaside pool - Landscape
    };
}

<link rel="stylesheet" href="~/css/premium-travel.css" asp-append-version="true" />

<div class="premium-page-container">
    <!-- Blog Header Hero -->
    <header class="premium-hero-header" style="background: linear-gradient(rgba(15, 23, 42, 0.5), rgba(15, 23, 42, 0.85)), url('https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?w=1600&auto=format&fit=crop&q=80') center/cover; min-height: 350px;">
        <span class="premium-mini-tag" style="background: var(--accent-teal); color: white; border: none; font-size: 0.8rem; padding: 0.5rem 1.5rem; box-shadow: 0 4px 10px rgba(13, 148, 136, 0.3);">GM TRAVEL BLOG</span>
        <h1 style="text-shadow: 0 4px 15px rgba(0,0,0,0.3); margin-top: 1rem;">Seyahat Rehberimiz & Hikayeler</h1>
        <p>Uzman rehberlerimizin ve gezginlerimizin gözünden en özel rotalar, kültür rehberleri ve gezi ipuçları.</p>
    </header>

    <!-- Blogs Masonry Grid -->
    <main style="max-width: 1200px; margin: 4.5rem auto 6rem; padding: 0 1.5rem;">
        <div class="premium-blog-masonry">
            @if (Model != null && Model.Any())
            {
                foreach (var blog in Model)
                {
                    // Select image with varying aspect ratio based on ID
                    string displayImg = masonryImages[blog.Id % masonryImages.Length];
                    
                    <a href="/Home/BlogDetail/@blog.Id" class="premium-blog-card">
                        <div class="premium-blog-img-container">
                            <img src="@displayImg" alt="@blog.Title" class="premium-blog-img">
                        </div>
                        <div class="premium-blog-body">
                            <span class="premium-blog-date">📅 @blog.CreatedAt.ToString("dd MMMM yyyy")</span>
                            <h3 class="premium-blog-title">@blog.Title</h3>
                            <p class="premium-blog-desc">@blog.Content</p>
                            
                            <div class="premium-blog-footer">
                                Okumaya Devam Et 
                                <svg class="lucide-icon" style="transition: transform 0.3s ease;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                            </div>
                        </div>
                    </a>
                }
            }
            else
            {
                <div style="column-span: all; text-align: center; padding: 5rem 2rem; background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 20px; box-shadow: var(--card-shadow); max-width: 600px; margin: 2rem auto;">
                    <div style="font-size: 3rem; margin-bottom: 1rem;">✍️</div>
                    <h3 style="font-size: 1.5rem; font-weight: 700; color: var(--text-primary);">Blog Bulunamadı</h3>
                    <p style="color: var(--text-secondary); line-height: 1.6;">Sistemde şu anda yayınlanmış herhangi bir blog yazısı bulunmamaktadır.</p>
                </div>
            }
        </div>
    </main>
</div>
