@model IEnumerable<seyahat_projesi.Model.Category>
@{
    ViewData["Title"] = "Tur Kategorileri";
}

<link rel="stylesheet" href="~/css/premium-travel.css" asp-append-version="true" />

<div class="premium-page-container">
    <!-- Categories Header Hero - Bright, sunlit Santorini image -->
    <header class="premium-hero-header" style="background: linear-gradient(rgba(15, 23, 42, 0.45), rgba(15, 23, 42, 0.8)), url('https://images.unsplash.com/photo-1533105079780-92b9be482077?w=1600&auto=format&fit=crop&q=80') center/cover; min-height: 380px;">
        <span class="premium-mini-tag" style="background: var(--accent-teal); color: white; border: none; font-size: 0.8rem; padding: 0.5rem 1.5rem; box-shadow: 0 4px 10px rgba(13, 148, 136, 0.3);">GM TRAVEL TARZINI KEŞFET</span>
        <h1 style="text-shadow: 0 4px 15px rgba(0,0,0,0.3); margin-top: 1rem;">Seyahat Kategorilerimiz</h1>
        <p>Seyahat tarzınıza en uygun kategoriyi seçerek size özel hazırladığımız eşsiz seyahat programlarını keşfedin.</p>
    </header>

    <!-- Categories Grid - Positioned cleanly below the hero with standard top margin -->
    <main style="max-width: 1200px; margin: 4.5rem auto 6rem; padding: 0 1.5rem;">
        <div class="premium-categories-grid">
            @if (Model != null)
            {
                foreach (var cat in Model)
                {
                    // Set custom parameters based on category names - Compass icon as default travel fallback
                    string svgIcon = @"<svg class='lucide-icon' style='width:24px; height:24px;' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='10'/><polygon points='16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76'/></svg>";
                    string label = "Keşfet";
                    string glowClass = "category-glow-default";
                    string bgAccent = "rgba(13, 148, 136, 0.1)";
                    string iconColor = "var(--accent-teal)";
                    
                    if (cat.Name == "Kültür")
                    {
                        svgIcon = @"<svg class='lucide-icon' style='width:24px; height:24px;' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><line x1='3' x2='21' y1='22' y2='22'/><line x1='6' x2='6' y1='18' y2='11'/><line x1='10' x2='10' y1='18' y2='11'/><line x1='14' x2='14' y1='18' y2='11'/><line x1='18' x2='18' y1='18' y2='11'/><path d='M12 2 2 7v3h20V7Z'/></svg>";
                        label = "Kültür & Tarih Turları";
                        glowClass = "category-glow-culture";
                        bgAccent = "rgba(234, 88, 12, 0.1)";
                        iconColor = "#ea580c";
                    }
                    else if (cat.Name == "Doğa & Macera")
                    {
                        svgIcon = @"<svg class='lucide-icon' style='width:24px; height:24px;' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M10 10v.01'/><path d='M9.5 14H5a3 3 0 0 1-2.28-4.94a3 3 0 0 1 3.92-3.92A3 3 0 0 1 11.66 8M14 10v.01'/><path d='M14.5 14H19a3 3 0 0 0 2.28-4.94a3 3 0 0 0-3.92-3.92A3 3 0 0 0 12.34 8'/><path d='M14 19.5v-5.5'/><path d='M10 19.5v-9.5'/><path d='M18 19.5v-5.5'/></svg>";
                        label = "Doğa & Macera Turları";
                        glowClass = "category-glow-nature";
                        bgAccent = "rgba(16, 185, 129, 0.1)";
                        iconColor = "#10b981";
                    }
                    else if (cat.Name == "Ege-Akdeniz")
                    {
                        svgIcon = @"<svg class='lucide-icon' style='width:24px; height:24px;' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='4'/><path d='M12 2v2'/><path d='M12 20v2'/><path d='m4.93 4.93 1.41 1.41'/><path d='m17.66 17.66 1.41 1.41'/><path d='M2 12h2'/><path d='M20 12h2'/><path d='m6.34 17.66-1.41 1.41'/><path d='m19.07 4.93-1.41 1.41'/></svg>";
                        label = "Lüks Deniz & Yaz Turları";
                        glowClass = "category-glow-sea";
                        bgAccent = "rgba(14, 165, 233, 0.1)";
                        iconColor = "#0ea5e9";
                    }
                    else if (cat.Name.Contains("Balayı") || cat.Name.Contains("Aşk") || cat.Name.Contains("Romantik"))
                    {
                        svgIcon = @"<svg class='lucide-icon' style='width:24px; height:24px;' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z'/></svg>";
                        label = "Romantik Balayı Turları";
                        glowClass = "category-glow-honeymoon";
                        bgAccent = "rgba(244, 63, 94, 0.1)";
                        iconColor = "#f43f5e";
                    }
                    
                    <a href="/Category/Detail/@cat.Id" class="premium-category-card-vector @glowClass">
                        <!-- Icon & Main Info -->
                        <div style="z-index: 2; display: flex; flex-direction: column; gap: 1.5rem; height: 100%;">
                            <div class="premium-icon-box" style="width: 56px; height: 56px; border-radius: 14px; background: @bgAccent; color: @iconColor; display: flex; align-items: center; justify-content: center; transition: transform 0.3s ease;">
                                @Html.Raw(svgIcon)
                            </div>
                            <div style="display: flex; flex-direction: column; gap: 0.5rem; margin-top: auto;">
                                <div style="font-size: 0.8rem; font-weight: 700; color: @iconColor; text-transform: uppercase; letter-spacing: 1px;">@label</div>
                                <h2 style="font-size: 1.5rem; font-weight: 800; color: var(--text-primary); margin: 0; letter-spacing: -0.5px;">@cat.Name</h2>
                                <p style="font-size: 0.9rem; color: var(--text-secondary); margin: 0; line-height: 1.5; font-weight: 500;">@cat.Description</p>
                            </div>
                        </div>
                        
                        <!-- Footer Action -->
                        <div style="z-index: 2; display: flex; align-items: center; justify-content: space-between; margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--border-color); width: 100%;">
                            <span style="font-size: 0.85rem; font-weight: 700; color: var(--text-primary); display: flex; align-items: center; gap: 0.5rem;">
                                Turları Keşfet
                                <svg class="arrow-trans lucide-icon" style="width:14px; height:14px; transition: transform 0.3s ease;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                            </span>
                            <span style="font-size: 0.8rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase;">@cat.Name</span>
                        </div>
                    </a>
                }
            }
        </div>
    </main>
</div>
