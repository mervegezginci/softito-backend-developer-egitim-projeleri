@{
    bool isAdminPage = ViewContext.RouteData.Values["controller"]?.ToString() == "Admin";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GM Travel | Lüks Seyahat ve Tatil Acentesi</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/user-dashboard.css" asp-append-version="true" />
</head>
<body>
    <script>
        // Apply theme immediately before rendering body to prevent flash
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'dark') {
            document.body.classList.add('dark-theme');
        }
    </script>

    <nav class="navbar">
        <div style="display:flex; justify-content:center; align-items:center; gap:2.5rem;">
            <a href="/" class="nav-logo">GM <span>Travel</span></a>

            @if (!isAdminPage)
            {
                <ul class="nav-links" id="navLinks">
                    <li class="active"><a href="/">Ana Sayfa</a></li>
                    <li><a href="/Tours">Turlar</a></li>
                    <li><a href="/Categories">Kategoriler</a></li>
                    <li><a href="/Home/Blogs">Blog</a></li>
                    <li><a href="/#about">Hakkımızda</a></li>
                    <li><a href="/#deals">Fırsatlar</a></li>
                    <li><a href="/#contact">İletişim</a></li>
                </ul>

                <!-- Mobile Hamburger Button -->
                <button class="mobile-menu-btn" id="mobileMenuBtn" type="button" aria-label="Menüyü Aç" style="display:none;">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
                </button>
            }
        </div>


        <div class="nav-actions">
            <!-- Light/Dark Mode Switcher Button -->
            <button class="theme-toggle-btn" id="themeToggleBtn" type="button" title="Tema Değiştir">
                <!-- Sun Icon (shown in dark theme to switch to light) -->
                <svg id="sunIcon" style="display:none;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
                <!-- Moon Icon (shown in light theme to switch to dark) -->
                <svg id="moonIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
            </button>

            @if (isAdminPage)
            {
                <a href="/" class="btn btn-teal">Siteye Git</a>
                <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                    <button type="submit" class="btn btn-danger" style="padding:0.5rem 1.2rem; border-radius:50px;">Çıkış</button>
                </form>
            }
            else
            {
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a href="/User" style="font-size:0.95rem; font-weight:500; color:var(--text-secondary);">Profilim</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin" class="btn btn-secondary" style="padding:0.5rem 1.2rem;">Yönetici Paneli</a>
                    }
                    <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-danger" style="padding:0.5rem 1.2rem; border-radius:50px;">Çıkış</button>
                    </form>
                }
                else
                {
                    <a href="/Account/Login" style="font-size:0.95rem; font-weight:500; color:var(--text-secondary);">Giriş Yap</a>
                    <a href="/Account/Register" class="btn btn-secondary" style="padding:0.5rem 1.2rem;">Kayıt Ol</a>
                }
                <a href="/#tours" class="btn btn-teal">Hemen Rezerve Et</a>
            }
        </div>
    </nav>

    <!-- Main Content Container -->
    <div style="min-height: calc(100vh - 250px);">
        <div style="max-width: 1200px; margin: 0 auto; padding: 1rem 1.5rem 0;">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success" style="background: rgba(13,148,136,0.15); color: var(--accent-teal); border: 1px solid var(--accent-teal); padding: 1rem; border-radius: 8px; font-weight: 600; margin-bottom: 1rem;">
                    @TempData["SuccessMessage"]
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger" style="background: rgba(239,68,68,0.15); color: #ef4444; border: 1px solid #ef4444; padding: 1rem; border-radius: 8px; font-weight: 600; margin-bottom: 1rem;">
                    @TempData["ErrorMessage"]
                </div>
            }
        </div>
        @RenderBody()
    </div>

    <!-- GM Travel Footer (Hidden on Admin pages) -->
    @if (!isAdminPage)
    {
        <footer class="footer-new">
            <div class="footer-grid">
                <!-- Sütun 1: Marka ve İletişim -->
                <div class="footer-col">
                    <a href="/" class="nav-logo" style="margin-bottom: 1rem; display: inline-block;">GM <span>Travel</span></a>
                    <div class="footer-contact-item">
                        <span>📞</span> Tel: +90 555 111 2233
                    </div>
                    <div class="footer-contact-item">
                        <span>✉️</span> info@gmtravel.com
                    </div>
                    <div class="footer-contact-item">
                        <span>📍</span> İstanbul, TR
                    </div>
                    <div class="footer-social-icons">
                        <a href="#" title="Facebook"><svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1V12h3v3h-3v6.8c4.56-.93 8-4.96 8-9.8z"/></svg></a>
                        <a href="#" title="Instagram"><svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg></a>
                        <a href="#" title="Twitter/X"><svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
                    </div>
                </div>

                <!-- Sütun 2: Hızlı Bağlantılar -->
                <div class="footer-col">
                    <h4>Hızlı Menü</h4>
                    <ul>
                        <li><a href="/">Ana Sayfa</a></li>
                        <li><a href="/#about">Hakkımızda</a></li>
                        <li><a href="/#tours">Destinasyonlar</a></li>
                        <li><a href="/#deals">Fırsatlar</a></li>
                        <li><a href="/#contact">İletişim</a></li>
                    </ul>
                </div>

                <!-- Sütun 3: Kategoriler -->
                <div class="footer-col">
                    <h4>Kategoriler</h4>
                    <ul>
                        <li><a href="/#tours">Kültür Turları</a></li>
                        <li><a href="/#tours">Doğa & Macera</a></li>
                        <li><a href="/#tours">Ege-Akdeniz</a></li>
                        <li><a href="/#tours">Tüm Rotalar</a></li>
                    </ul>
                </div>

                <!-- Sütun 4: Sözleşmeler -->
                <div class="footer-col">
                    <h4>Yasal & Sözleşmeler</h4>
                    <ul>
                        <li><a href="/Home/Policy#privacy">Gizlilik Politikası</a></li>
                        <li><a href="/Home/Policy#terms">Kullanım Koşulları</a></li>
                        <li><a href="/Home/Policy#refund">İptal & İade Koşulları</a></li>
                        <li><a href="/Home/Policy#sales">Mesafeli Satış Sözleşmesi</a></li>
                    </ul>
                </div>

                <!-- Sütun 5: Kurumsal -->
                <div class="footer-col">
                    <h4>Kurumsal</h4>
                    <ul>
                        <li><a href="/#about">Biz Kimiz?</a></li>
                        <li><a href="/#about">Vizyonumuz</a></li>
                        <li><a href="/#contact">Canlı Destek</a></li>
                        <li><a href="/Account/Login">Yönetici Girişi</a></li>
                    </ul>
                </div>
            </div>

            <!-- Alt Bilgi Satırı -->
            <div class="footer-bottom-row">
                <p style="margin: 0;">&copy; 2026 <span>GM Travel</span> - Gamze & Merve Mezuniyet Ortak Projesi. Tüm Hakları Saklıdır.</p>
                <p style="margin: 0;">Powered by .NET Core MVC & Entity Framework</p>
            </div>
        </footer>
    }

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const themeToggleBtn = document.getElementById('themeToggleBtn');
            const sunIcon = document.getElementById('sunIcon');
            const moonIcon = document.getElementById('moonIcon');
            const mobileMenuBtn = document.getElementById('mobileMenuBtn');
            const navLinks = document.getElementById('navLinks');

            // Mobile Menu Toggle
            if (mobileMenuBtn && navLinks) {
                mobileMenuBtn.addEventListener('click', () => {
                    navLinks.classList.toggle('active');
                });
            }

            function updateThemeIcons() {
                if (document.body.classList.contains('dark-theme')) {
                    sunIcon.style.display = 'block';
                    moonIcon.style.display = 'none';
                } else {
                    sunIcon.style.display = 'none';
                    moonIcon.style.display = 'block';
                }
            }

            // Sync on load
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme === 'dark') {
                document.body.classList.add('dark-theme');
            } else {
                document.body.classList.remove('dark-theme');
            }
            updateThemeIcons();

            themeToggleBtn.addEventListener('click', () => {
                document.body.classList.toggle('dark-theme');
                if (document.body.classList.contains('dark-theme')) {
                    localStorage.setItem('theme', 'dark');
                } else {
                    localStorage.setItem('theme', 'light');
                }
                updateThemeIcons();
            });

            // --- Canlı Destek Sohbet Kutusu JS Mantığı ---
            const chatTriggerBtn = document.getElementById('chatTriggerBtn');
            const chatBoxContainer = document.getElementById('chatBoxContainer');
            const chatBoxCloseBtn = document.getElementById('chatBoxCloseBtn');
            const chatBoxBody = document.getElementById('chatBoxBody');
            const chatInput = document.getElementById('chatInput');
            const chatSendBtn = document.getElementById('chatSendBtn');

            // Benzersiz SessionID al veya oluştur
            let sessionId = sessionStorage.getItem('chat_session_id');
            if (!sessionId) {
                sessionId = 'session_' + Math.random().toString(36).substring(2, 11);
                sessionStorage.setItem('chat_session_id', sessionId);
            }

            // Sohbet geçmişini getir
            async function loadChatHistory() {
                try {
                    const res = await fetch('/Home/GetChatMessages?sessionId=' + sessionId);
                    const messages = await res.json();
                    
                    chatBoxBody.innerHTML = '';
                    
                    if (messages.length === 0) {
                        // Varsayılan açılış mesajını ekle
                        appendMessageBubble('admin', 'Merhaba! GM Travel destek merkezine hoş geldiniz. Size nasıl yardımcı olabiliriz?');
                    } else {
                        messages.forEach(msg => {
                            appendMessageBubble(msg.sender, msg.messageText);
                        });
                    }
                    scrollToBottom();
                } catch (err) {
                    console.error(err);
                }
            }

            function appendMessageBubble(sender, text) {
                const bubble = document.createElement('div');
                bubble.className = 'chat-msg chat-msg-' + sender;
                bubble.textContent = text;
                chatBoxBody.appendChild(bubble);
            }

            function scrollToBottom() {
                chatBoxBody.scrollTop = chatBoxBody.scrollHeight;
            }

            // Sohbet kutusunu aç/kapat
            chatTriggerBtn.addEventListener('click', () => {
                const isVisible = chatBoxContainer.style.display === 'flex';
                if (isVisible) {
                    chatBoxContainer.style.display = 'none';
                } else {
                    chatBoxContainer.style.display = 'flex';
                    loadChatHistory();
                }
            });

            chatBoxCloseBtn.addEventListener('click', () => {
                chatBoxContainer.style.display = 'none';
            });

            // Mesaj Gönder
            async function sendMessage() {
                const text = chatInput.value.trim();
                if (!text) return;

                // Anında ekrana ekle (Hız hissi için)
                appendMessageBubble('user', text);
                chatInput.value = '';
                scrollToBottom();

                const formData = new FormData();
                formData.append('sessionId', sessionId);
                formData.append('message', text);

                try {
                    await fetch('/Home/SendChatMessage', {
                        method: 'POST',
                        body: formData
                    });
                    
                    // 1.2 saniye sonra geçmişi yeniden yükle (Admin cevabını çekmek için)
                    setTimeout(loadChatHistory, 1200);
                } catch (err) {
                    console.error(err);
                }
            }

            chatSendBtn.addEventListener('click', sendMessage);
            chatInput.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') {
                    sendMessage();
                }
            });
        });
    </script>

    <!-- Floating Chat Elements -->
    <button class="chat-trigger" id="chatTriggerBtn" title="Canlı Destek">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
    </button>

    <div class="chat-box" id="chatBoxContainer">
        <div class="chat-box-header">
            <h3>
                <span style="display:inline-block; width:10px; height:10px; background:#10b981; border-radius:50%;"></span>
                GM Canlı Destek
            </h3>
            <button class="chat-box-close" id="chatBoxCloseBtn">&times;</button>
        </div>
        <div class="chat-box-body" id="chatBoxBody"></div>
        <div class="chat-box-footer">
            <input type="text" id="chatInput" class="chat-input" placeholder="Mesajınızı yazın..." autocomplete="off">
            <button type="button" id="chatSendBtn" class="chat-send-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
            </button>
        </div>
    </div>

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <!-- Floating Coupon Ribbon -->
        <div class="coupon-ribbon" id="couponRibbon" onclick="openCouponModal()">
            <span class="coupon-ribbon-icon">🎁</span>
            <span class="coupon-ribbon-text">Sürpriz Kupon Kazan!</span>
        </div>

        <!-- Coupon Popup Modal -->
        <div class="coupon-modal-overlay" id="couponModalOverlay" onclick="closeCouponModalOnOverlay(event)">
            <div class="coupon-modal-card">
                <button class="coupon-modal-close" onclick="closeCouponModal()">&times;</button>
                <div class="coupon-modal-gift-icon">🎁</div>
                <h2 class="coupon-modal-title" id="couponModalTitle">Sürpriz İndirim Kuponu!</h2>
                <p class="coupon-modal-desc" id="couponModalDesc">Aşağıdaki karekodu telefonunuzun kamerasıyla okutarak indirim kodunuza ulaşabilirsiniz!</p>
                
                <div class="coupon-modal-qr-container" id="couponQrContainer">
                    <canvas id="couponQrCanvas"></canvas>
                    <div class="coupon-modal-loading" id="couponQrLoading">Kupon hazırlanıyor...</div>
                </div>
                
                <a id="couponDirectLink" href="#" target="_blank" style="display:none; font-size:0.85rem; color:var(--accent-teal); text-decoration:none; font-weight:600; margin-bottom:1.5rem;">Kodu sayfada gör (Test Linki) →</a>

                <!-- PC Revealed Success Section -->
                <div id="couponSuccessSection" style="display:none; margin: 0 auto 1.5rem; width: 100%; max-width: 280px;">
                    <div style="background: rgba(13, 148, 136, 0.05); border: 2px dashed var(--accent-teal); border-radius: 12px; padding: 1.25rem 1rem; margin-bottom: 1rem;">
                        <div id="pcCouponValue" style="font-size: 0.95rem; font-weight: 700; color: var(--accent-teal); margin-bottom: 0.25rem; text-transform: uppercase;"></div>
                        <div id="pcCouponCode" style="font-size: 1.8rem; font-weight: 800; color: #0f172a; letter-spacing: 1px; font-family: monospace;"></div>
                    </div>
                    <button class="btn btn-teal" onclick="copyPcCouponToClipboard()" style="width:100%; padding:0.6rem 1rem; font-size:0.85rem; border-radius:8px; font-weight:700;">Kodu Kopyala</button>
                </div>
                
                <p class="coupon-modal-footer">GM Travel keyifli seyahatler diler!</p>
            </div>
        </div>

        <!-- Qrious QR Code Generator Library -->
        <script src="https://cdnjs.cloudflare.com/ajax/libs/qrious/4.0.2/qrious.min.js"></script>
        <script>
            let qriousQr = null;
            let couponPollInterval = null;

            function openCouponModal() {
                const overlay = document.getElementById('couponModalOverlay');
                const canvas = document.getElementById('couponQrCanvas');
                const loading = document.getElementById('couponQrLoading');
                const directLink = document.getElementById('couponDirectLink');
                
                canvas.style.display = 'none';
                if (directLink) directLink.style.display = 'none';
                document.getElementById('couponSuccessSection').style.display = 'none';
                document.getElementById('couponQrContainer').style.display = 'block';
                document.getElementById('couponModalTitle').textContent = 'Sürpriz İndirim Kuponu!';
                document.getElementById('couponModalDesc').style.display = 'block';

                loading.style.display = 'block';
                loading.textContent = 'Kupon hazırlanıyor...';
                overlay.classList.add('active');

                if (couponPollInterval) {
                    clearInterval(couponPollInterval);
                    couponPollInterval = null;
                }

                fetch('/User/GetRandomCoupon')
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Kupon bulunamadı');
                        }
                        return response.json();
                    })
                    .then(data => {
                        const qrValue = data.revealUrl;
                        
                        if (qriousQr === null) {
                            qriousQr = new QRious({
                                element: canvas,
                                value: qrValue,
                                size: 180,
                                backgroundAlpha: 0,
                                foreground: '#0f172a'
                            });
                        } else {
                            qriousQr.value = qrValue;
                        }
                        
                        if (directLink) {
                            directLink.href = `/User/RevealCoupon?code=${encodeURIComponent(data.code)}`;
                            directLink.style.display = 'inline-block';
                        }
                        
                        loading.style.display = 'none';
                        canvas.style.display = 'block';

                        startCouponPolling(data.code, data.discountType, data.discountValue);
                    })
                    .catch(err => {
                        console.error(err);
                        loading.textContent = 'Kupon yüklenirken bir hata oluştu.';
                    });
            }

            function startCouponPolling(code, discountType, discountValue) {
                if (couponPollInterval) clearInterval(couponPollInterval);
                
                couponPollInterval = setInterval(() => {
                    fetch(`/User/CheckCouponStatus?code=${encodeURIComponent(code)}`)
                        .then(response => response.json())
                        .then(data => {
                            if (data.scanned) {
                                clearInterval(couponPollInterval);
                                couponPollInterval = null;
                                showScannedCoupon(code, discountType, discountValue);
                            }
                        })
                        .catch(err => console.error('Polling error:', err));
                }, 1500);
            }

            function showScannedCoupon(code, discountType, discountValue) {
                document.getElementById('couponModalTitle').textContent = 'Tebrikler! Kuponunuz Hazır! 🎉';
                document.getElementById('couponModalDesc').style.display = 'none';
                document.getElementById('couponQrContainer').style.display = 'none';
                if (document.getElementById('couponDirectLink')) {
                    document.getElementById('couponDirectLink').style.display = 'none';
                }

                const displayValue = discountType === 'Oransal' ? `%${discountValue}` : `${discountValue} TL`;
                document.getElementById('pcCouponValue').textContent = `${displayValue} İNDİRİM`;
                document.getElementById('pcCouponCode').textContent = code;
                document.getElementById('couponSuccessSection').style.display = 'block';
            }

            function copyPcCouponToClipboard() {
                const codeText = document.getElementById('pcCouponCode').textContent;
                navigator.clipboard.writeText(codeText).then(() => {
                    alert('Kupon kodu başarıyla kopyalandı!');
                }).catch(err => {
                    console.error('Kopyalama hatası:', err);
                });
            }

            function closeCouponModal() {
                if (couponPollInterval) {
                    clearInterval(couponPollInterval);
                    couponPollInterval = null;
                }
                document.getElementById('couponModalOverlay').classList.remove('active');
            }

            function closeCouponModalOnOverlay(event) {
                if (event.target === document.getElementById('couponModalOverlay')) {
                    closeCouponModal();
                }
            }
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
