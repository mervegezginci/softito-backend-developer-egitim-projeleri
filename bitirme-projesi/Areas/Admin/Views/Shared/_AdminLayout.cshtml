<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GM Travel Yönetici Paneli</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <script>
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'dark') {
            document.body.classList.add('dark-theme');
        }
    </script>

    <!-- Admin Navbar -->
    <nav class="navbar">
        <a href="/" class="nav-logo">GM <span>Travel</span></a>
        <div class="nav-actions">
            <!-- Global Admin Search Bar -->
            <input type="text" id="globalTableSearch" placeholder="Tabloda ara..." class="form-control" style="max-width: 200px; border-radius: 50px; padding: 0.45rem 1.2rem; border: 1px solid var(--border-color); background-color: var(--bg-secondary); color: var(--text-primary); font-size: 0.85rem;" />
            <!-- Light/Dark Mode Switcher -->
            <button class="theme-toggle-btn" id="themeToggleBtn" type="button" title="Tema Değiştir">
                <svg id="sunIcon" style="display:none;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
                <svg id="moonIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
            </button>
            <a href="/" class="btn btn-teal">Siteye Git</a>
            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                <button type="submit" class="btn btn-danger" style="padding:0.5rem 1.2rem; border-radius:50px;">Çıkış</button>
            </form>
        </div>
    </nav>

    <!-- Main Content Container with sidebar -->
    <div style="min-height: calc(100vh - 80px);">
        @RenderBody()
    </div>

    <!-- Theme toggler script -->
    <script>
        const themeToggleBtn = document.getElementById('themeToggleBtn');
        const sunIcon = document.getElementById('sunIcon');
        const moonIcon = document.getElementById('moonIcon');

        function updateIcons() {
            if (document.body.classList.contains('dark-theme')) {
                sunIcon.style.display = 'block';
                moonIcon.style.display = 'none';
            } else {
                sunIcon.style.display = 'none';
                moonIcon.style.display = 'block';
            }
        }

        updateIcons();

        themeToggleBtn.addEventListener('click', () => {
            document.body.classList.toggle('dark-theme');
            const theme = document.body.classList.contains('dark-theme') ? 'dark' : 'light';
            localStorage.setItem('theme', theme);
            updateIcons();
        });

        // Global Table Search Logic
        document.addEventListener('DOMContentLoaded', () => {
            const searchInput = document.getElementById('globalTableSearch');
            if (searchInput) {
                searchInput.addEventListener('input', function() {
                    const filter = this.value.toLowerCase();
                    const rows = document.querySelectorAll('table tbody tr');
                    rows.forEach(row => {
                        const text = row.textContent.toLowerCase();
                        // Tabloda veri yoksa o satırı filtreleme dışı bırak
                        if (row.cells.length > 1) {
                            row.style.display = text.includes(filter) ? '' : 'none';
                        }
                    });
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
