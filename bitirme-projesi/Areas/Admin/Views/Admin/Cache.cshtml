@{
    ViewData["Title"] = "Önbellek Yönetimi";
    var cachedKeys = ViewBag.CachedKeys as IEnumerable<dynamic>;
}

<div class="dashboard-grid">
    <!-- Admin Sidebar -->
    @await Html.PartialAsync("_AdminSidebar")

    <!-- Main Content Panel -->
    <main>
        <div class="glass-card">
            <div class="dashboard-header">
                <h2>Önbellek & Sunucu Ayarları (Caching)</h2>
            </div>

            <div style="display:flex; flex-direction:column; gap:2rem; margin-top: 1.5rem;">
                <div>
                    <h3>Veri Önbellekleme (In-Memory Cache)</h3>
                    <p style="color:var(--text-secondary); font-size:0.9rem; margin-bottom:1.5rem; margin-top:0.4rem;">
                        Çok sık ziyaret edilen API rotalarının yanıtları sunucu hafızasında tutulur. Bu, veritabanı sorgularını azaltır ve hızı 10 katına çıkarır.
                    </p>
                    
                    <div style="background:rgba(255,255,255,0.03); border:1px solid var(--border-color); border-radius:8px; padding:1.2rem; margin-bottom:2rem; font-family:monospace; font-size:0.9rem; line-height:1.8;">
                        <p><strong>Önbellek İzleme:</strong></p>
                        <ul style="padding-left:1.5rem; margin-top:0.5rem; display:flex; flex-direction:column; gap:0.4rem;">
                            @if (cachedKeys != null)
                            {
                                foreach (dynamic item in cachedKeys)
                                {
                                    <li>
                                        Anahtar: <strong style="color:var(--accent-secondary);">@item.Key</strong> | 
                                        Durum: @(item.IsCached ? "Önbellekte Var" : "Boş") | 
                                        Geçerlilik: @item.Expiry
                                    </li>
                                }
                            }
                        </ul>
                    </div>

                    <form asp-action="ClearSystemCache" method="post">
                        <button type="submit" class="btn btn-danger">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                            Önbelleği Temizle (Invalidate Cache)
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </main>
</div>
