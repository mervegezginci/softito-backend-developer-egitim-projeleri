@model IEnumerable<seyahat_projesi.Model.Review>
@{
    ViewData["Title"] = "Yorum Yönetimi";
}

<div class="dashboard-grid">
    <!-- Admin Sidebar -->
    @await Html.PartialAsync("_AdminSidebar")

    <!-- Main Content Panel -->
    <main>
        <div class="glass-card">
            <div class="dashboard-header">
                <h2>Üye Değerlendirmeleri ve Yorumları Yönet</h2>
            </div>

            <div class="table-wrapper" style="margin-top: 1.5rem;">
                <table>
                    <thead>
                        <tr>
                            <th>Yorum ID</th>
                            <th>Kullanıcı</th>
                            <th>Seyahat Rotası / Tur</th>
                            <th>Puan</th>
                            <th>Yorum İçeriği</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="6" style="text-align: center; color: var(--text-muted); padding:2rem;">Kayıtlı yorum bulunmamaktadır.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var r in Model)
                            {
                                <tr>
                                    <td>#@r.Id</td>
                                    <td>
                                        <strong>@r.User?.Name</strong><br/>
                                        <small style="color:var(--text-secondary);">@r.User?.Email</small>
                                    </td>
                                    <td>@r.Tour?.Title</td>
                                    <td style="color: var(--warning); font-weight: bold;">
                                        @string.Concat(Enumerable.Repeat("★", r.Rating))
                                    </td>
                                    <td style="max-width: 300px; white-space: normal; color: var(--text-secondary);">@r.Comment</td>
                                    <td>
                                        <button class="btn btn-danger btn-delete-review" data-id="@r.Id" style="padding:0.4rem 0.8rem; font-size:0.8rem;">Sil</button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Delete review
            document.querySelectorAll('.btn-delete-review').forEach(btn => {
                btn.addEventListener('click', async () => {
                    if (confirm('Bu yorumu sistemden tamamen silmek istediğinize emin misiniz?')) {
                        const id = btn.getAttribute('data-id');
                        try {
                            const res = await fetch('/Admin/DeleteReview/' + id, { method: 'POST' });
                            const result = await res.json();
                            if (result.success) {
                                window.location.reload();
                            } else {
                                alert(result.message);
                            }
                        } catch (err) {
                            console.error(err);
                        }
                    }
                });
            });
        });
    </script>
}
