@model IEnumerable<seyahat_projesi.Model.ContactMessage>
@{
    ViewData["Title"] = "Mesaj Yönetimi";
}

<div class="dashboard-grid">
    <!-- Admin Sidebar -->
    @await Html.PartialAsync("_AdminSidebar")

    <!-- Main Content Panel -->
    <main>
        <div class="glass-card">
            <div class="dashboard-header">
                <h2>İletişim Formu Mesajlarını Yönet</h2>
            </div>

            <div class="table-wrapper" style="margin-top: 1.5rem;">
                <table>
                    <thead>
                        <tr>
                            <th>Mesaj ID</th>
                            <th>Ad Soyad</th>
                            <th>E-posta</th>
                            <th>Konu</th>
                            <th>Mesaj Metni</th>
                            <th>Durum</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="7" style="text-align: center; color: var(--text-muted); padding:2rem;">Gelen mesaj bulunmamaktadır.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var m in Model)
                            {
                                 <tr>
                                     <td>#@m.Id</td>
                                     <td style="font-weight: 600;">@m.Name</td>
                                     <td>@m.Email</td>
                                     <td style="font-weight: 600;">@m.Subject</td>
                                     <td style="max-width: 250px; text-overflow: ellipsis; overflow: hidden; white-space: nowrap; color: var(--text-secondary); font-size: 0.85rem;">@m.Message</td>
                                     <td>
                                         @if (m.IsRead)
                                         {
                                             <span class="status-badge status-approved">Okundu</span>
                                         }
                                         else
                                         {
                                             <span class="status-badge status-cancelled" style="background: rgba(239, 68, 68, 0.15); color: #fca5a5;">Yeni / Okunmadı</span>
                                         }
                                     </td>
                                     <td>
                                         <div style="display:flex; gap:0.4rem;">
                                             <button class="btn btn-teal btn-view-message" 
                                                     data-id="@m.Id" 
                                                     data-name="@m.Name" 
                                                     data-email="@m.Email" 
                                                     data-subject="@m.Subject" 
                                                     data-message="@m.Message" 
                                                     data-read="@m.IsRead.ToString().ToLower()"
                                                     style="padding:0.4rem 0.6rem; font-size:0.8rem;">
                                                 Oku
                                             </button>
                                             @if (!m.IsRead)
                                             {
                                                 <button class="btn btn-secondary btn-status-message" data-id="@m.Id" data-status="true" style="padding:0.4rem; font-size:0.8rem;">Okundu Yap</button>
                                             }
                                             else
                                             {
                                                 <button class="btn btn-secondary btn-status-message" data-id="@m.Id" data-status="false" style="padding:0.4rem; font-size:0.8rem;">Okunmadı Yap</button>
                                             }
                                             <button class="btn btn-danger btn-delete-message" data-id="@m.Id" style="padding:0.4rem; font-size:0.8rem;">Sil</button>
                                         </div>
                                     </td>
                                 </tr>
                             }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>

<!-- Message Detail Modal -->
<div id="messageModal" class="modal-backdrop" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 10000; align-items: center; justify-content: center;">
    <div class="glass-card" style="width: 500px; max-width: 90%; padding: 2rem; border-radius: 16px; position: relative; background: var(--card-bg); border: 1px solid var(--border-color); box-shadow: var(--card-hover-shadow);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem;">
            <h3 id="modalSubject" style="font-weight: 700; margin: 0; font-size: 1.2rem; color: var(--text-primary);">Konu Detayı</h3>
            <button id="closeModalBtn" style="background: none; border: none; font-size: 1.8rem; cursor: pointer; color: var(--text-muted); line-height: 1;">&times;</button>
        </div>
        <div style="display: flex; flex-direction: column; gap: 0.85rem; font-size: 0.9rem; color: var(--text-secondary);">
            <p><strong>Gönderen:</strong> <span id="modalName" style="color: var(--text-primary); font-weight: 600;"></span></p>
            <p><strong>E-posta:</strong> <span id="modalEmail" style="color: var(--accent-teal);"></span></p>
            <div style="border-top: 1px solid var(--border-color); padding-top: 1rem; margin-top: 0.5rem;">
                <strong>Mesaj:</strong>
                <p id="modalBody" style="margin-top: 0.5rem; background: var(--bg-secondary); padding: 1rem; border-radius: 8px; line-height: 1.5; color: var(--text-primary); max-height: 200px; overflow-y: auto; white-space: pre-wrap;"></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Update message status
            document.querySelectorAll('.btn-status-message').forEach(btn => {
                btn.addEventListener('click', async () => {
                    const id = btn.getAttribute('data-id');
                    const isRead = btn.getAttribute('data-status') === 'true';

                    const formData = new FormData();
                    formData.append('id', id);
                    formData.append('isRead', isRead);

                    try {
                        const res = await fetch('/Admin/UpdateMessageStatus', {
                            method: 'POST',
                            body: formData
                        });
                        const result = await res.json();
                        if (result.success) {
                            window.location.reload();
                        } else {
                            alert(result.message);
                        }
                    } catch (err) {
                        console.error(err);
                    }
                });
            });

            // View message popup
            const messageModal = document.getElementById('messageModal');
            const closeModalBtn = document.getElementById('closeModalBtn');
            const modalSubject = document.getElementById('modalSubject');
            const modalName = document.getElementById('modalName');
            const modalEmail = document.getElementById('modalEmail');
            const modalBody = document.getElementById('modalBody');

            document.querySelectorAll('.btn-view-message').forEach(btn => {
                btn.addEventListener('click', async () => {
                    const id = btn.getAttribute('data-id');
                    const name = btn.getAttribute('data-name');
                    const email = btn.getAttribute('data-email');
                    const subject = btn.getAttribute('data-subject');
                    const messageText = btn.getAttribute('data-message');
                    const isRead = btn.getAttribute('data-read') === 'true';

                    modalSubject.textContent = subject;
                    modalName.textContent = name;
                    modalEmail.textContent = email;
                    modalBody.textContent = messageText;

                    messageModal.style.display = 'flex';

                    // If message is unread, automatically mark it as read in background
                    if (!isRead) {
                        const formData = new FormData();
                        formData.append('id', id);
                        formData.append('isRead', true);
                        try {
                            const res = await fetch('/Admin/UpdateMessageStatus', {
                                method: 'POST',
                                body: formData
                            });
                            const result = await res.json();
                            if (result.success) {
                                btn.setAttribute('data-read', 'true');
                                closeModalBtn.setAttribute('data-reload', 'true');
                            }
                        } catch (err) {
                            console.error(err);
                        }
                    }
                });
            });

            closeModalBtn.addEventListener('click', () => {
                messageModal.style.display = 'none';
                if (closeModalBtn.getAttribute('data-reload') === 'true') {
                    window.location.reload();
                }
            });

            messageModal.addEventListener('click', (e) => {
                if (e.target === messageModal) {
                    messageModal.style.display = 'none';
                    if (closeModalBtn.getAttribute('data-reload') === 'true') {
                        window.location.reload();
                    }
                }
            });

            // Delete message
            document.querySelectorAll('.btn-delete-message').forEach(btn => {
                btn.addEventListener('click', async () => {
                    if (confirm('Bu mesajı silmek istediğinize emin misiniz?')) {
                        const id = btn.getAttribute('data-id');
                        try {
                            const res = await fetch('/Admin/DeleteMessage/' + id, { method: 'POST' });
                            const result = await res.json();
                            if (result.success) {
                                window.location.reload();
                            } else {
                                alert(result.message);
                            }
                        } catch (err) {
                            console.error(err);
                        }
                    }
                });
            });
        });
    </script>
}
