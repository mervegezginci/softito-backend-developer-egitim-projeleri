@model seyahat_projesi.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Rezervasyonlarım";
}

<div class="glass-card" style="padding: 2.5rem; border-radius: 16px;">
    <div class="dashboard-header" style="border-bottom: 1px solid var(--border-color); padding-bottom: 1rem; margin-bottom: 1.5rem;">
        <h2 style="font-weight: 800; color: var(--text-primary); margin: 0;">Rezervasyonlarım</h2>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" style="display:block; margin-bottom:1.5rem;">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Rez ID</th>
                    <th>Gezilecek Yer / Rota</th>
                    <th>Seyahat Tarihi</th>
                    <th>Kişi</th>
                    <th>Toplam Tutar</th>
                    <th>Durum</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody id="bookingsList">
                @if (Model.Bookings == null || !Model.Bookings.Any())
                {
                    <tr>
                        <td colspan="7" style="text-align: center; color: var(--text-muted); padding:2rem;">Henüz bir rezervasyon yapmadınız.</td>
                    </tr>
                }
                else
                {
                    foreach (var b in Model.Bookings)
                    {
                        <tr>
                            <td>#@b.Id</td>
                            <td>
                                <div style="font-weight: 600; color: var(--text-primary);">@b.Tour?.Title</div>
                                <div style="font-size: 0.8rem; color: var(--text-muted);">📍 @b.Tour?.Location</div>
                            </td>
                            <td>
                                <div style="color: var(--text-primary);">@b.Tour?.StartDate.ToString("dd.MM.yyyy")</div>
                                <div style="font-size: 0.8rem; color: var(--text-muted);">@b.Tour?.DurationDays Gün</div>
                            </td>
                            <td>@b.GuestsCount Kişi</td>
                            <td style="font-weight: 700; color: var(--text-primary);">@b.TotalPrice.ToString("N0") TL</td>
                            <td>
                                @if (b.Status == "approved")
                                {
                                    <span style="background: rgba(13,148,136,0.1); color: var(--accent-teal); padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.75rem; font-weight: 700;">Onaylandı</span>
                                }
                                else if (b.Status == "cancelled")
                                {
                                    <span style="background: rgba(239,68,68,0.1); color: #ef4444; padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.75rem; font-weight: 700;">İptal Edildi</span>
                                }
                                else
                                {
                                    <span style="background: rgba(245,158,11,0.1); color: #f59e0b; padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.75rem; font-weight: 700;">Onay Bekliyor</span>
                                }
                            </td>
                            <td style="display:flex; gap:0.5rem; align-items:center;">
                                <a href="/Export/Invoice/@b.Id" class="btn btn-teal" style="padding:0.4rem 0.8rem; font-size:0.8rem; display:inline-flex; align-items:center; gap:0.25rem;">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                                    Bilet/PDF
                                </a>
                                @if (b.Status != "cancelled")
                                {
                                    <button class="btn btn-danger btn-cancel" data-id="@b.Id" style="padding:0.4rem 0.8rem; font-size:0.8rem;">İptal Et</button>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Booking cancellation listener
            document.querySelectorAll('.btn-cancel').forEach(btn => {
                btn.addEventListener('click', async (e) => {
                    if (confirm('Bu rezervasyonu iptal etmek istediğinize emin misiniz?')) {
                        const id = e.target.getAttribute('data-id');
                        try {
                            const res = await fetch('/User/Cancel/' + id, { method: 'POST' });
                            const data = await res.json();
                            if (data.success) {
                                alert(data.message);
                                window.location.reload();
                            } else {
                                alert(data.message || 'İptal başarısız oldu.');
                            }
                        } catch (err) {
                            alert('Hata: İptal işlemi gerçekleştirilemedi.');
                            console.error(err);
                        }
                    }
                });
            });
        });
    </script>
}
