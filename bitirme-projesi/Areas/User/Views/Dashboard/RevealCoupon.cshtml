@model seyahat_projesi.Model.Coupon
@{
    Layout = null;
    string displayValue = Model.DiscountType == "percentage" ? $"%{Model.DiscountValue}" : $"{Model.DiscountValue:N0} TL";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tebrikler! İndirim Kuponunuz Hazır - GM Travel</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-gradient: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
            --card-bg: rgba(30, 41, 59, 0.7);
            --border-color: rgba(255, 255, 255, 0.1);
            --accent-teal: #0d9488;
            --accent-glow: rgba(13, 148, 136, 0.4);
            --text-primary: #f8fafc;
            --text-secondary: #cbd5e1;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: var(--bg-gradient);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
            overflow-x: hidden;
        }

        /* Ambient glowing backgrounds */
        .glow-circle {
            position: absolute;
            width: 300px;
            height: 300px;
            border-radius: 50%;
            background: var(--accent-teal);
            filter: blur(120px);
            opacity: 0.3;
            z-index: 1;
        }
        .glow-1 { top: 10%; left: 10%; }
        .glow-2 { bottom: 10%; right: 10%; }

        .container {
            position: relative;
            z-index: 2;
            width: 100%;
            max-width: 480px;
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--border-color);
            border-radius: 24px;
            padding: 2.5rem 2rem;
            text-align: center;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
            animation: fadeInScale 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }

        @@keyframes fadeInScale {
            0% { opacity: 0; transform: scale(0.9) translateY(20px); }
            100% { opacity: 1; transform: scale(1) translateY(0); }
        }

        .gift-icon-wrapper {
            width: 80px;
            height: 80px;
            background: rgba(13, 148, 136, 0.15);
            border: 1px solid rgba(13, 148, 136, 0.3);
            color: var(--accent-teal);
            font-size: 2.5rem;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            box-shadow: 0 0 20px var(--accent-glow);
            animation: pulseGlow 2s infinite ease-in-out;
        }

        @@keyframes pulseGlow {
            0%, 100% { transform: scale(1); box-shadow: 0 0 20px var(--accent-glow); }
            50% { transform: scale(1.05); box-shadow: 0 0 35px rgba(13, 148, 136, 0.6); }
        }

        h1 {
            font-size: 1.8rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            background: linear-gradient(135deg, #fff 30%, var(--accent-teal) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .subtitle {
            font-size: 0.95rem;
            color: var(--text-secondary);
            margin-bottom: 2rem;
        }

        .coupon-box {
            background: rgba(15, 23, 42, 0.6);
            border: 2px dashed rgba(13, 148, 136, 0.5);
            border-radius: 16px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            position: relative;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .coupon-box:hover {
            border-color: var(--accent-teal);
            background: rgba(15, 23, 42, 0.8);
            transform: translateY(-2px);
        }

        .coupon-code {
            font-size: 2.2rem;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: 2px;
            margin-bottom: 0.5rem;
        }

        .coupon-value {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--accent-teal);
            margin-bottom: 0.25rem;
        }

        .coupon-expiry {
            font-size: 0.8rem;
            color: #94a3b8;
        }

        .copy-hint {
            font-size: 0.85rem;
            color: var(--accent-teal);
            font-weight: 600;
            margin-top: 0.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.25rem;
            opacity: 0.8;
        }

        .btn-copy {
            width: 100%;
            background: var(--accent-teal);
            color: white;
            border: none;
            padding: 1rem 1.5rem;
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 4px 12px var(--accent-glow);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }
        .btn-copy:hover {
            background: #0f766e;
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(13, 148, 136, 0.5);
        }
        .btn-copy:active {
            transform: translateY(0);
        }

        /* Success Alert styling */
        .toast {
            position: fixed;
            bottom: -60px;
            left: 50%;
            transform: translateX(-50%);
            background: #10b981;
            color: white;
            padding: 0.75rem 1.5rem;
            border-radius: 50px;
            font-size: 0.9rem;
            font-weight: 700;
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
            z-index: 100;
            transition: bottom 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .toast.show {
            bottom: 30px;
        }

        .logo-footer {
            margin-top: 2rem;
            font-size: 0.85rem;
            color: #64748b;
            font-weight: 600;
        }
        .logo-footer span {
            color: var(--accent-teal);
        }
    </style>
</head>
<body>
    <div class="glow-circle glow-1"></div>
    <div class="glow-circle glow-2"></div>

    <div class="container">
        <div class="gift-icon-wrapper">
            🎁
        </div>
        <h1>Tebrikler! 🎉</h1>
        <p class="subtitle">İndirim kuponunuz başarıyla doğrulandı ve hazırlandı.</p>

        <div class="coupon-box" onclick="copyToClipboard()" title="Kopyalamak için tıklayın">
            <div class="coupon-value">@displayValue İNDİRİM</div>
            <div class="coupon-code" id="couponCode">@Model.Code</div>
            <div class="coupon-expiry">Son Geçerlilik: @Model.ExpiryDate.ToString("dd.MM.yyyy")</div>
            <div class="copy-hint">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                Kopyalamak için dokunun
            </div>
        </div>

        <button class="btn-copy" onclick="copyToClipboard()">
            Kupon Kodunu Kopyala
        </button>

        <div class="logo-footer">
            GM <span>Travel</span> • Dünyayı Keşfet
        </div>
    </div>

    <div class="toast" id="copyToast">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
        Kupon kodu başarıyla kopyalandı!
    </div>

    <script>
        function copyToClipboard() {
            const codeText = document.getElementById('couponCode').textContent;
            navigator.clipboard.writeText(codeText).then(() => {
                const toast = document.getElementById('copyToast');
                toast.classList.add('show');
                setTimeout(() => {
                    toast.classList.remove('show');
                }, 2500);
            }).catch(err => {
                console.error('Kopyalama başarısız: ', err);
            });
        }
    </script>
</body>
</html>
