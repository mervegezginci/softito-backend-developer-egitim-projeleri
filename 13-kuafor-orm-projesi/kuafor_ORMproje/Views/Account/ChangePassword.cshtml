@using kuafor_ORMproje.ViewModels
@model ChangePasswordViewModel

@{
    ViewData["Title"] = "Şifre Değiştir";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}


<div class="account-container">
    <div class="account-box">

        <h2>Şifre Değiştir</h2>

        <form asp-action="ChangePassword" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-4">
                <label asp-for="Email" class="form-label">E-posta Adresi</label>
                <input asp-for="Email" class="form-control readonly-input" readonly />
            </div>

            <div class="mb-4">
                <label asp-for="NewPassword" class="form-label">Yeni Şifre</label>
                <input asp-for="NewPassword"
                       class="form-control"
                       placeholder="Yeni şifrenizi giriniz" />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmNewPassword" class="form-label">Şifre Tekrar</label>
                <input asp-for="ConfirmNewPassword"
                       class="form-control"
                       placeholder="Yeni şifrenizi tekrar giriniz" />
                <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="change-btn">
                Şifreyi Güncelle
            </button>

            <div class="text-center mt-4">
                <a asp-controller="Account"
                   asp-action="VerifyEmail"
                   class="back-link">
                    ← Geri Dön
                </a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}