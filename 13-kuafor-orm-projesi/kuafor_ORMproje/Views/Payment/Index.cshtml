@model IEnumerable<kuafor_ORMproje.Model.Payment>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Ödeme Yönetimi";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Ödeme Kayıtları</h5>
        <div class="d-flex gap-2">
            <button onclick="exportToExcel('paymentTable', 'odemeler')" class="btn btn-outline-success btn-sm">
                <i class="bx bx-file me-1"></i> Excel
            </button>
            <button onclick="exportToPdf('paymentTable', 'Odeme Raporu')" class="btn btn-outline-danger btn-sm">
                <i class="bx bxs-file-pdf me-1"></i> PDF
            </button>
            <a asp-action="Create" class="btn btn-primary btn-sm">
                <i class="bx bx-plus me-1"></i> Yeni Ödeme Al
            </a>
        </div>
    </div>
    <div class="table-responsive text-nowrap">
        <table class="table table-hover" id="paymentTable">
            <thead>
                <tr>
                    <th>Müşteri</th>
                    <th>Hizmet</th>
                    <th>Tutar</th>
                    <th>Ödeme Yöntemi</th>
                    <th>Ödeme Tarihi</th>
                    <th>Durum</th>
                    <th style="width: 150px;">İşlemler</th>
                </tr>
            </thead>
            <tbody class="table-border-bottom-0">
                @if (Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.Appointment?.Customer?.FullName</strong></td>
                            <td>@item.Appointment?.Service?.ServiceName</td>
                            <td class="text-success fw-bold">@item.Amount.ToString("C2")</td>
                            <td>
                                @if (item.PaymentMethod == "Kredi Kartı")
                                {
                                    <span><i class="bx bx-credit-card me-1"></i> Kredi Kartı</span>
                                }
                                else if (item.PaymentMethod == "Nakit")
                                {
                                    <span><i class="bx bx-money me-1"></i> Nakit</span>
                                }
                                else
                                {
                                    <span><i class="bx bx-wallet me-1"></i> @item.PaymentMethod</span>
                                }
                            </td>
                            <td>@item.PaymentDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                @if (item.PaymentStatus)
                                {
                                    <span class="badge bg-label-success">Ödendi</span>
                                }
                                else
                                {
                                    <span class="badge bg-label-danger">Bekliyor</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm" title="Düzenle">
                                        <i class="bx bx-edit-alt"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bu ödeme kaydını silmek istediğinizden emin misiniz?');" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm" title="Sil">
                                            <i class="bx bx-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            Kayıtlı ödeme bulunamadı.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
