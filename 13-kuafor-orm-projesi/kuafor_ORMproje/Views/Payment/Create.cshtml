@model kuafor_ORMproje.Model.Payment

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Ödeme Al";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Yeni Ödeme Kaydı</h5>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="bx bx-arrow-back me-1"></i> Listeye Dön
                </a>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="AppointmentId">Randevu</label>
                        <select asp-for="AppointmentId" class="form-select" id="appointmentSelect" required>
                            <option value="">-- Ödeme Yapılacak Randevu --</option>
                            @if (ViewBag.UnpaidAppointments != null)
                            {
                                foreach (var app in ViewBag.UnpaidAppointments)
                                {
                                    <option value="@app.Id" data-price="@app.Price">@app.DisplayText</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="AppointmentId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="Amount">Tutar (TL)</label>
                        <div class="input-group input-group-merge">
                            <span class="input-group-text">₺</span>
                            <input asp-for="Amount" type="number" step="0.01" class="form-control" id="amountInput" placeholder="250.00" required />
                        </div>
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="PaymentMethod">Ödeme Yöntemi</label>
                        <select asp-for="PaymentMethod" class="form-select" required>
                            <option value="Kredi Kartı">Kredi Kartı</option>
                            <option value="Nakit">Nakit</option>
                            <option value="Havale / EFT">Havale / EFT</option>
                        </select>
                        <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="PaymentStatus" class="form-check-input" type="checkbox" checked />
                            <label class="form-check-label" asp-for="PaymentStatus">Ödeme Tamamlandı mı?</label>
                        </div>
                        <span asp-validation-for="PaymentStatus" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <button type="submit" class="btn btn-primary">Kaydet</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        document.getElementById('appointmentSelect').addEventListener('change', function () {
            var selectedOption = this.options[this.selectedIndex];
            var price = selectedOption.getAttribute('data-price');
            var amountInput = document.getElementById('amountInput');
            if (price) {
                var parsedPrice = parseFloat(price.toString().replace(',', '.'));
                amountInput.value = parsedPrice.toFixed(2);
            } else {
                amountInput.value = '';
            }
        });
    </script>
}
