@model IEnumerable<kuafor_ORMproje.Model.Appointment>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Randevu Yönetimi";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Randevu Listesi</h5>
        <div class="d-flex gap-2">
            <button onclick="exportToExcel('appointmentTable', 'randevular')" class="btn btn-outline-success btn-sm">
                <i class="bx bx-file me-1"></i> Excel
            </button>
            <button onclick="exportToPdf('appointmentTable', 'Randevu Listesi')" class="btn btn-outline-danger btn-sm">
                <i class="bx bxs-file-pdf me-1"></i> PDF
            </button>
            <a asp-action="Create" class="btn btn-primary btn-sm">
                <i class="bx bx-plus me-1"></i> Yeni Randevu Al
            </a>
        </div>
    </div>
    <div class="table-responsive text-nowrap">
        <table class="table table-hover" id="appointmentTable">
            <thead>
                <tr>
                    <th>Müşteri</th>
                    <th>Çalışan</th>
                    <th>Hizmet</th>
                    <th>Tarih</th>
                    <th>Saat</th>
                    <th>Durum</th>
                    <th>Notlar</th>
                    <th style="width: 150px;">İşlemler</th>
                </tr>
            </thead>
            <tbody class="table-border-bottom-0">
                @if (Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.Customer?.FullName</strong></td>
                            <td>@item.Employee?.FullName</td>
                            <td>@item.Service?.ServiceName</td>
                            <td>@item.AppointmentDate.ToString("dd.MM.yyyy")</td>
                            <td>@item.AppointmentTime.ToString(@"hh\:mm")</td>
                            <td>
                                @if (item.Status == "Onaylandı" || item.Status == "Tamamlandı")
                                {
                                    <span class="badge bg-label-success">@item.Status</span>
                                }
                                else if (item.Status == "Bekliyor")
                                {
                                    <span class="badge bg-label-warning">@item.Status</span>
                                }
                                else
                                {
                                    <span class="badge bg-label-danger">@item.Status</span>
                                }
                            </td>
                            <td style="max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@item.Note">@item.Note</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm" title="Düzenle">
                                        <i class="bx bx-edit-alt"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bu randevuyu silmek istediğinizden emin misiniz?');" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm" title="Sil">
                                            <i class="bx bx-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            Kayıtlı randevu bulunamadı.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
