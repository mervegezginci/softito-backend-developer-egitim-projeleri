@model kuafor_ORMproje.Model.Appointment

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Randevu Al";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Yeni Randevu Kaydı</h5>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="bx bx-arrow-back me-1"></i> Listeye Dön
                </a>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="CustomerId">Müşteri</label>
                        <select asp-for="CustomerId" class="form-select" asp-items="ViewBag.CustomerId" required>
                            <option value="">-- Müşteri Seçin --</option>
                        </select>
                        <span asp-validation-for="CustomerId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="EmployeeId">Çalışan Uzman</label>
                        <select asp-for="EmployeeId" class="form-select" asp-items="ViewBag.EmployeeId" required>
                            <option value="">-- Uzman Seçin --</option>
                        </select>
                        <span asp-validation-for="EmployeeId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="ServiceId">Hizmet / İşlem</label>
                        <select asp-for="ServiceId" class="form-select" asp-items="ViewBag.ServiceId" required>
                            <option value="">-- Yapılacak İşlem --</option>
                        </select>
                        <span asp-validation-for="ServiceId" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label" asp-for="AppointmentDate">Tarih</label>
                            <input asp-for="AppointmentDate" type="date" class="form-control" required value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="AppointmentDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label" asp-for="AppointmentTime">Saat</label>
                            <input asp-for="AppointmentTime" type="time" class="form-control" required value="09:00" />
                            <span asp-validation-for="AppointmentTime" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="Status">Randevu Durumu</label>
                        <select asp-for="Status" class="form-select">
                            <option value="Bekliyor">Bekliyor</option>
                            <option value="Onaylandı">Onaylandı</option>
                            <option value="Tamamlandı">Tamamlandı</option>
                            <option value="İptal Edildi">İptal Edildi</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label" asp-for="Note">Notlar</label>
                        <textarea asp-for="Note" class="form-control" style="height: 100px; resize: none;" placeholder="İsteğe bağlı not ekleyebilirsiniz..."></textarea>
                        <span asp-validation-for="Note" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <button type="submit" class="btn btn-primary">Kaydet</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
