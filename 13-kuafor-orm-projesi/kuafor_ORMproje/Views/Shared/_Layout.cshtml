<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>Güzellik Salonu</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="" name="keywords">
    <meta content="" name="description">

    <!-- Favicon -->
    <link href="img/favicon.ico" rel="icon">

    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script&family=Playfair+Display:wght@500&family=Work+Sans&display=swap"
          rel="stylesheet">

    <!-- Icon Font Stylesheet -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Libraries Stylesheet -->
    <link href="~/salone-1.0.0/lib/animate/animate.min.css" rel="stylesheet">
    <link href="~/salone-1.0.0/lib/lightbox/css/lightbox.min.css" rel="stylesheet">
    <link href="~/salone-1.0.0/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">

    <!-- Customized Bootstrap Stylesheet -->
    <link href="~/salone-1.0.0/css/bootstrap.min.css" rel="stylesheet">

    <!-- Template Stylesheet -->
    <link href="~/salone-1.0.0/css/style.css" rel="stylesheet">
</head>

<body>
    <!-- Spinner Start -->
    <div id="spinner"
         class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-grow text-primary" style="width: 3rem; height: 3rem;" role="status">
            <span class="sr-only">Yükleniyor...</span>
        </div>
    </div>
    <!-- Spinner End -->
    <!-- Navbar Start -->
    <div class="container-fluid bg-light sticky-top p-0">
        <nav class="navbar navbar-expand-lg navbar-light p-0">
            <a href="/" class="navbar-brand bg-primary py-4 px-5 me-0">
                <h1 class="mb-0"><i class="bi bi-scissors"></i>Salone</h1>
            </a>
            <button type="button" class="navbar-toggler me-4" data-bs-toggle="collapse"
                    data-bs-target="#navbarCollapse">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse p-3" id="navbarCollapse">
                <div class="navbar-nav mx-auto">
                    <a href="#anasayfa" class="nav-item nav-link active">Anasayfa</a>

                    <a href="#hakkimizda" class="nav-item nav-link">Hakkımızda</a>

                    <a href="#hizmetler" class="nav-item nav-link">Hizmetler</a>

                    <a href="#fiyatlar" class="nav-item nav-link">Fiyatlar</a>

                    <a href="#ekibimiz" class="nav-item nav-link">Ekibimiz</a>

                    <a href="#iletisim" class="nav-item nav-link">İletişim</a>


                </div>
                <div class="d-flex">
                    <a class="btn btn-primary btn-sm-square me-3" href=""><i class="fab fa-facebook-f"></i></a>
                    <a class="btn btn-primary btn-sm-square me-3" href=""><i class="fab fa-instagram"></i></a>
                    <a class="btn btn-primary btn-sm-square" href=""><i class="fab fa-linkedin-in"></i></a>
                </div>

                <div class="navbar-nav mx-auto">
                    <a href="/Account/Login" class="nav-item nav-link">Giriş Yap</a>
                    <a href="/Account/Register" class="nav-item nav-link">Kayıt Ol</a>
                </div>

            </div>
        </nav>
    </div>
    <!-- Navbar End -->
    <!-- Hero Start -->
    <div id="anasayfa" class="container-fluid p-0 hero-header bg-light mb-5">
        <div class="container p-0">
            <div class="row g-0 align-items-center">
                <div class="col-lg-6 hero-header-text py-5">
                    <div class="py-5 px-3 ps-lg-0">
                        <h1 class="font-dancing-script text-primary animated slideInLeft">Hoş Geldiniz</h1>
                        <h1 class="display-1 mb-4 animated slideInLeft">Profesyonel Güzellik ve Kuaför Hizmetleri</h1>
                        <div class="row g-4 animated slideInLeft">
                            <div class="col-md-6">
                                <div class="d-flex align-items-center">
                                    <div class="btn-square btn btn-primary flex-shrink-0">
                                        <i class="fa fa-phone text-dark"></i>
                                    </div>
                                    <div class="px-3">
                                        <h5 class="text-primary mb-0">Bizi arayın</h5>
                                        <p class="fs-5 text-dark mb-0">+90 (555) 123 45 67</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex align-items-center">
                                    <div class="btn-square btn btn-primary flex-shrink-0">
                                        <i class="fa fa-envelope text-dark"></i>
                                    </div>
                                    <div class="px-3">
                                        <h5 class="text-primary mb-0">Bize E-posta Gönderin</h5>
                                        <p class="fs-5 text-dark mb-0">info@guzelliksalonu.com</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="owl-carousel header-carousel animated fadeIn">
                        <img class="img-fluid" src="~/salone-1.0.0/img/hero-slider-1.jpg" alt="">
                        <img class="img-fluid" src="~/salone-1.0.0/img/hero-slider-2.jpg" alt="">
                        <img class="img-fluid" src="~/salone-1.0.0/img/hero-slider-3.jpg" alt="">
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Hero End -->
    <div class="container mt-3">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
    </div>

    @RenderBody()


    <!-- Footer Start -->
    <div class="container-fluid footer position-relative bg-dark text-white-50 py-5 wow fadeIn" data-wow-delay="0.2s">
        <div id="iletisim" class="container-fluid py-5">
            <div class="row g-5">
                <div class="col-lg-6 pe-lg-5">
                    <a href="/" class="navbar-brand">
                        <h1 class="display-5 text-primary mb-0"><i class="bi bi-scissors"></i>Salone</h1>
                    </a>
                    <p>
                        Profesyonel ekibimiz ile saç kesimi, saç boyama, cilt bakımı ve kişisel bakım hizmetlerini en kaliteli ürünlerle sunuyoruz. Online randevu sistemi sayesinde dilediğiniz gün ve saatte kolayca randevu oluşturabilirsiniz.
                    </p>
                    <p class="mb-2"><i class="fa fa-map-marker-alt me-2"></i>Sakarya / Türkiyes</p>
                    <p class="mb-2"><i class="fa fa-phone-alt me-2"></i>+90 (555) 123 45 67</p>
                    <p><i class="fa fa-envelope me-2"></i>info@guzelliksalonu.com</p>
                    <div class="d-flex justify-content-start mt-4">
                        <a class="btn btn-sm-square btn-primary me-3" href="#"><i class="fab fa-twitter"></i></a>
                        <a class="btn btn-sm-square btn-primary me-3" href="#"><i class="fab fa-facebook-f"></i></a>
                        <a class="btn btn-sm-square btn-primary me-3" href="#"><i class="fab fa-linkedin-in"></i></a>
                        <a class="btn btn-sm-square btn-primary me-3" href="#"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>
                <div class="col-lg-6 ps-lg-5">
                    <div class="row g-4">

                        <div class="col-sm-6">
                            <h5 class="text-primary mb-4">Hızlı Menü</h5>

                            <a class="btn btn-link" href="#anasayfa">Anasayfa</a>

                            <a class="btn btn-link" href="#hakkimizda">Hakkımızda</a>

                            <a class="btn btn-link" href="#hizmetler">Hizmetlerimiz</a>

                            <a class="btn btn-link" href="#fiyatlar">Fiyat Listesi</a>

                            <a class="btn btn-link" href="#ekibimiz">Ekibimiz</a>

                            <a class="btn btn-link" href="#iletisim">İletişim</a>
                        </div>

                        <div class="col-sm-6">
                            <h5 class="text-primary mb-4">Kurumsal</h5>

                            <a class="btn btn-link" href="#hakkimizda">Biz Kimiz?</a>

                            <a class="btn btn-link" href="#hizmetler">Hizmetler</a>

                            <a class="btn btn-link" href="#ekibimiz">Uzman Kadromuz</a>

                            <a class="btn btn-link" href="#iletisim">Bize Ulaşın</a>

                            <a class="btn btn-link" asp-controller="Appointment" asp-action="Book">
                                Randevu Oluştur
                            </a>
                        </div>

                        <div class="col-sm-12">
                            <h5 class="text-primary mb-4">Bültenimize Abone Olun</h5>

                            <div class="position-relative w-100 mb-2">
                                <input class="form-control bg-secondary border-0 w-100 ps-4 pe-5"
                                       type="email"
                                       placeholder="E-posta adresinizi giriniz"
                                       style="height:60px;">

                                <button type="button"
                                        class="btn shadow-none position-absolute top-0 end-0 mt-2 me-2">
                                    <i class="fa fa-paper-plane text-primary fs-4"></i>
                                </button>
                            </div>

                            <p class="mb-0">
                                Kampanya, indirim ve yeni hizmetlerimizden ilk siz haberdar olun.
                            </p>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Footer End -->
    <!-- Copyright Start -->
    <div class="container-fluid bg-dark text-white border-top border-secondary py-4 wow fadeIn" data-wow-delay="0.1s">
        <div class="container">
            <div class="row">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    &copy; <a class="border-bottom" href="#">Kuaför Randevu Sistemi</a>, Tüm Hakları Saklıdır.
                </div>
            </div>
        </div>
    </div>
    <!-- Copyright End -->
    <!-- Back to Top -->
    <a href="#" class="btn btn-lg btn-primary btn-lg-square back-to-top"><i class="bi bi-arrow-up"></i></a>


    <!-- JavaScript Libraries -->
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/salone-1.0.0/lib/wow/wow.min.js"></script>
    <script src="~/salone-1.0.0/lib/easing/easing.min.js"></script>
    <script src="~/salone-1.0.0/lib/waypoints/waypoints.min.js"></script>
    <script src="~/salone-1.0.0/lib/counterup/counterup.min.js"></script>
    <script src="~/salone-1.0.0/lib/lightbox/js/lightbox.min.js"></script>
    <script src="~/salone-1.0.0/lib/owlcarousel/owl.carousel.min.js"></script>

    <!-- Template Javascript -->
    <script src="~/salone-1.0.0/js/main.js"></script>
</body>

</html>