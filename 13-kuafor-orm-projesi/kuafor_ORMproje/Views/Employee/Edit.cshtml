@model kuafor_ORMproje.Model.Employee

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Çalışan Düzenle";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Çalışan Bilgilerini Düzenle</h5>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="bx bx-arrow-back me-1"></i> Listeye Dön
                </a>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    
                    <input type="hidden" asp-for="Id" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="FullName">Ad Soyad</label>
                        <div class="input-group input-group-merge">
                            <span class="input-group-text"><i class="bx bx-user"></i></span>
                            <input asp-for="FullName" class="form-control" required />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="Speciality">Uzmanlık Alanı / Rol</label>
                        <div class="input-group input-group-merge">
                            <span class="input-group-text"><i class="bx bx-star"></i></span>
                            <input asp-for="Speciality" class="form-control" required />
                        </div>
                        <span asp-validation-for="Speciality" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="Phone">Telefon</label>
                        <div class="input-group input-group-merge">
                            <span class="input-group-text"><i class="bx bx-phone"></i></span>
                            <input asp-for="Phone" class="form-control" required />
                        </div>
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="ImageUrl">Profil Fotoğrafı URL</label>
                        <div class="input-group input-group-merge">
                            <span class="input-group-text"><i class="bx bx-image"></i></span>
                            <input asp-for="ImageUrl" class="form-control" />
                        </div>
                        <span asp-validation-for="ImageUrl" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                            <label class="form-check-label" asp-for="IsActive">Çalışan Aktif mi?</label>
                        </div>
                        <span asp-validation-for="IsActive" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <button type="submit" class="btn btn-primary">Kaydet</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
