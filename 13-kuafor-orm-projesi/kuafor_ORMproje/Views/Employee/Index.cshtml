@model IEnumerable<kuafor_ORMproje.Model.Employee>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Çalışan Yönetimi";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Çalışan Uzman Listesi</h5>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bx bx-plus me-1"></i> Yeni Çalışan Ekle
        </a>
    </div>
    <div class="table-responsive text-nowrap">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th style="width: 80px;">Fotoğraf</th>
                    <th>Ad Soyad</th>
                    <th>Uzmanlık Alanı</th>
                    <th>Telefon</th>
                    <th>Durum</th>
                    <th style="width: 150px;">İşlemler</th>
                </tr>
            </thead>
            <tbody class="table-border-bottom-0">
                @if (Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <img src="@item.ImageUrl" alt="@item.FullName" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;" onerror="this.src='https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&w=100&q=80'" />
                            </td>
                            <td><strong>@item.FullName</strong></td>
                            <td>@item.Speciality</td>
                            <td>@item.Phone</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-label-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-label-danger">Pasif</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm" title="Düzenle">
                                        <i class="bx bx-edit-alt"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bu çalışanı silmek istediğinizden emin misiniz?');" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm" title="Sil">
                                            <i class="bx bx-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            Kayıtlı çalışan bulunamadı.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
