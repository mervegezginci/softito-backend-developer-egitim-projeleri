<div id="ekibimiz" class="container-fluid overflow-hidden py-5">
    <div class="container">
        <div class="text-center wow fadeIn" data-wow-delay="0.2s">
            <h1 class="font-dancing-script text-primary">Ekibimiz</h1>
            <h1 class="mb-5">Uzman Personellerimiz</h1>
        </div>
        <div class="row g-4 team">

            @foreach (var item in Model.Employees)
            {
                <div class="col-md-6 col-lg-3 wow fadeIn">

                    <div class="team-item position-relative overflow-hidden">

                        <img class="img-fluid w-100"
                             src="@item.ImageUrl"
                             alt="@item.FullName">

                        <div class="team-overlay">

                            <p class="text-primary mb-1">
                                @item.Speciality
                            </p>

                            <h4>
                                @item.FullName
                            </h4>

                            <div class="d-flex justify-content-center">

                                <a class="btn btn-dark btn-sm-square border-2 me-2" href="#">
                                    <i class="fab fa-facebook-f"></i>
                                </a>

                                <a class="btn btn-dark btn-sm-square border-2 me-2" href="#">
                                    <i class="fab fa-instagram"></i>
                                </a>

                                <a class="btn btn-dark btn-sm-square border-2" href="#">
                                    <i class="fab fa-linkedin-in"></i>
                                </a>

                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>
    </div>
</div>
