                    </div>
                </div>
            </div>
            <div class="col-md-3 wow fadeIn" data-wow-delay="0.4s">
                <div class="gallery-item h-100">
                    <img src="~/salone-1.0.0/img/gallery-5.jpg" class="img-fluid w-100 h-100" alt="">
                    <div class="gallery-icon">
